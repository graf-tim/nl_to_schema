    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE bookings (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    startdate TIMESTAMP NOT NULL,\n    enddate TIMESTAMP NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_bookings PRIMARY KEY (id),\n    CONSTRAINT fk_bookings_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE services (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    is_bookable BOOLEAN NOT NULL,\n    CONSTRAINT pk_services PRIMARY KEY (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE service_locations (\n    id INTEGER NOT NULL,\n    service_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    price DECIMAL(18,2),\n    CONSTRAINT pk_service_locations PRIMARY KEY (id),\n    CONSTRAINT fk_service_locations_service_id FOREIGN KEY (service_id) REFERENCES services (id),\n    CONSTRAINT fk_service_locations_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE booking_services (\n    id INTEGER NOT NULL,\n    booking_id INTEGER NOT NULL,\n    service_location_id INTEGER NOT NULL,\n    quantity INTEGER,\n    price_at_booking DECIMAL(18,2),\n    CONSTRAINT pk_booking_services PRIMARY KEY (id),\n    CONSTRAINT fk_booking_services_booking_id FOREIGN KEY (booking_id) REFERENCES bookings (id),\n    CONSTRAINT fk_booking_services_service_location_id FOREIGN KEY (service_location_id) REFERENCES service_locations (id)\n);\n\nCREATE TABLE spaces (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    capacity INTEGER NOT NULL,\n    description TEXT,\n    is_bookable BOOLEAN NOT NULL,\n    CONSTRAINT pk_spaces PRIMARY KEY (id)\n);\n\nCREATE TABLE space_locations (\n    id INTEGER NOT NULL,\n    space_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    price DECIMAL(18,2),\n    CONSTRAINT pk_space_locations PRIMARY KEY (id),\n    CONSTRAINT fk_space_locations_space_id FOREIGN KEY (space_id) REFERENCES spaces (id),\n    CONSTRAINT fk_space_locations_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE booking_spaces (\n    id INTEGER NOT NULL,\n    booking_id INTEGER NOT NULL,\n    space_location_id INTEGER NOT NULL,\n    price_at_booking DECIMAL(18,2),\n    CONSTRAINT pk_booking_spaces PRIMARY KEY (id),\n    CONSTRAINT fk_booking_spaces_booking_id FOREIGN KEY (booking_id) REFERENCES bookings (id),\n    CONSTRAINT fk_booking_spaces_space_location_id FOREIGN KEY (space_location_id) REFERENCES space_locations (id)\n);\n",
