    "final_ddl": "CREATE TABLE suppliers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_suppliers PRIMARY KEY (id)\n);\n\nCREATE TABLE fish (\n    id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    product_group VARCHAR(255) NOT NULL,\n    price_per_kg DECIMAL(18,2) NOT NULL,\n    condition VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_fish PRIMARY KEY (id),\n    CONSTRAINT fk_fish_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id)\n);\n\nCREATE TABLE sales (\n    id INTEGER NOT NULL,\n    fish_id INTEGER NOT NULL,\n    sale_date DATE NOT NULL,\n    quantity_kg DECIMAL(18,2) NOT NULL,\n    total_price DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_sales PRIMARY KEY (id),\n    CONSTRAINT fk_sales_fish_id FOREIGN KEY (fish_id) REFERENCES fish (id)\n);\n",
