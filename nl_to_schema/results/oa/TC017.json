    "final_ddl": "CREATE TABLE product_groups (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_product_groups PRIMARY KEY (id)\n);\n\nCREATE TABLE suppliers (\n    id INTEGER NOT NULL,\n    company_name VARCHAR(255) NOT NULL,\n    contact_person VARCHAR(255),\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_suppliers PRIMARY KEY (id)\n);\n\nCREATE TABLE products (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    sale_price DECIMAL(18,2) NOT NULL,\n    stock_quantity DECIMAL(18,2) NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    product_group_id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    CONSTRAINT pk_products PRIMARY KEY (id),\n    CONSTRAINT fk_products_product_group_id FOREIGN KEY (product_group_id) REFERENCES product_groups (id),\n    CONSTRAINT fk_products_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id)\n);\n",
