    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE shoes (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    brand VARCHAR(255) NOT NULL,\n    model VARCHAR(255) NOT NULL,\n    color VARCHAR(255) NOT NULL,\n    size VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_shoes PRIMARY KEY (id),\n    CONSTRAINT fk_shoes_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE repair_orders (\n    id INTEGER NOT NULL,\n    shoe_id INTEGER NOT NULL,\n    acceptance_date DATE NOT NULL,\n    desired_work TEXT NOT NULL,\n    is_completed BOOLEAN NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_repair_orders PRIMARY KEY (id),\n    CONSTRAINT fk_repair_orders_shoe_id FOREIGN KEY (shoe_id) REFERENCES shoes (id)\n);\n",
