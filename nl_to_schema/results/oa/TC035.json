    "final_ddl": "CREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    openingdate DATE NOT NULL,\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    address VARCHAR(255),\n    hiredate DATE NOT NULL,\n    primary_location_id INTEGER NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id),\n    CONSTRAINT fk_employees_primary_location_id FOREIGN KEY (primary_location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE assignments (\n    id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    startdate DATE NOT NULL,\n    enddate DATE,\n    CONSTRAINT pk_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_assignments_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE categories (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_categories PRIMARY KEY (id)\n);\n\nCREATE TABLE dishes (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    price DECIMAL(18,2) NOT NULL,\n    category_id INTEGER NOT NULL,\n    CONSTRAINT pk_dishes PRIMARY KEY (id),\n    CONSTRAINT fk_dishes_category_id FOREIGN KEY (category_id) REFERENCES categories (id)\n);\n\nCREATE TABLE ingredients (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    is_allergen BOOLEAN NOT NULL,\n    CONSTRAINT pk_ingredients PRIMARY KEY (id)\n);\n\nCREATE TABLE dish_ingredients (\n    id INTEGER NOT NULL,\n    dish_id INTEGER NOT NULL,\n    ingredient_id INTEGER NOT NULL,\n    CONSTRAINT pk_dish_ingredients PRIMARY KEY (id),\n    CONSTRAINT fk_dish_ingredients_dish_id FOREIGN KEY (dish_id) REFERENCES dishes (id),\n    CONSTRAINT fk_dish_ingredients_ingredient_id FOREIGN KEY (ingredient_id) REFERENCES ingredients (id)\n);\n\nCREATE TABLE offerings (\n    id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    dish_id INTEGER NOT NULL,\n    CONSTRAINT pk_offerings PRIMARY KEY (id),\n    CONSTRAINT fk_offerings_location_id FOREIGN KEY (location_id) REFERENCES locations (id),\n    CONSTRAINT fk_offerings_dish_id FOREIGN KEY (dish_id) REFERENCES dishes (id)\n);\n",
