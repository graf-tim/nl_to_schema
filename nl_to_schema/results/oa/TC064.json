    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    customer_number VARCHAR(255) NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    address VARCHAR(255),\n    customer_type VARCHAR(255) NOT NULL,\n    care_start_date DATE NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE consumption_points (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    meter_number VARCHAR(255) NOT NULL,\n    energy_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_consumption_points PRIMARY KEY (id),\n    CONSTRAINT fk_consumption_points_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE contracts (\n    id INTEGER NOT NULL,\n    consumption_point_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    planned_end_date DATE,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_contracts PRIMARY KEY (id),\n    CONSTRAINT fk_contracts_consumption_point_id FOREIGN KEY (consumption_point_id) REFERENCES consumption_points (id)\n);\n\nCREATE TABLE tariffs (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    base_price DECIMAL(18,2) NOT NULL,\n    work_price DECIMAL(18,2) NOT NULL,\n    product VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_tariffs PRIMARY KEY (id)\n);\n\nCREATE TABLE contract_tariffs (\n    contract_id INTEGER NOT NULL,\n    tariff_id INTEGER NOT NULL,\n    sequence INTEGER,\n    valid_from_date DATE,\n    valid_to_date DATE,\n    CONSTRAINT pk_contract_tariffs PRIMARY KEY (contract_id, tariff_id),\n    CONSTRAINT fk_contract_tariffs_contract_id FOREIGN KEY (contract_id) REFERENCES contracts (id),\n    CONSTRAINT fk_contract_tariffs_tariff_id FOREIGN KEY (tariff_id) REFERENCES tariffs (id)\n);\n\nCREATE TABLE service_packages (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_service_packages PRIMARY KEY (id)\n);\n\nCREATE TABLE customer_service_packages (\n    customer_id INTEGER NOT NULL,\n    service_package_id INTEGER NOT NULL,\n    valid_from_date DATE NOT NULL,\n    valid_to_date DATE,\n    CONSTRAINT pk_customer_service_packages PRIMARY KEY (customer_id, service_package_id),\n    CONSTRAINT fk_customer_service_packages_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_customer_service_packages_service_package_id FOREIGN KEY (service_package_id) REFERENCES service_packages (id)\n);\n\nCREATE TABLE invoices (\n    id INTEGER NOT NULL,\n    contract_id INTEGER NOT NULL,\n    invoice_date DATE NOT NULL,\n    period_start_date DATE NOT NULL,\n    period_end_date DATE NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    payment_status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_invoices PRIMARY KEY (id),\n    CONSTRAINT fk_invoices_contract_id FOREIGN KEY (contract_id) REFERENCES contracts (id)\n);\n",
