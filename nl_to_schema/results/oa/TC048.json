    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    address TEXT,\n    customer_since DATE NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE products (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    product_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_products PRIMARY KEY (id)\n);\n\nCREATE TABLE devices (\n    id INTEGER NOT NULL,\n    serial_number VARCHAR(255) NOT NULL,\n    product_id INTEGER NOT NULL,\n    CONSTRAINT pk_devices PRIMARY KEY (id),\n    CONSTRAINT fk_devices_product_id FOREIGN KEY (product_id) REFERENCES products (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id)\n);\n\nCREATE TABLE specialties (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_specialties PRIMARY KEY (id)\n);\n\nCREATE TABLE employee_specialties (\n    employee_id INTEGER NOT NULL,\n    specialty_id INTEGER NOT NULL,\n    CONSTRAINT pk_employee_specialties PRIMARY KEY (employee_id, specialty_id),\n    CONSTRAINT fk_employee_specialties_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_employee_specialties_specialty_id FOREIGN KEY (specialty_id) REFERENCES specialties (id)\n);\n\nCREATE TABLE requests (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    device_id INTEGER,\n    received_at TIMESTAMP NOT NULL,\n    description TEXT NOT NULL,\n    urgency VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    solution_description TEXT,\n    resolved_at TIMESTAMP,\n    CONSTRAINT pk_requests PRIMARY KEY (id),\n    CONSTRAINT fk_requests_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_requests_device_id FOREIGN KEY (device_id) REFERENCES devices (id)\n);\n\nCREATE TABLE request_assignments (\n    request_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    assigned_at TIMESTAMP NOT NULL,\n    sequence INTEGER,\n    CONSTRAINT pk_request_assignments PRIMARY KEY (request_id, employee_id),\n    CONSTRAINT fk_request_assignments_request_id FOREIGN KEY (request_id) REFERENCES requests (id),\n    CONSTRAINT fk_request_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n",
