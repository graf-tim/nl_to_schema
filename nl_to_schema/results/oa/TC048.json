    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    address TEXT,\n    customer_since DATE NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE products (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    product_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_products PRIMARY KEY (id)\n);\n\nCREATE TABLE devices (\n    id INTEGER NOT NULL,\n    serial_number VARCHAR(255) NOT NULL,\n    product_id INTEGER NOT NULL,\n    CONSTRAINT pk_devices PRIMARY KEY (id),\n    CONSTRAINT fk_devices_product_id FOREIGN KEY (product_id) REFERENCES products (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id)\n);\n\nCREATE TABLE specializations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_specializations PRIMARY KEY (id)\n);\n\nCREATE TABLE employee_specializations (\n    employee_id INTEGER NOT NULL,\n    specialization_id INTEGER NOT NULL,\n    CONSTRAINT pk_employee_specializations PRIMARY KEY (employee_id, specialization_id),\n    CONSTRAINT fk_employee_specializations_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_employee_specializations_specialization_id FOREIGN KEY (specialization_id) REFERENCES specializations (id)\n);\n\nCREATE TABLE issues (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    device_id INTEGER,\n    received_at TIMESTAMP NOT NULL,\n    description TEXT NOT NULL,\n    urgency VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    solution_description TEXT,\n    resolved_at TIMESTAMP,\n    CONSTRAINT pk_issues PRIMARY KEY (id),\n    CONSTRAINT fk_issues_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_issues_device_id FOREIGN KEY (device_id) REFERENCES devices (id)\n);\n\nCREATE TABLE issue_assignments (\n    issue_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    assigned_at TIMESTAMP NOT NULL,\n    role VARCHAR(255),\n    CONSTRAINT pk_issue_assignments PRIMARY KEY (issue_id, employee_id),\n    CONSTRAINT fk_issue_assignments_issue_id FOREIGN KEY (issue_id) REFERENCES issues (id),\n    CONSTRAINT fk_issue_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n",
