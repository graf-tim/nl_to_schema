    "final_ddl": "CREATE TABLE departments (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_departments PRIMARY KEY (id)\n);\n\nCREATE TABLE functions (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    category VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_functions PRIMARY KEY (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address VARCHAR(255),\n    hire_date DATE NOT NULL,\n    department_id INTEGER NOT NULL,\n    function_id INTEGER NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id),\n    CONSTRAINT fk_employees_department_id FOREIGN KEY (department_id) REFERENCES departments (id),\n    CONSTRAINT fk_employees_function_id FOREIGN KEY (function_id) REFERENCES functions (id)\n);\n\nCREATE TABLE department_managers (\n    id INTEGER NOT NULL,\n    department_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    valid_from DATE NOT NULL,\n    valid_until DATE,\n    CONSTRAINT pk_department_managers PRIMARY KEY (id),\n    CONSTRAINT fk_department_managers_department_id FOREIGN KEY (department_id) REFERENCES departments (id),\n    CONSTRAINT fk_department_managers_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n\nCREATE TABLE projects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    planned_start_date DATE NOT NULL,\n    planned_end_date DATE NOT NULL,\n    budget DECIMAL(18,2),\n    CONSTRAINT pk_projects PRIMARY KEY (id)\n);\n\nCREATE TABLE project_assignments (\n    id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    task VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_project_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_project_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_project_assignments_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE trainings (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_trainings PRIMARY KEY (id)\n);\n\nCREATE TABLE training_participations (\n    id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    training_id INTEGER NOT NULL,\n    participation_date DATE NOT NULL,\n    CONSTRAINT pk_training_participations PRIMARY KEY (id),\n    CONSTRAINT fk_training_participations_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_training_participations_training_id FOREIGN KEY (training_id) REFERENCES trainings (id)\n);\n\nCREATE TABLE training_relevances (\n    id INTEGER NOT NULL,\n    training_id INTEGER NOT NULL,\n    function_id INTEGER NOT NULL,\n    relevance_level VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_training_relevances PRIMARY KEY (id),\n    CONSTRAINT fk_training_relevances_training_id FOREIGN KEY (training_id) REFERENCES trainings (id),\n    CONSTRAINT fk_training_relevances_function_id FOREIGN KEY (function_id) REFERENCES functions (id)\n);\n",
