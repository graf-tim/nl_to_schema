    "final_ddl": "CREATE TABLE branches (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_branches PRIMARY KEY (id)\n);\n\nCREATE TABLE accounts (\n    id INTEGER NOT NULL,\n    account_type VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    branch_id INTEGER NOT NULL,\n    CONSTRAINT pk_accounts PRIMARY KEY (id),\n    CONSTRAINT fk_accounts_branch_id FOREIGN KEY (branch_id) REFERENCES branches (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    address VARCHAR(255),\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE account_holders (\n    account_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    access_rights VARCHAR(255),\n    CONSTRAINT pk_account_holders PRIMARY KEY (account_id, person_id),\n    CONSTRAINT fk_account_holders_account_id FOREIGN KEY (account_id) REFERENCES accounts (id),\n    CONSTRAINT fk_account_holders_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    branch_id INTEGER NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id),\n    CONSTRAINT fk_employees_branch_id FOREIGN KEY (branch_id) REFERENCES branches (id)\n);\n\nCREATE TABLE employee_customers (\n    employee_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    care_since DATE,\n    CONSTRAINT pk_employee_customers PRIMARY KEY (employee_id, person_id),\n    CONSTRAINT fk_employee_customers_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_employee_customers_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE transactions (\n    id INTEGER NOT NULL,\n    account_id INTEGER NOT NULL,\n    transaction_date DATE NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    transaction_type VARCHAR(255) NOT NULL,\n    purpose TEXT,\n    CONSTRAINT pk_transactions PRIMARY KEY (id),\n    CONSTRAINT fk_transactions_account_id FOREIGN KEY (account_id) REFERENCES accounts (id)\n);\n",
