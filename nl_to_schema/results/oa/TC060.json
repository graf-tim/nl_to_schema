    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    contact_address VARCHAR(255),\n    email VARCHAR(255),\n    phone_number VARCHAR(255),\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE specializations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_specializations PRIMARY KEY (id)\n);\n\nCREATE TABLE requests (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    specialization_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    description TEXT NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_requests PRIMARY KEY (id),\n    CONSTRAINT fk_requests_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_requests_specialization_id FOREIGN KEY (specialization_id) REFERENCES specializations (id)\n);\n\nCREATE TABLE businesses (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    contact_address VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone_number VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_businesses PRIMARY KEY (id)\n);\n\nCREATE TABLE awards (\n    id INTEGER NOT NULL,\n    request_id INTEGER NOT NULL,\n    business_id INTEGER NOT NULL,\n    awarded_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_awards PRIMARY KEY (id),\n    CONSTRAINT fk_awards_request_id FOREIGN KEY (request_id) REFERENCES requests (id),\n    CONSTRAINT fk_awards_business_id FOREIGN KEY (business_id) REFERENCES businesses (id)\n);\n\nCREATE TABLE bids (\n    id INTEGER NOT NULL,\n    request_id INTEGER NOT NULL,\n    business_id INTEGER NOT NULL,\n    bid_at TIMESTAMP NOT NULL,\n    price DECIMAL(18,2),\n    message TEXT,\n    CONSTRAINT pk_bids PRIMARY KEY (id),\n    CONSTRAINT fk_bids_request_id FOREIGN KEY (request_id) REFERENCES requests (id),\n    CONSTRAINT fk_bids_business_id FOREIGN KEY (business_id) REFERENCES businesses (id)\n);\n\nCREATE TABLE business_specializations (\n    business_id INTEGER NOT NULL,\n    specialization_id INTEGER NOT NULL,\n    CONSTRAINT pk_business_specializations PRIMARY KEY (business_id, specialization_id),\n    CONSTRAINT fk_business_specializations_business_id FOREIGN KEY (business_id) REFERENCES businesses (id),\n    CONSTRAINT fk_business_specializations_specialization_id FOREIGN KEY (specialization_id) REFERENCES specializations (id)\n);\n",
