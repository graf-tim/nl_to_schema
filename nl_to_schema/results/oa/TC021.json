    "final_ddl": "CREATE TABLE plant_species (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_plant_species PRIMARY KEY (id)\n);\n\nCREATE TABLE suppliers (\n    id INTEGER NOT NULL,\n    company_name VARCHAR(255) NOT NULL,\n    contact_person VARCHAR(255),\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_suppliers PRIMARY KEY (id)\n);\n\nCREATE TABLE plants (\n    id INTEGER NOT NULL,\n    sales_name VARCHAR(255) NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    stock_quantity INTEGER NOT NULL,\n    is_for_sale BOOLEAN NOT NULL,\n    plant_species_id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    CONSTRAINT pk_plants PRIMARY KEY (id),\n    CONSTRAINT fk_plants_plant_species_id FOREIGN KEY (plant_species_id) REFERENCES plant_species (id),\n    CONSTRAINT fk_plants_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id)\n);\n",
