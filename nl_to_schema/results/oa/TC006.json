    "final_ddl": "CREATE TABLE teachers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phonenumber VARCHAR(255),\n    hiredate DATE NOT NULL,\n    CONSTRAINT pk_teachers PRIMARY KEY (id)\n);\n\nCREATE TABLE subjects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    monthly_fee DECIMAL(18,2) NOT NULL,\n    teacher_id INTEGER NOT NULL,\n    CONSTRAINT pk_subjects PRIMARY KEY (id),\n    CONSTRAINT fk_subjects_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id)\n);\n\nCREATE TABLE students (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    phonenumber VARCHAR(255),\n    enrollmentdate DATE NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    subject_id INTEGER NOT NULL,\n    CONSTRAINT pk_students PRIMARY KEY (id),\n    CONSTRAINT fk_students_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id)\n);\n",
