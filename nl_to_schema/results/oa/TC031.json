    "final_ddl": "CREATE TABLE stations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    available_parking_spaces INTEGER NOT NULL,\n    CONSTRAINT pk_stations PRIMARY KEY (id)\n);\n\nCREATE TABLE bicycles (\n    id INTEGER NOT NULL,\n    internal_number VARCHAR(255) NOT NULL,\n    brand VARCHAR(255) NOT NULL,\n    model VARCHAR(255) NOT NULL,\n    bicycle_type VARCHAR(255) NOT NULL,\n    current_condition VARCHAR(255) NOT NULL,\n    station_id INTEGER NOT NULL,\n    CONSTRAINT pk_bicycles PRIMARY KEY (id),\n    CONSTRAINT fk_bicycles_station_id FOREIGN KEY (station_id) REFERENCES stations (id)\n);\n\nCREATE TABLE customers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    registration_date DATE NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE rentals (\n    id INTEGER NOT NULL,\n    bicycle_id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    rental_start_date TIMESTAMP NOT NULL,\n    planned_end_date TIMESTAMP NOT NULL,\n    CONSTRAINT pk_rentals PRIMARY KEY (id),\n    CONSTRAINT fk_rentals_bicycle_id FOREIGN KEY (bicycle_id) REFERENCES bicycles (id),\n    CONSTRAINT fk_rentals_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n",
