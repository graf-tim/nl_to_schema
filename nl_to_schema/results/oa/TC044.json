    "final_ddl": "CREATE TABLE advisors (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_advisors PRIMARY KEY (id)\n);\n\nCREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address VARCHAR(255),\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    care_start_date DATE NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE insurance_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_insurance_types PRIMARY KEY (id)\n);\n\nCREATE TABLE contracts (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    insurance_type_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    planned_end_date DATE,\n    status VARCHAR(255) NOT NULL,\n    regular_premium DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_contracts PRIMARY KEY (id),\n    CONSTRAINT fk_contracts_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_contracts_insurance_type_id FOREIGN KEY (insurance_type_id) REFERENCES insurance_types (id)\n);\n\nCREATE TABLE customer_advisors (\n    customer_id INTEGER NOT NULL,\n    advisor_id INTEGER NOT NULL,\n    care_start_date DATE NOT NULL,\n    CONSTRAINT pk_customer_advisors PRIMARY KEY (customer_id, advisor_id),\n    CONSTRAINT fk_customer_advisors_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_customer_advisors_advisor_id FOREIGN KEY (advisor_id) REFERENCES advisors (id)\n);\n\nCREATE TABLE damage_claims (\n    id INTEGER NOT NULL,\n    contract_id INTEGER NOT NULL,\n    advisor_id INTEGER NOT NULL,\n    report_date DATE NOT NULL,\n    description TEXT NOT NULL,\n    processed_amount DECIMAL(18,2),\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_damage_claims PRIMARY KEY (id),\n    CONSTRAINT fk_damage_claims_contract_id FOREIGN KEY (contract_id) REFERENCES contracts (id),\n    CONSTRAINT fk_damage_claims_advisor_id FOREIGN KEY (advisor_id) REFERENCES advisors (id)\n);\n",
