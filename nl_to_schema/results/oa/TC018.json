    "final_ddl": "CREATE TABLE groups (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    age_range VARCHAR(255) NOT NULL,\n    group_room VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_groups PRIMARY KEY (id)\n);\n\nCREATE TABLE caregivers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    hire_date DATE NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    group_id INTEGER NOT NULL,\n    is_leader BOOLEAN NOT NULL,\n    CONSTRAINT pk_caregivers PRIMARY KEY (id),\n    CONSTRAINT fk_caregivers_group_id FOREIGN KEY (group_id) REFERENCES groups (id)\n);\n\nCREATE TABLE children (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    admission_date DATE NOT NULL,\n    special_notes TEXT,\n    group_id INTEGER NOT NULL,\n    CONSTRAINT pk_children PRIMARY KEY (id),\n    CONSTRAINT fk_children_group_id FOREIGN KEY (group_id) REFERENCES groups (id)\n);\n",
