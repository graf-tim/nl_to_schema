    "final_ddl": "CREATE TABLE destinations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    country VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_destinations PRIMARY KEY (id)\n);\n\nCREATE TABLE trips (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    startdate DATE NOT NULL,\n    enddate DATE NOT NULL,\n    baseprice DECIMAL(18,2) NOT NULL,\n    destination_id INTEGER NOT NULL,\n    CONSTRAINT pk_trips PRIMARY KEY (id),\n    CONSTRAINT fk_trips_destination_id FOREIGN KEY (destination_id) REFERENCES destinations (id)\n);\n\nCREATE TABLE bookings (\n    id INTEGER NOT NULL,\n    trip_id INTEGER NOT NULL,\n    bookingdate DATE NOT NULL,\n    paid BOOLEAN NOT NULL,\n    contact_email VARCHAR(255) NOT NULL,\n    contact_phone VARCHAR(255),\n    contact_address TEXT,\n    CONSTRAINT pk_bookings PRIMARY KEY (id),\n    CONSTRAINT fk_bookings_trip_id FOREIGN KEY (trip_id) REFERENCES trips (id)\n);\n\nCREATE TABLE travelers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    CONSTRAINT pk_travelers PRIMARY KEY (id)\n);\n\nCREATE TABLE booking_travelers (\n    booking_id INTEGER NOT NULL,\n    traveler_id INTEGER NOT NULL,\n    sequence INTEGER,\n    CONSTRAINT pk_booking_travelers PRIMARY KEY (booking_id, traveler_id),\n    CONSTRAINT fk_booking_travelers_booking_id FOREIGN KEY (booking_id) REFERENCES bookings (id),\n    CONSTRAINT fk_booking_travelers_traveler_id FOREIGN KEY (traveler_id) REFERENCES travelers (id)\n);\n\nCREATE TABLE service_partners (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    partner_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_service_partners PRIMARY KEY (id)\n);\n\nCREATE TABLE service_partner_trips (\n    service_partner_id INTEGER NOT NULL,\n    trip_id INTEGER NOT NULL,\n    service_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_service_partner_trips PRIMARY KEY (service_partner_id, trip_id),\n    CONSTRAINT fk_service_partner_trips_service_partner_id FOREIGN KEY (service_partner_id) REFERENCES service_partners (id),\n    CONSTRAINT fk_service_partner_trips_trip_id FOREIGN KEY (trip_id) REFERENCES trips (id)\n);\n",
