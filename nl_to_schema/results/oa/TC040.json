    "final_ddl": "CREATE TABLE additional_services (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_additional_services PRIMARY KEY (id)\n);\n\nCREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    phone_number VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    driver_license_number VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE manufacturers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_manufacturers PRIMARY KEY (id)\n);\n\nCREATE TABLE vehicles (\n    id INTEGER NOT NULL,\n    license_plate VARCHAR(255) NOT NULL,\n    model_designation VARCHAR(255) NOT NULL,\n    year_of_manufacture INTEGER NOT NULL,\n    mileage INTEGER NOT NULL,\n    daily_price DECIMAL(18,2) NOT NULL,\n    availability_status VARCHAR(255) NOT NULL,\n    manufacturer_id INTEGER NOT NULL,\n    CONSTRAINT pk_vehicles PRIMARY KEY (id),\n    CONSTRAINT fk_vehicles_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id)\n);\n\nCREATE TABLE rentals (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    vehicle_id INTEGER NOT NULL,\n    pickup_timestamp TIMESTAMP NOT NULL,\n    planned_return_timestamp TIMESTAMP NOT NULL,\n    actual_return_timestamp TIMESTAMP,\n    pickup_location_id INTEGER NOT NULL,\n    return_location_id INTEGER NOT NULL,\n    CONSTRAINT pk_rentals PRIMARY KEY (id),\n    CONSTRAINT fk_rentals_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_rentals_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id),\n    CONSTRAINT fk_rentals_pickup_location_id FOREIGN KEY (pickup_location_id) REFERENCES locations (id),\n    CONSTRAINT fk_rentals_return_location_id FOREIGN KEY (return_location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE rental_additional_services (\n    rental_id INTEGER NOT NULL,\n    additional_service_id INTEGER NOT NULL,\n    CONSTRAINT pk_rental_additional_services PRIMARY KEY (rental_id, additional_service_id),\n    CONSTRAINT fk_rental_additional_services_rental_id FOREIGN KEY (rental_id) REFERENCES rentals (id),\n    CONSTRAINT fk_rental_additional_services_additional_service_id FOREIGN KEY (additional_service_id) REFERENCES additional_services (id)\n);\n\nCREATE TABLE vehicle_locations (\n    vehicle_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    CONSTRAINT pk_vehicle_locations PRIMARY KEY (vehicle_id, location_id),\n    CONSTRAINT fk_vehicle_locations_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id),\n    CONSTRAINT fk_vehicle_locations_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n",
