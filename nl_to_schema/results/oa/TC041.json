    "final_ddl": "CREATE TABLE departments (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_departments PRIMARY KEY (id)\n);\n\nCREATE TABLE courses (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    duration INTEGER NOT NULL,\n    department_id INTEGER NOT NULL,\n    CONSTRAINT pk_courses PRIMARY KEY (id),\n    CONSTRAINT fk_courses_department_id FOREIGN KEY (department_id) REFERENCES departments (id)\n);\n\nCREATE TABLE instructors (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    contact VARCHAR(255),\n    CONSTRAINT pk_instructors PRIMARY KEY (id)\n);\n\nCREATE TABLE course_assignments (\n    id INTEGER NOT NULL,\n    course_id INTEGER NOT NULL,\n    instructor_id INTEGER NOT NULL,\n    CONSTRAINT pk_course_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_course_assignments_course_id FOREIGN KEY (course_id) REFERENCES courses (id),\n    CONSTRAINT fk_course_assignments_instructor_id FOREIGN KEY (instructor_id) REFERENCES instructors (id)\n);\n\nCREATE TABLE course_instances (\n    id INTEGER NOT NULL,\n    course_id INTEGER NOT NULL,\n    startdate DATE NOT NULL,\n    enddate DATE NOT NULL,\n    location VARCHAR(255),\n    capacity INTEGER NOT NULL,\n    is_released BOOLEAN NOT NULL,\n    CONSTRAINT pk_course_instances PRIMARY KEY (id),\n    CONSTRAINT fk_course_instances_course_id FOREIGN KEY (course_id) REFERENCES courses (id)\n);\n\nCREATE TABLE course_instance_assignments (\n    id INTEGER NOT NULL,\n    course_instance_id INTEGER NOT NULL,\n    instructor_id INTEGER NOT NULL,\n    CONSTRAINT pk_course_instance_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_course_instance_assignments_course_instance_id FOREIGN KEY (course_instance_id) REFERENCES course_instances (id),\n    CONSTRAINT fk_course_instance_assignments_instructor_id FOREIGN KEY (instructor_id) REFERENCES instructors (id)\n);\n\nCREATE TABLE participants (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    contact VARCHAR(255),\n    CONSTRAINT pk_participants PRIMARY KEY (id)\n);\n\nCREATE TABLE enrollments (\n    id INTEGER NOT NULL,\n    participant_id INTEGER NOT NULL,\n    course_instance_id INTEGER NOT NULL,\n    enrollment_date TIMESTAMP NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_enrollments PRIMARY KEY (id),\n    CONSTRAINT fk_enrollments_participant_id FOREIGN KEY (participant_id) REFERENCES participants (id),\n    CONSTRAINT fk_enrollments_course_instance_id FOREIGN KEY (course_instance_id) REFERENCES course_instances (id)\n);\n",
