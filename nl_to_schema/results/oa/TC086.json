    "final_ddl": "CREATE TABLE employees (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    general_role VARCHAR(255),\n    CONSTRAINT pk_employees PRIMARY KEY (id)\n);\n\nCREATE TABLE teams (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    discipline VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_teams PRIMARY KEY (id)\n);\n\nCREATE TABLE employee_team_roles (\n    employee_id INTEGER NOT NULL,\n    team_id INTEGER NOT NULL,\n    team_role VARCHAR(255),\n    CONSTRAINT pk_employee_team_roles PRIMARY KEY (employee_id, team_id),\n    CONSTRAINT fk_employee_team_roles_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_employee_team_roles_team_id FOREIGN KEY (team_id) REFERENCES teams (id)\n);\n\nCREATE TABLE manufacturers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_manufacturers PRIMARY KEY (id)\n);\n\nCREATE TABLE programs (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    parent_program_id INTEGER,\n    CONSTRAINT pk_programs PRIMARY KEY (id),\n    CONSTRAINT fk_programs_parent_program_id FOREIGN KEY (parent_program_id) REFERENCES programs (id)\n);\n\nCREATE TABLE missions (\n    id INTEGER NOT NULL,\n    internal_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    planned_start DATE NOT NULL,\n    actual_start DATE,\n    mission_end DATE,\n    mission_type VARCHAR(255) NOT NULL,\n    program_id INTEGER NOT NULL,\n    CONSTRAINT pk_missions PRIMARY KEY (id),\n    CONSTRAINT fk_missions_program_id FOREIGN KEY (program_id) REFERENCES programs (id)\n);\n\nCREATE TABLE milestones (\n    id INTEGER NOT NULL,\n    milestone_type VARCHAR(255) NOT NULL,\n    milestone_date DATE NOT NULL,\n    mission_id INTEGER NOT NULL,\n    CONSTRAINT pk_milestones PRIMARY KEY (id),\n    CONSTRAINT fk_milestones_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id)\n);\n\nCREATE TABLE spacecrafts (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    spacecraft_type VARCHAR(255) NOT NULL,\n    manufacturer_id INTEGER NOT NULL,\n    CONSTRAINT pk_spacecrafts PRIMARY KEY (id),\n    CONSTRAINT fk_spacecrafts_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id)\n);\n\nCREATE TABLE mission_spacecrafts (\n    mission_id INTEGER NOT NULL,\n    spacecraft_id INTEGER NOT NULL,\n    CONSTRAINT pk_mission_spacecrafts PRIMARY KEY (mission_id, spacecraft_id),\n    CONSTRAINT fk_mission_spacecrafts_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id),\n    CONSTRAINT fk_mission_spacecrafts_spacecraft_id FOREIGN KEY (spacecraft_id) REFERENCES spacecrafts (id)\n);\n\nCREATE TABLE mission_teams (\n    mission_id INTEGER NOT NULL,\n    team_id INTEGER NOT NULL,\n    CONSTRAINT pk_mission_teams PRIMARY KEY (mission_id, team_id),\n    CONSTRAINT fk_mission_teams_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id),\n    CONSTRAINT fk_mission_teams_team_id FOREIGN KEY (team_id) REFERENCES teams (id)\n);\n\nCREATE TABLE risks (\n    id INTEGER NOT NULL,\n    description TEXT NOT NULL,\n    probability DECIMAL(18,2) NOT NULL,\n    impact DECIMAL(18,2) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    mission_id INTEGER,\n    spacecraft_id INTEGER,\n    team_id INTEGER,\n    CONSTRAINT pk_risks PRIMARY KEY (id),\n    CONSTRAINT fk_risks_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id),\n    CONSTRAINT fk_risks_spacecraft_id FOREIGN KEY (spacecraft_id) REFERENCES spacecrafts (id),\n    CONSTRAINT fk_risks_team_id FOREIGN KEY (team_id) REFERENCES teams (id)\n);\n",
