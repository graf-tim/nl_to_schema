    "final_ddl": "CREATE TABLE owners (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_owners PRIMARY KEY (id)\n);\n\nCREATE TABLE dogs (\n    id INTEGER NOT NULL,\n    owner_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    gender VARCHAR(255) NOT NULL,\n    special_notes TEXT,\n    CONSTRAINT pk_dogs PRIMARY KEY (id),\n    CONSTRAINT fk_dogs_owner_id FOREIGN KEY (owner_id) REFERENCES owners (id)\n);\n\nCREATE TABLE stays (\n    id INTEGER NOT NULL,\n    dog_id INTEGER NOT NULL,\n    arrival_date DATE NOT NULL,\n    departure_date DATE,\n    feeding_plan_required BOOLEAN NOT NULL,\n    CONSTRAINT pk_stays PRIMARY KEY (id),\n    CONSTRAINT fk_stays_dog_id FOREIGN KEY (dog_id) REFERENCES dogs (id)\n);\n",
