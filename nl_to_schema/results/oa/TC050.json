    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE delivery_addresses (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    street VARCHAR(255) NOT NULL,\n    house_number VARCHAR(255) NOT NULL,\n    postal_code VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    address_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_delivery_addresses PRIMARY KEY (id),\n    CONSTRAINT fk_delivery_addresses_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE restaurants (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    street VARCHAR(255) NOT NULL,\n    house_number VARCHAR(255) NOT NULL,\n    postal_code VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    cuisine VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_restaurants PRIMARY KEY (id)\n);\n\nCREATE TABLE dishes (\n    id INTEGER NOT NULL,\n    restaurant_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    price DECIMAL(18,2) NOT NULL,\n    is_available BOOLEAN NOT NULL,\n    CONSTRAINT pk_dishes PRIMARY KEY (id),\n    CONSTRAINT fk_dishes_restaurant_id FOREIGN KEY (restaurant_id) REFERENCES restaurants (id)\n);\n\nCREATE TABLE orders (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    delivery_address_id INTEGER NOT NULL,\n    received_at TIMESTAMP NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    total_amount DECIMAL(18,2) NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_orders PRIMARY KEY (id),\n    CONSTRAINT fk_orders_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_orders_delivery_address_id FOREIGN KEY (delivery_address_id) REFERENCES delivery_addresses (id)\n);\n\nCREATE TABLE order_dishes (\n    order_id INTEGER NOT NULL,\n    dish_id INTEGER NOT NULL,\n    quantity INTEGER NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_order_dishes PRIMARY KEY (order_id, dish_id),\n    CONSTRAINT fk_order_dishes_order_id FOREIGN KEY (order_id) REFERENCES orders (id),\n    CONSTRAINT fk_order_dishes_dish_id FOREIGN KEY (dish_id) REFERENCES dishes (id)\n);\n",
