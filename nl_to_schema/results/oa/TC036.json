    "final_ddl": "CREATE TABLE teachers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    hire_date DATE NOT NULL,\n    CONSTRAINT pk_teachers PRIMARY KEY (id)\n);\n\nCREATE TABLE learning_groups (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    school_year VARCHAR(255) NOT NULL,\n    class_teacher_id INTEGER NOT NULL,\n    CONSTRAINT pk_learning_groups PRIMARY KEY (id),\n    CONSTRAINT fk_learning_groups_class_teacher_id FOREIGN KEY (class_teacher_id) REFERENCES teachers (id)\n);\n\nCREATE TABLE students (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    address VARCHAR(255),\n    birthdate DATE NOT NULL,\n    learning_group_id INTEGER NOT NULL,\n    CONSTRAINT pk_students PRIMARY KEY (id),\n    CONSTRAINT fk_students_learning_group_id FOREIGN KEY (learning_group_id) REFERENCES learning_groups (id)\n);\n\nCREATE TABLE subjects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_subjects PRIMARY KEY (id)\n);\n\nCREATE TABLE performance_assessments (\n    id INTEGER NOT NULL,\n    date DATE NOT NULL,\n    topic VARCHAR(255) NOT NULL,\n    subject_id INTEGER NOT NULL,\n    CONSTRAINT pk_performance_assessments PRIMARY KEY (id),\n    CONSTRAINT fk_performance_assessments_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id)\n);\n\nCREATE TABLE grades (\n    id INTEGER NOT NULL,\n    value DECIMAL(18,2) NOT NULL,\n    student_id INTEGER NOT NULL,\n    performance_assessment_id INTEGER NOT NULL,\n    CONSTRAINT pk_grades PRIMARY KEY (id),\n    CONSTRAINT fk_grades_student_id FOREIGN KEY (student_id) REFERENCES students (id),\n    CONSTRAINT fk_grades_performance_assessment_id FOREIGN KEY (performance_assessment_id) REFERENCES performance_assessments (id)\n);\n\nCREATE TABLE instructions (\n    id INTEGER NOT NULL,\n    teacher_id INTEGER NOT NULL,\n    subject_id INTEGER NOT NULL,\n    learning_group_id INTEGER NOT NULL,\n    CONSTRAINT pk_instructions PRIMARY KEY (id),\n    CONSTRAINT fk_instructions_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id),\n    CONSTRAINT fk_instructions_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id),\n    CONSTRAINT fk_instructions_learning_group_id FOREIGN KEY (learning_group_id) REFERENCES learning_groups (id)\n);\n\nCREATE TABLE supervisions (\n    id INTEGER NOT NULL,\n    teacher_id INTEGER NOT NULL,\n    learning_group_id INTEGER NOT NULL,\n    supervision_type VARCHAR(255),\n    CONSTRAINT pk_supervisions PRIMARY KEY (id),\n    CONSTRAINT fk_supervisions_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id),\n    CONSTRAINT fk_supervisions_learning_group_id FOREIGN KEY (learning_group_id) REFERENCES learning_groups (id)\n);\n\nCREATE TABLE teacher_subjects (\n    teacher_id INTEGER NOT NULL,\n    subject_id INTEGER NOT NULL,\n    CONSTRAINT pk_teacher_subjects PRIMARY KEY (teacher_id, subject_id),\n    CONSTRAINT fk_teacher_subjects_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id),\n    CONSTRAINT fk_teacher_subjects_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id)\n);\n",
