    "final_ddl": "CREATE TABLE youths (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    contact VARCHAR(255),\n    registration_date DATE NOT NULL,\n    CONSTRAINT pk_youths PRIMARY KEY (id)\n);\n\nCREATE TABLE staff (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_staff PRIMARY KEY (id)\n);\n\nCREATE TABLE events (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    date DATE NOT NULL,\n    responsible_staff_id INTEGER NOT NULL,\n    CONSTRAINT pk_events PRIMARY KEY (id),\n    CONSTRAINT fk_events_responsible_staff_id FOREIGN KEY (responsible_staff_id) REFERENCES staff (id)\n);\n\nCREATE TABLE event_participations (\n    id INTEGER NOT NULL,\n    youth_id INTEGER NOT NULL,\n    event_id INTEGER NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_event_participations PRIMARY KEY (id),\n    CONSTRAINT fk_event_participations_youth_id FOREIGN KEY (youth_id) REFERENCES youths (id),\n    CONSTRAINT fk_event_participations_event_id FOREIGN KEY (event_id) REFERENCES events (id)\n);\n\nCREATE TABLE offers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    weekday VARCHAR(255) NOT NULL,\n    age_group VARCHAR(255) NOT NULL,\n    capacity INTEGER,\n    registration_required BOOLEAN NOT NULL,\n    CONSTRAINT pk_offers PRIMARY KEY (id)\n);\n\nCREATE TABLE offer_staff (\n    offer_id INTEGER NOT NULL,\n    staff_id INTEGER NOT NULL,\n    CONSTRAINT pk_offer_staff PRIMARY KEY (offer_id, staff_id),\n    CONSTRAINT fk_offer_staff_offer_id FOREIGN KEY (offer_id) REFERENCES offers (id),\n    CONSTRAINT fk_offer_staff_staff_id FOREIGN KEY (staff_id) REFERENCES staff (id)\n);\n\nCREATE TABLE participations (\n    id INTEGER NOT NULL,\n    youth_id INTEGER NOT NULL,\n    offer_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_participations PRIMARY KEY (id),\n    CONSTRAINT fk_participations_youth_id FOREIGN KEY (youth_id) REFERENCES youths (id),\n    CONSTRAINT fk_participations_offer_id FOREIGN KEY (offer_id) REFERENCES offers (id)\n);\n",
