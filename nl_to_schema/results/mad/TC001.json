    "final_ddl": "CREATE TABLE authors (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    CONSTRAINT pk_authors PRIMARY KEY (id)\n);\n\nCREATE TABLE shelves (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    location_area VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_shelves PRIMARY KEY (id)\n);\n\nCREATE TABLE books (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    publicationyear INTEGER,\n    description TEXT,\n    author_id INTEGER NOT NULL,\n    shelf_id INTEGER NOT NULL,\n    CONSTRAINT pk_books PRIMARY KEY (id),\n    CONSTRAINT fk_books_author_id FOREIGN KEY (author_id) REFERENCES authors (id),\n    CONSTRAINT fk_books_shelf_id FOREIGN KEY (shelf_id) REFERENCES shelves (id)\n);\n",
