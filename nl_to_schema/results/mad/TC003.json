    "final_ddl": "CREATE TABLE courses (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    duration_minutes INTEGER NOT NULL,\n    CONSTRAINT pk_courses PRIMARY KEY (id)\n);\n\nCREATE TABLE trainers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    CONSTRAINT pk_trainers PRIMARY KEY (id)\n);\n\nCREATE TABLE course_sessions (\n    id INTEGER NOT NULL,\n    course_id INTEGER NOT NULL,\n    trainer_id INTEGER NOT NULL,\n    session_date DATE NOT NULL,\n    start_time VARCHAR(255) NOT NULL,\n    available_seats INTEGER NOT NULL,\n    CONSTRAINT pk_course_sessions PRIMARY KEY (id),\n    CONSTRAINT fk_course_sessions_course_id FOREIGN KEY (course_id) REFERENCES courses (id),\n    CONSTRAINT fk_course_sessions_trainer_id FOREIGN KEY (trainer_id) REFERENCES trainers (id)\n);\n\nCREATE TABLE members (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    joindate DATE NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_members PRIMARY KEY (id)\n);\n\nCREATE TABLE member_course_sessions (\n    member_id INTEGER NOT NULL,\n    course_session_id INTEGER NOT NULL,\n    CONSTRAINT pk_member_course_sessions PRIMARY KEY (member_id, course_session_id),\n    CONSTRAINT fk_member_course_sessions_member_id FOREIGN KEY (member_id) REFERENCES members (id),\n    CONSTRAINT fk_member_course_sessions_course_session_id FOREIGN KEY (course_session_id) REFERENCES course_sessions (id)\n);\n",
