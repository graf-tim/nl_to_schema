    "final_ddl": "CREATE TABLE departments (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_departments PRIMARY KEY (id)\n);\n\nCREATE TABLE functions (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_functions PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    birthdate DATE,\n    hiredate DATE NOT NULL,\n    department_id INTEGER NOT NULL,\n    function_id INTEGER NOT NULL,\n    CONSTRAINT pk_persons PRIMARY KEY (id),\n    CONSTRAINT fk_persons_department_id FOREIGN KEY (department_id) REFERENCES departments (id),\n    CONSTRAINT fk_persons_function_id FOREIGN KEY (function_id) REFERENCES functions (id)\n);\n\nCREATE TABLE department_managers (\n    id INTEGER NOT NULL,\n    department_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    effective_from DATE NOT NULL,\n    effective_to DATE,\n    CONSTRAINT pk_department_managers PRIMARY KEY (id),\n    CONSTRAINT fk_department_managers_department_id FOREIGN KEY (department_id) REFERENCES departments (id),\n    CONSTRAINT fk_department_managers_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE trainings (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    provider VARCHAR(255),\n    CONSTRAINT pk_trainings PRIMARY KEY (id)\n);\n\nCREATE TABLE training_relevance_levels (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_training_relevance_levels PRIMARY KEY (id)\n);\n\nCREATE TABLE function_trainings (\n    id INTEGER NOT NULL,\n    function_id INTEGER NOT NULL,\n    training_id INTEGER NOT NULL,\n    training_relevance_level_id INTEGER,\n    CONSTRAINT pk_function_trainings PRIMARY KEY (id),\n    CONSTRAINT fk_function_trainings_function_id FOREIGN KEY (function_id) REFERENCES functions (id),\n    CONSTRAINT fk_function_trainings_training_id FOREIGN KEY (training_id) REFERENCES trainings (id),\n    CONSTRAINT fk_function_trainings_training_relevance_level_id FOREIGN KEY (training_relevance_level_id) REFERENCES training_relevance_levels (id)\n);\n\nCREATE TABLE projects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    startdate DATE NOT NULL,\n    enddate DATE,\n    budget DECIMAL(18,2),\n    CONSTRAINT pk_projects PRIMARY KEY (id)\n);\n\nCREATE TABLE project_roles (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_project_roles PRIMARY KEY (id)\n);\n\nCREATE TABLE person_projects (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    project_role_id INTEGER NOT NULL,\n    startdate DATE NOT NULL,\n    enddate DATE,\n    CONSTRAINT pk_person_projects PRIMARY KEY (id),\n    CONSTRAINT fk_person_projects_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_projects_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_person_projects_project_role_id FOREIGN KEY (project_role_id) REFERENCES project_roles (id)\n);\n\nCREATE TABLE person_trainings (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    training_id INTEGER NOT NULL,\n    participationdate DATE NOT NULL,\n    completion_date DATE,\n    certificate BOOLEAN,\n    CONSTRAINT pk_person_trainings PRIMARY KEY (id),\n    CONSTRAINT fk_person_trainings_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_trainings_training_id FOREIGN KEY (training_id) REFERENCES trainings (id)\n);\n",
