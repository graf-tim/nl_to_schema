    "final_ddl": "CREATE TABLE agents (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    hire_date DATE NOT NULL,\n    CONSTRAINT pk_agents PRIMARY KEY (id)\n);\n\nCREATE TABLE owners (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    contact_preference VARCHAR(255),\n    CONSTRAINT pk_owners PRIMARY KEY (id)\n);\n\nCREATE TABLE properties (\n    id INTEGER NOT NULL,\n    owner_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    property_type VARCHAR(255) NOT NULL,\n    living_area DECIMAL(18,2),\n    price DECIMAL(18,2) NOT NULL,\n    price_type VARCHAR(255) NOT NULL,\n    is_available BOOLEAN NOT NULL,\n    listing_start_date DATE NOT NULL,\n    CONSTRAINT pk_properties PRIMARY KEY (id),\n    CONSTRAINT fk_properties_owner_id FOREIGN KEY (owner_id) REFERENCES owners (id)\n);\n\nCREATE TABLE property_agents (\n    id INTEGER NOT NULL,\n    property_id INTEGER NOT NULL,\n    agent_id INTEGER NOT NULL,\n    assignment_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_property_agents PRIMARY KEY (id),\n    CONSTRAINT fk_property_agents_property_id FOREIGN KEY (property_id) REFERENCES properties (id),\n    CONSTRAINT fk_property_agents_agent_id FOREIGN KEY (agent_id) REFERENCES agents (id)\n);\n\nCREATE TABLE prospects (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    search_criteria TEXT,\n    CONSTRAINT pk_prospects PRIMARY KEY (id)\n);\n\nCREATE TABLE prospect_interests (\n    id INTEGER NOT NULL,\n    prospect_id INTEGER NOT NULL,\n    property_id INTEGER NOT NULL,\n    last_contact_date DATE,\n    CONSTRAINT pk_prospect_interests PRIMARY KEY (id),\n    CONSTRAINT fk_prospect_interests_prospect_id FOREIGN KEY (prospect_id) REFERENCES prospects (id),\n    CONSTRAINT fk_prospect_interests_property_id FOREIGN KEY (property_id) REFERENCES properties (id)\n);\n\nCREATE TABLE viewings (\n    id INTEGER NOT NULL,\n    prospect_id INTEGER NOT NULL,\n    property_id INTEGER NOT NULL,\n    viewing_date DATE NOT NULL,\n    result VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_viewings PRIMARY KEY (id),\n    CONSTRAINT fk_viewings_prospect_id FOREIGN KEY (prospect_id) REFERENCES prospects (id),\n    CONSTRAINT fk_viewings_property_id FOREIGN KEY (property_id) REFERENCES properties (id)\n);\n\nCREATE TABLE viewing_agents (\n    id INTEGER NOT NULL,\n    viewing_id INTEGER NOT NULL,\n    agent_id INTEGER NOT NULL,\n    CONSTRAINT pk_viewing_agents PRIMARY KEY (id),\n    CONSTRAINT fk_viewing_agents_viewing_id FOREIGN KEY (viewing_id) REFERENCES viewings (id),\n    CONSTRAINT fk_viewing_agents_agent_id FOREIGN KEY (agent_id) REFERENCES agents (id)\n);\n",
