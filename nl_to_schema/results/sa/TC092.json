    "final_ddl": "CREATE TABLE persons (\n    id INTEGER NOT NULL,\n    internal_id VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    biological_sex VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE institutions (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255),\n    category VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_institutions PRIMARY KEY (id)\n);\n\nCREATE TABLE studies (\n    id INTEGER NOT NULL,\n    code VARCHAR(255) NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    start_date DATE,\n    end_date DATE,\n    responsible_institution_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_studies PRIMARY KEY (id),\n    CONSTRAINT fk_studies_responsible_institution_id FOREIGN KEY (responsible_institution_id) REFERENCES institutions (id)\n);\n\nCREATE TABLE consents (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    study_id INTEGER,\n    consent_type VARCHAR(255),\n    consent_date DATE NOT NULL,\n    is_withdrawn BOOLEAN NOT NULL,\n    withdrawal_date DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_consents PRIMARY KEY (id),\n    CONSTRAINT fk_consents_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_consents_study_id FOREIGN KEY (study_id) REFERENCES studies (id)\n);\n\nCREATE TABLE diagnoses (\n    id INTEGER NOT NULL,\n    icd_code VARCHAR(255),\n    description TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_diagnoses PRIMARY KEY (id)\n);\n\nCREATE TABLE person_studies (\n    person_id INTEGER NOT NULL,\n    study_id INTEGER NOT NULL,\n    enrollment_date DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_person_studies PRIMARY KEY (person_id, study_id),\n    CONSTRAINT fk_person_studies_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_studies_study_id FOREIGN KEY (study_id) REFERENCES studies (id)\n);\n\nCREATE TABLE storage_locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location_type VARCHAR(255),\n    parent_location_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_storage_locations PRIMARY KEY (id),\n    CONSTRAINT fk_storage_locations_parent_location_id FOREIGN KEY (parent_location_id) REFERENCES storage_locations (id)\n);\n\nCREATE TABLE samples (\n    id INTEGER NOT NULL,\n    internal_id VARCHAR(255) NOT NULL,\n    person_id INTEGER NOT NULL,\n    study_id INTEGER NOT NULL,\n    sample_type VARCHAR(255) NOT NULL,\n    collection_date DATE,\n    parent_sample_id INTEGER,\n    is_aliquot BOOLEAN NOT NULL,\n    processing_type VARCHAR(255),\n    current_storage_location_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_samples PRIMARY KEY (id),\n    CONSTRAINT fk_samples_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_samples_study_id FOREIGN KEY (study_id) REFERENCES studies (id),\n    CONSTRAINT fk_samples_parent_sample_id FOREIGN KEY (parent_sample_id) REFERENCES samples (id),\n    CONSTRAINT fk_samples_current_storage_location_id FOREIGN KEY (current_storage_location_id) REFERENCES storage_locations (id)\n);\n\nCREATE TABLE sample_diagnoses (\n    sample_id INTEGER NOT NULL,\n    diagnosis_id INTEGER NOT NULL,\n    relevance_note TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_sample_diagnoses PRIMARY KEY (sample_id, diagnosis_id),\n    CONSTRAINT fk_sample_diagnoses_sample_id FOREIGN KEY (sample_id) REFERENCES samples (id),\n    CONSTRAINT fk_sample_diagnoses_diagnosis_id FOREIGN KEY (diagnosis_id) REFERENCES diagnoses (id)\n);\n\nCREATE TABLE sample_quality_metrics (\n    id INTEGER NOT NULL,\n    sample_id INTEGER NOT NULL,\n    metric_name VARCHAR(255) NOT NULL,\n    metric_value DECIMAL(18,2),\n    unit VARCHAR(255),\n    measurement_date DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_sample_quality_metrics PRIMARY KEY (id),\n    CONSTRAINT fk_sample_quality_metrics_sample_id FOREIGN KEY (sample_id) REFERENCES samples (id)\n);\n\nCREATE TABLE sample_sources (\n    sample_id INTEGER NOT NULL,\n    institution_id INTEGER NOT NULL,\n    source_role VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_sample_sources PRIMARY KEY (sample_id, institution_id),\n    CONSTRAINT fk_sample_sources_sample_id FOREIGN KEY (sample_id) REFERENCES samples (id),\n    CONSTRAINT fk_sample_sources_institution_id FOREIGN KEY (institution_id) REFERENCES institutions (id)\n);\n\nCREATE TABLE sample_transfers (\n    id INTEGER NOT NULL,\n    sample_id INTEGER NOT NULL,\n    from_location_id INTEGER,\n    to_location_id INTEGER NOT NULL,\n    transfer_date DATE NOT NULL,\n    reason TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_sample_transfers PRIMARY KEY (id),\n    CONSTRAINT fk_sample_transfers_sample_id FOREIGN KEY (sample_id) REFERENCES samples (id),\n    CONSTRAINT fk_sample_transfers_from_location_id FOREIGN KEY (from_location_id) REFERENCES storage_locations (id),\n    CONSTRAINT fk_sample_transfers_to_location_id FOREIGN KEY (to_location_id) REFERENCES storage_locations (id)\n);\n\nCREATE TABLE study_institutions (\n    study_id INTEGER NOT NULL,\n    institution_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_study_institutions PRIMARY KEY (study_id, institution_id),\n    CONSTRAINT fk_study_institutions_study_id FOREIGN KEY (study_id) REFERENCES studies (id),\n    CONSTRAINT fk_study_institutions_institution_id FOREIGN KEY (institution_id) REFERENCES institutions (id)\n);\n",
