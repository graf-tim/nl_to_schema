    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE trades (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_trades PRIMARY KEY (id)\n);\n\nCREATE TABLE requests (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    trade_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    is_open BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_requests PRIMARY KEY (id),\n    CONSTRAINT fk_requests_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_requests_trade_id FOREIGN KEY (trade_id) REFERENCES trades (id)\n);\n\nCREATE TABLE businesses (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_businesses PRIMARY KEY (id)\n);\n\nCREATE TABLE awards (\n    id INTEGER NOT NULL,\n    request_id INTEGER NOT NULL,\n    business_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_awards PRIMARY KEY (id),\n    CONSTRAINT fk_awards_request_id FOREIGN KEY (request_id) REFERENCES requests (id),\n    CONSTRAINT fk_awards_business_id FOREIGN KEY (business_id) REFERENCES businesses (id)\n);\n\nCREATE TABLE bids (\n    id INTEGER NOT NULL,\n    request_id INTEGER NOT NULL,\n    business_id INTEGER NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    message TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_bids PRIMARY KEY (id),\n    CONSTRAINT fk_bids_request_id FOREIGN KEY (request_id) REFERENCES requests (id),\n    CONSTRAINT fk_bids_business_id FOREIGN KEY (business_id) REFERENCES businesses (id)\n);\n\nCREATE TABLE business_trades (\n    business_id INTEGER NOT NULL,\n    trade_id INTEGER NOT NULL,\n    CONSTRAINT pk_business_trades PRIMARY KEY (business_id, trade_id),\n    CONSTRAINT fk_business_trades_business_id FOREIGN KEY (business_id) REFERENCES businesses (id),\n    CONSTRAINT fk_business_trades_trade_id FOREIGN KEY (trade_id) REFERENCES trades (id)\n);\n",
