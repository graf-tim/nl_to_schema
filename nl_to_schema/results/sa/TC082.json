    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    customer_name VARCHAR(255) NOT NULL,\n    customer_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE sites (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    site_type VARCHAR(255) NOT NULL,\n    commissioning_date DATE NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_sites PRIMARY KEY (id)\n);\n\nCREATE TABLE connections (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    site_id INTEGER NOT NULL,\n    tariff VARCHAR(255) NOT NULL,\n    activation_date DATE NOT NULL,\n    technical_status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_connections PRIMARY KEY (id),\n    CONSTRAINT fk_connections_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_connections_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE devices (\n    id INTEGER NOT NULL,\n    device_type VARCHAR(255) NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    serial_number VARCHAR(255),\n    installation_date DATE NOT NULL,\n    decommissioning_date DATE,\n    CONSTRAINT pk_devices PRIMARY KEY (id)\n);\n\nCREATE TABLE device_site_assignments (\n    id INTEGER NOT NULL,\n    device_id INTEGER NOT NULL,\n    site_id INTEGER NOT NULL,\n    assignment_start_date DATE NOT NULL,\n    assignment_end_date DATE,\n    CONSTRAINT pk_device_site_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_device_site_assignments_device_id FOREIGN KEY (device_id) REFERENCES devices (id),\n    CONSTRAINT fk_device_site_assignments_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE frequency_bands (\n    id INTEGER NOT NULL,\n    band_designation VARCHAR(255) NOT NULL,\n    frequency_range VARCHAR(255),\n    CONSTRAINT pk_frequency_bands PRIMARY KEY (id)\n);\n\nCREATE TABLE incidents (\n    id INTEGER NOT NULL,\n    report_date DATE NOT NULL,\n    priority VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    processing_status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_incidents PRIMARY KEY (id)\n);\n\nCREATE TABLE incident_connection_assignments (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    connection_id INTEGER NOT NULL,\n    CONSTRAINT pk_incident_connection_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_incident_connection_assignments_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_connection_assignments_connection_id FOREIGN KEY (connection_id) REFERENCES connections (id)\n);\n\nCREATE TABLE radio_cells (\n    id INTEGER NOT NULL,\n    cell_identifier VARCHAR(255) NOT NULL,\n    site_id INTEGER NOT NULL,\n    technology VARCHAR(255) NOT NULL,\n    sector_designation VARCHAR(255),\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_radio_cells PRIMARY KEY (id),\n    CONSTRAINT fk_radio_cells_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE incident_radio_cell_assignments (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    radio_cell_id INTEGER NOT NULL,\n    CONSTRAINT pk_incident_radio_cell_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_incident_radio_cell_assignments_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_radio_cell_assignments_radio_cell_id FOREIGN KEY (radio_cell_id) REFERENCES radio_cells (id)\n);\n\nCREATE TABLE incident_site_assignments (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    site_id INTEGER NOT NULL,\n    CONSTRAINT pk_incident_site_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_incident_site_assignments_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_site_assignments_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE technicians (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    CONSTRAINT pk_technicians PRIMARY KEY (id)\n);\n\nCREATE TABLE incident_technician_assignments (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    technician_id INTEGER NOT NULL,\n    assignment_date DATE NOT NULL,\n    CONSTRAINT pk_incident_technician_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_incident_technician_assignments_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_technician_assignments_technician_id FOREIGN KEY (technician_id) REFERENCES technicians (id)\n);\n\nCREATE TABLE radio_cell_device_assignments (\n    id INTEGER NOT NULL,\n    radio_cell_id INTEGER NOT NULL,\n    device_id INTEGER NOT NULL,\n    CONSTRAINT pk_radio_cell_device_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_radio_cell_device_assignments_radio_cell_id FOREIGN KEY (radio_cell_id) REFERENCES radio_cells (id),\n    CONSTRAINT fk_radio_cell_device_assignments_device_id FOREIGN KEY (device_id) REFERENCES devices (id)\n);\n\nCREATE TABLE radio_cell_frequency_bands (\n    id INTEGER NOT NULL,\n    radio_cell_id INTEGER NOT NULL,\n    frequency_band_id INTEGER NOT NULL,\n    CONSTRAINT pk_radio_cell_frequency_bands PRIMARY KEY (id),\n    CONSTRAINT fk_radio_cell_frequency_bands_radio_cell_id FOREIGN KEY (radio_cell_id) REFERENCES radio_cells (id),\n    CONSTRAINT fk_radio_cell_frequency_bands_frequency_band_id FOREIGN KEY (frequency_band_id) REFERENCES frequency_bands (id)\n);\n",
