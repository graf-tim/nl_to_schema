    "final_ddl": "CREATE TABLE account_products (\n    id INTEGER NOT NULL,\n    product_name VARCHAR(255) NOT NULL,\n    product_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_account_products PRIMARY KEY (id)\n);\n\nCREATE TABLE branches (\n    id INTEGER NOT NULL,\n    branch_code VARCHAR(255) NOT NULL,\n    branch_name VARCHAR(255) NOT NULL,\n    city VARCHAR(255),\n    CONSTRAINT pk_branches PRIMARY KEY (id)\n);\n\nCREATE TABLE accounts (\n    id INTEGER NOT NULL,\n    iban VARCHAR(255) NOT NULL,\n    account_product_id INTEGER NOT NULL,\n    currency VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    branch_id INTEGER NOT NULL,\n    opened_at DATE NOT NULL,\n    closed_at DATE,\n    CONSTRAINT pk_accounts PRIMARY KEY (id),\n    CONSTRAINT fk_accounts_account_product_id FOREIGN KEY (account_product_id) REFERENCES account_products (id),\n    CONSTRAINT fk_accounts_branch_id FOREIGN KEY (branch_id) REFERENCES branches (id)\n);\n\nCREATE TABLE customers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    customer_type VARCHAR(255) NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE account_authorizations (\n    id INTEGER NOT NULL,\n    account_id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    authorization_type VARCHAR(255) NOT NULL,\n    valid_from DATE,\n    valid_to DATE,\n    CONSTRAINT pk_account_authorizations PRIMARY KEY (id),\n    CONSTRAINT fk_account_authorizations_account_id FOREIGN KEY (account_id) REFERENCES accounts (id),\n    CONSTRAINT fk_account_authorizations_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE account_holders (\n    id INTEGER NOT NULL,\n    account_id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    holder_type VARCHAR(255) NOT NULL,\n    is_signatory BOOLEAN NOT NULL,\n    CONSTRAINT pk_account_holders PRIMARY KEY (id),\n    CONSTRAINT fk_account_holders_account_id FOREIGN KEY (account_id) REFERENCES accounts (id),\n    CONSTRAINT fk_account_holders_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE addresses (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    address_type VARCHAR(255) NOT NULL,\n    street VARCHAR(255) NOT NULL,\n    house_number VARCHAR(255) NOT NULL,\n    postal_code VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    country VARCHAR(255) NOT NULL,\n    is_current BOOLEAN NOT NULL,\n    valid_from DATE,\n    valid_to DATE,\n    CONSTRAINT pk_addresses PRIMARY KEY (id),\n    CONSTRAINT fk_addresses_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE card_types (\n    id INTEGER NOT NULL,\n    card_type_name VARCHAR(255) NOT NULL,\n    card_category VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_card_types PRIMARY KEY (id)\n);\n\nCREATE TABLE cards (\n    id INTEGER NOT NULL,\n    card_type_id INTEGER NOT NULL,\n    account_id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    card_number VARCHAR(255) NOT NULL,\n    expiry_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    issued_at DATE NOT NULL,\n    blocked_at DATE,\n    CONSTRAINT pk_cards PRIMARY KEY (id),\n    CONSTRAINT fk_cards_card_type_id FOREIGN KEY (card_type_id) REFERENCES card_types (id),\n    CONSTRAINT fk_cards_account_id FOREIGN KEY (account_id) REFERENCES accounts (id),\n    CONSTRAINT fk_cards_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE collateral_types (\n    id INTEGER NOT NULL,\n    collateral_type_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_collateral_types PRIMARY KEY (id)\n);\n\nCREATE TABLE collaterals (\n    id INTEGER NOT NULL,\n    collateral_type_id INTEGER NOT NULL,\n    description TEXT NOT NULL,\n    estimated_value DECIMAL(18,2),\n    currency VARCHAR(255),\n    CONSTRAINT pk_collaterals PRIMARY KEY (id),\n    CONSTRAINT fk_collaterals_collateral_type_id FOREIGN KEY (collateral_type_id) REFERENCES collateral_types (id)\n);\n\nCREATE TABLE collateral_providers (\n    id INTEGER NOT NULL,\n    collateral_id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    provider_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_collateral_providers PRIMARY KEY (id),\n    CONSTRAINT fk_collateral_providers_collateral_id FOREIGN KEY (collateral_id) REFERENCES collaterals (id),\n    CONSTRAINT fk_collateral_providers_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE contact_methods (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    contact_type VARCHAR(255) NOT NULL,\n    contact_value VARCHAR(255) NOT NULL,\n    is_primary BOOLEAN NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_contact_methods PRIMARY KEY (id),\n    CONSTRAINT fk_contact_methods_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE credit_types (\n    id INTEGER NOT NULL,\n    credit_type_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_credit_types PRIMARY KEY (id)\n);\n\nCREATE TABLE credits (\n    id INTEGER NOT NULL,\n    credit_type_id INTEGER NOT NULL,\n    nominal_amount DECIMAL(18,2) NOT NULL,\n    interest_rate DECIMAL(18,2) NOT NULL,\n    start_date DATE NOT NULL,\n    maturity_date DATE NOT NULL,\n    branch_id INTEGER NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    currency VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_credits PRIMARY KEY (id),\n    CONSTRAINT fk_credits_credit_type_id FOREIGN KEY (credit_type_id) REFERENCES credit_types (id),\n    CONSTRAINT fk_credits_branch_id FOREIGN KEY (branch_id) REFERENCES branches (id)\n);\n\nCREATE TABLE credit_borrowers (\n    id INTEGER NOT NULL,\n    credit_id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    borrower_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_credit_borrowers PRIMARY KEY (id),\n    CONSTRAINT fk_credit_borrowers_credit_id FOREIGN KEY (credit_id) REFERENCES credits (id),\n    CONSTRAINT fk_credit_borrowers_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE credit_collaterals (\n    id INTEGER NOT NULL,\n    credit_id INTEGER NOT NULL,\n    collateral_id INTEGER NOT NULL,\n    CONSTRAINT pk_credit_collaterals PRIMARY KEY (id),\n    CONSTRAINT fk_credit_collaterals_credit_id FOREIGN KEY (credit_id) REFERENCES credits (id),\n    CONSTRAINT fk_credit_collaterals_collateral_id FOREIGN KEY (collateral_id) REFERENCES collaterals (id)\n);\n\nCREATE TABLE transactions (\n    id INTEGER NOT NULL,\n    account_id INTEGER NOT NULL,\n    booking_date DATE NOT NULL,\n    value_date DATE NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    counterparty_text VARCHAR(255),\n    purpose TEXT,\n    transaction_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_transactions PRIMARY KEY (id),\n    CONSTRAINT fk_transactions_account_id FOREIGN KEY (account_id) REFERENCES accounts (id)\n);\n",
