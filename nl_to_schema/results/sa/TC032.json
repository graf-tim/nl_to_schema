    "final_ddl": "CREATE TABLE districts (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    responsible_district VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_districts PRIMARY KEY (id)\n);\n\nCREATE TABLE playgrounds (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    street VARCHAR(255) NOT NULL,\n    house_number VARCHAR(255) NOT NULL,\n    postal_code VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    opening_date DATE NOT NULL,\n    is_open BOOLEAN NOT NULL,\n    district_id INTEGER NOT NULL,\n    CONSTRAINT pk_playgrounds PRIMARY KEY (id),\n    CONSTRAINT fk_playgrounds_district_id FOREIGN KEY (district_id) REFERENCES districts (id)\n);\n\nCREATE TABLE playground_equipment (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    equipment_type VARCHAR(255) NOT NULL,\n    installation_date DATE NOT NULL,\n    condition VARCHAR(255) NOT NULL,\n    playground_id INTEGER NOT NULL,\n    CONSTRAINT pk_playground_equipment PRIMARY KEY (id),\n    CONSTRAINT fk_playground_equipment_playground_id FOREIGN KEY (playground_id) REFERENCES playgrounds (id)\n);\n",
