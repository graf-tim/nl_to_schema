    "final_ddl": "CREATE TABLE articles (\n    id INTEGER NOT NULL,\n    internal_number VARCHAR(255) NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    standard_sales_price DECIMAL(18,2) NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    is_batch_tracked BOOLEAN NOT NULL,\n    CONSTRAINT pk_articles PRIMARY KEY (id)\n);\n\nCREATE TABLE manufacturers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_manufacturers PRIMARY KEY (id)\n);\n\nCREATE TABLE article_manufacturers (\n    article_id INTEGER NOT NULL,\n    manufacturer_id INTEGER NOT NULL,\n    CONSTRAINT pk_article_manufacturers PRIMARY KEY (article_id, manufacturer_id),\n    CONSTRAINT fk_article_manufacturers_article_id FOREIGN KEY (article_id) REFERENCES articles (id),\n    CONSTRAINT fk_article_manufacturers_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id)\n);\n\nCREATE TABLE article_variants (\n    id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    variant_name VARCHAR(255) NOT NULL,\n    packaging_size VARCHAR(255),\n    packaging_unit VARCHAR(255),\n    CONSTRAINT pk_article_variants PRIMARY KEY (id),\n    CONSTRAINT fk_article_variants_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE contacts (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_contacts PRIMARY KEY (id)\n);\n\nCREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE customer_addresses (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    address_type VARCHAR(255) NOT NULL,\n    address TEXT NOT NULL,\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_customer_addresses PRIMARY KEY (id),\n    CONSTRAINT fk_customer_addresses_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE suppliers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address TEXT,\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_suppliers PRIMARY KEY (id)\n);\n\nCREATE TABLE purchase_orders (\n    id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    order_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_purchase_orders PRIMARY KEY (id),\n    CONSTRAINT fk_purchase_orders_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id)\n);\n\nCREATE TABLE warehouses (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address TEXT,\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_warehouses PRIMARY KEY (id)\n);\n\nCREATE TABLE goods_receipts (\n    id INTEGER NOT NULL,\n    purchase_order_id INTEGER NOT NULL,\n    warehouse_id INTEGER NOT NULL,\n    receipt_date DATE NOT NULL,\n    CONSTRAINT pk_goods_receipts PRIMARY KEY (id),\n    CONSTRAINT fk_goods_receipts_purchase_order_id FOREIGN KEY (purchase_order_id) REFERENCES purchase_orders (id),\n    CONSTRAINT fk_goods_receipts_warehouse_id FOREIGN KEY (warehouse_id) REFERENCES warehouses (id)\n);\n\nCREATE TABLE goods_receipt_positions (\n    id INTEGER NOT NULL,\n    goods_receipt_id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    batch_number VARCHAR(255),\n    expiry_date DATE,\n    CONSTRAINT pk_goods_receipt_positions PRIMARY KEY (id),\n    CONSTRAINT fk_goods_receipt_positions_goods_receipt_id FOREIGN KEY (goods_receipt_id) REFERENCES goods_receipts (id),\n    CONSTRAINT fk_goods_receipt_positions_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE manufacturer_contacts (\n    manufacturer_id INTEGER NOT NULL,\n    contact_id INTEGER NOT NULL,\n    CONSTRAINT pk_manufacturer_contacts PRIMARY KEY (manufacturer_id, contact_id),\n    CONSTRAINT fk_manufacturer_contacts_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id),\n    CONSTRAINT fk_manufacturer_contacts_contact_id FOREIGN KEY (contact_id) REFERENCES contacts (id)\n);\n\nCREATE TABLE purchase_order_positions (\n    id INTEGER NOT NULL,\n    purchase_order_id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    unit_price DECIMAL(18,2) NOT NULL,\n    discount_percent DECIMAL(18,2),\n    CONSTRAINT pk_purchase_order_positions PRIMARY KEY (id),\n    CONSTRAINT fk_purchase_order_positions_purchase_order_id FOREIGN KEY (purchase_order_id) REFERENCES purchase_orders (id),\n    CONSTRAINT fk_purchase_order_positions_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE sales_orders (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    delivery_address_id INTEGER,\n    order_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_sales_orders PRIMARY KEY (id),\n    CONSTRAINT fk_sales_orders_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_sales_orders_delivery_address_id FOREIGN KEY (delivery_address_id) REFERENCES customer_addresses (id)\n);\n\nCREATE TABLE sales_order_positions (\n    id INTEGER NOT NULL,\n    sales_order_id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    unit_price DECIMAL(18,2) NOT NULL,\n    discount_percent DECIMAL(18,2),\n    CONSTRAINT pk_sales_order_positions PRIMARY KEY (id),\n    CONSTRAINT fk_sales_order_positions_sales_order_id FOREIGN KEY (sales_order_id) REFERENCES sales_orders (id),\n    CONSTRAINT fk_sales_order_positions_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE shipments (\n    id INTEGER NOT NULL,\n    sales_order_id INTEGER NOT NULL,\n    warehouse_id INTEGER NOT NULL,\n    shipment_date DATE NOT NULL,\n    CONSTRAINT pk_shipments PRIMARY KEY (id),\n    CONSTRAINT fk_shipments_sales_order_id FOREIGN KEY (sales_order_id) REFERENCES sales_orders (id),\n    CONSTRAINT fk_shipments_warehouse_id FOREIGN KEY (warehouse_id) REFERENCES warehouses (id)\n);\n\nCREATE TABLE shipment_positions (\n    id INTEGER NOT NULL,\n    shipment_id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_shipment_positions PRIMARY KEY (id),\n    CONSTRAINT fk_shipment_positions_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id),\n    CONSTRAINT fk_shipment_positions_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE warehouse_stocks (\n    id INTEGER NOT NULL,\n    warehouse_id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    minimum_stock DECIMAL(18,2),\n    CONSTRAINT pk_warehouse_stocks PRIMARY KEY (id),\n    CONSTRAINT fk_warehouse_stocks_warehouse_id FOREIGN KEY (warehouse_id) REFERENCES warehouses (id),\n    CONSTRAINT fk_warehouse_stocks_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n",
