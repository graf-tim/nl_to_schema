    "final_ddl": "CREATE TABLE models (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    version VARCHAR(255),\n    description TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_models PRIMARY KEY (id)\n);\n\nCREATE TABLE manufacturers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_manufacturers PRIMARY KEY (id)\n);\n\nCREATE TABLE product_series (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    manufacturer_id INTEGER,\n    description TEXT,\n    CONSTRAINT pk_product_series PRIMARY KEY (id),\n    CONSTRAINT fk_product_series_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    address VARCHAR(255),\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE digital_twins (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    model_id INTEGER NOT NULL,\n    manufacturer_id INTEGER,\n    product_series_id INTEGER,\n    location_id INTEGER,\n    commissioning_date DATE,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_digital_twins PRIMARY KEY (id),\n    CONSTRAINT fk_digital_twins_model_id FOREIGN KEY (model_id) REFERENCES models (id),\n    CONSTRAINT fk_digital_twins_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id),\n    CONSTRAINT fk_digital_twins_product_series_id FOREIGN KEY (product_series_id) REFERENCES product_series (id),\n    CONSTRAINT fk_digital_twins_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE documents (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    document_type VARCHAR(255),\n    description TEXT,\n    file_path VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_documents PRIMARY KEY (id)\n);\n\nCREATE TABLE digital_twin_documents (\n    digital_twin_id INTEGER NOT NULL,\n    document_id INTEGER NOT NULL,\n    CONSTRAINT pk_digital_twin_documents PRIMARY KEY (digital_twin_id, document_id),\n    CONSTRAINT fk_digital_twin_documents_digital_twin_id FOREIGN KEY (digital_twin_id) REFERENCES digital_twins (id),\n    CONSTRAINT fk_digital_twin_documents_document_id FOREIGN KEY (document_id) REFERENCES documents (id)\n);\n\nCREATE TABLE event_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_event_types PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE events (\n    id INTEGER NOT NULL,\n    digital_twin_id INTEGER NOT NULL,\n    event_type_id INTEGER NOT NULL,\n    reported_by_person_id INTEGER,\n    performed_by_person_id INTEGER,\n    description TEXT,\n    event_date DATE NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_events PRIMARY KEY (id),\n    CONSTRAINT fk_events_digital_twin_id FOREIGN KEY (digital_twin_id) REFERENCES digital_twins (id),\n    CONSTRAINT fk_events_event_type_id FOREIGN KEY (event_type_id) REFERENCES event_types (id),\n    CONSTRAINT fk_events_reported_by_person_id FOREIGN KEY (reported_by_person_id) REFERENCES persons (id),\n    CONSTRAINT fk_events_performed_by_person_id FOREIGN KEY (performed_by_person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE sensor_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    unit VARCHAR(255),\n    CONSTRAINT pk_sensor_types PRIMARY KEY (id)\n);\n\nCREATE TABLE sensors (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    sensor_type_id INTEGER NOT NULL,\n    digital_twin_id INTEGER NOT NULL,\n    installation_date DATE,\n    removal_date DATE,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_sensors PRIMARY KEY (id),\n    CONSTRAINT fk_sensors_sensor_type_id FOREIGN KEY (sensor_type_id) REFERENCES sensor_types (id),\n    CONSTRAINT fk_sensors_digital_twin_id FOREIGN KEY (digital_twin_id) REFERENCES digital_twins (id)\n);\n\nCREATE TABLE measurements (\n    id INTEGER NOT NULL,\n    sensor_id INTEGER NOT NULL,\n    value DECIMAL(18,2) NOT NULL,\n    measured_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_measurements PRIMARY KEY (id),\n    CONSTRAINT fk_measurements_sensor_id FOREIGN KEY (sensor_id) REFERENCES sensors (id)\n);\n\nCREATE TABLE qualifications (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_qualifications PRIMARY KEY (id)\n);\n\nCREATE TABLE person_qualifications (\n    person_id INTEGER NOT NULL,\n    qualification_id INTEGER NOT NULL,\n    acquired_date DATE,\n    CONSTRAINT pk_person_qualifications PRIMARY KEY (person_id, qualification_id),\n    CONSTRAINT fk_person_qualifications_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_qualifications_qualification_id FOREIGN KEY (qualification_id) REFERENCES qualifications (id)\n);\n\nCREATE TABLE twin_locations (\n    id INTEGER NOT NULL,\n    digital_twin_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_twin_locations PRIMARY KEY (id),\n    CONSTRAINT fk_twin_locations_digital_twin_id FOREIGN KEY (digital_twin_id) REFERENCES digital_twins (id),\n    CONSTRAINT fk_twin_locations_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE twin_relationships (\n    id INTEGER NOT NULL,\n    parent_twin_id INTEGER NOT NULL,\n    child_twin_id INTEGER NOT NULL,\n    relationship_type VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_twin_relationships PRIMARY KEY (id),\n    CONSTRAINT fk_twin_relationships_parent_twin_id FOREIGN KEY (parent_twin_id) REFERENCES digital_twins (id),\n    CONSTRAINT fk_twin_relationships_child_twin_id FOREIGN KEY (child_twin_id) REFERENCES digital_twins (id)\n);\n",
