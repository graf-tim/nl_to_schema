    "final_ddl": "CREATE TABLE sources (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_sources PRIMARY KEY (id)\n);\n\nCREATE TABLE regulations (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    source_id INTEGER NOT NULL,\n    publicationdate DATE,\n    status VARCHAR(255) NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    replaced_by_regulation_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_regulations PRIMARY KEY (id),\n    CONSTRAINT fk_regulations_source_id FOREIGN KEY (source_id) REFERENCES sources (id),\n    CONSTRAINT fk_regulations_replaced_by_regulation_id FOREIGN KEY (replaced_by_regulation_id) REFERENCES regulations (id)\n);\n\nCREATE TABLE requirements (\n    id INTEGER NOT NULL,\n    regulation_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_requirements PRIMARY KEY (id),\n    CONSTRAINT fk_requirements_regulation_id FOREIGN KEY (regulation_id) REFERENCES regulations (id)\n);\n\nCREATE TABLE controls (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    control_type VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_controls PRIMARY KEY (id)\n);\n\nCREATE TABLE findings (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    severity VARCHAR(255) NOT NULL,\n    requirement_id INTEGER,\n    control_id INTEGER,\n    audit_date DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_findings PRIMARY KEY (id),\n    CONSTRAINT fk_findings_requirement_id FOREIGN KEY (requirement_id) REFERENCES requirements (id),\n    CONSTRAINT fk_findings_control_id FOREIGN KEY (control_id) REFERENCES controls (id)\n);\n\nCREATE TABLE departments (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_departments PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    department_id INTEGER,\n    CONSTRAINT pk_persons PRIMARY KEY (id),\n    CONSTRAINT fk_persons_department_id FOREIGN KEY (department_id) REFERENCES departments (id)\n);\n\nCREATE TABLE actions (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    finding_id INTEGER,\n    requirement_id INTEGER,\n    status VARCHAR(255) NOT NULL,\n    due_date DATE,\n    assigned_to_person_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_actions PRIMARY KEY (id),\n    CONSTRAINT fk_actions_finding_id FOREIGN KEY (finding_id) REFERENCES findings (id),\n    CONSTRAINT fk_actions_requirement_id FOREIGN KEY (requirement_id) REFERENCES requirements (id),\n    CONSTRAINT fk_actions_assigned_to_person_id FOREIGN KEY (assigned_to_person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE evidences (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    document_type VARCHAR(255),\n    file_path VARCHAR(255),\n    uploaded_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_evidences PRIMARY KEY (id)\n);\n\nCREATE TABLE evidence_controls (\n    evidence_id INTEGER NOT NULL,\n    control_id INTEGER NOT NULL,\n    CONSTRAINT pk_evidence_controls PRIMARY KEY (evidence_id, control_id),\n    CONSTRAINT fk_evidence_controls_evidence_id FOREIGN KEY (evidence_id) REFERENCES evidences (id),\n    CONSTRAINT fk_evidence_controls_control_id FOREIGN KEY (control_id) REFERENCES controls (id)\n);\n\nCREATE TABLE evidence_requirements (\n    evidence_id INTEGER NOT NULL,\n    requirement_id INTEGER NOT NULL,\n    CONSTRAINT pk_evidence_requirements PRIMARY KEY (evidence_id, requirement_id),\n    CONSTRAINT fk_evidence_requirements_evidence_id FOREIGN KEY (evidence_id) REFERENCES evidences (id),\n    CONSTRAINT fk_evidence_requirements_requirement_id FOREIGN KEY (requirement_id) REFERENCES requirements (id)\n);\n\nCREATE TABLE topics (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_topics PRIMARY KEY (id)\n);\n\nCREATE TABLE regulation_topics (\n    regulation_id INTEGER NOT NULL,\n    topic_id INTEGER NOT NULL,\n    CONSTRAINT pk_regulation_topics PRIMARY KEY (regulation_id, topic_id),\n    CONSTRAINT fk_regulation_topics_regulation_id FOREIGN KEY (regulation_id) REFERENCES regulations (id),\n    CONSTRAINT fk_regulation_topics_topic_id FOREIGN KEY (topic_id) REFERENCES topics (id)\n);\n\nCREATE TABLE requirement_controls (\n    requirement_id INTEGER NOT NULL,\n    control_id INTEGER NOT NULL,\n    CONSTRAINT pk_requirement_controls PRIMARY KEY (requirement_id, control_id),\n    CONSTRAINT fk_requirement_controls_requirement_id FOREIGN KEY (requirement_id) REFERENCES requirements (id),\n    CONSTRAINT fk_requirement_controls_control_id FOREIGN KEY (control_id) REFERENCES controls (id)\n);\n\nCREATE TABLE requirement_departments (\n    requirement_id INTEGER NOT NULL,\n    department_id INTEGER NOT NULL,\n    CONSTRAINT pk_requirement_departments PRIMARY KEY (requirement_id, department_id),\n    CONSTRAINT fk_requirement_departments_requirement_id FOREIGN KEY (requirement_id) REFERENCES requirements (id),\n    CONSTRAINT fk_requirement_departments_department_id FOREIGN KEY (department_id) REFERENCES departments (id)\n);\n",
