    "final_ddl": "CREATE TABLE departments (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_departments PRIMARY KEY (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    department_id INTEGER NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id),\n    CONSTRAINT fk_employees_department_id FOREIGN KEY (department_id) REFERENCES departments (id)\n);\n\nCREATE TABLE priority_levels (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    level INTEGER NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_priority_levels PRIMARY KEY (id)\n);\n\nCREATE TABLE ticket_statuses (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_ticket_statuses PRIMARY KEY (id)\n);\n\nCREATE TABLE tickets (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    reporter_id INTEGER NOT NULL,\n    department_id INTEGER NOT NULL,\n    priority_level_id INTEGER NOT NULL,\n    status_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    completed_at TIMESTAMP,\n    CONSTRAINT pk_tickets PRIMARY KEY (id),\n    CONSTRAINT fk_tickets_reporter_id FOREIGN KEY (reporter_id) REFERENCES employees (id),\n    CONSTRAINT fk_tickets_department_id FOREIGN KEY (department_id) REFERENCES departments (id),\n    CONSTRAINT fk_tickets_priority_level_id FOREIGN KEY (priority_level_id) REFERENCES priority_levels (id),\n    CONSTRAINT fk_tickets_status_id FOREIGN KEY (status_id) REFERENCES ticket_statuses (id)\n);\n\nCREATE TABLE notes (\n    id INTEGER NOT NULL,\n    ticket_id INTEGER NOT NULL,\n    author_id INTEGER NOT NULL,\n    content TEXT NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_notes PRIMARY KEY (id),\n    CONSTRAINT fk_notes_ticket_id FOREIGN KEY (ticket_id) REFERENCES tickets (id),\n    CONSTRAINT fk_notes_author_id FOREIGN KEY (author_id) REFERENCES employees (id)\n);\n\nCREATE TABLE ticket_assignments (\n    id INTEGER NOT NULL,\n    ticket_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    assigned_at TIMESTAMP NOT NULL,\n    unassigned_at TIMESTAMP,\n    CONSTRAINT pk_ticket_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_ticket_assignments_ticket_id FOREIGN KEY (ticket_id) REFERENCES tickets (id),\n    CONSTRAINT fk_ticket_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n",
