    "final_ddl": "CREATE TABLE staff_members (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_staff_members PRIMARY KEY (id)\n);\n\nCREATE TABLE events (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    event_date DATE NOT NULL,\n    responsible_staff_id INTEGER NOT NULL,\n    CONSTRAINT pk_events PRIMARY KEY (id),\n    CONSTRAINT fk_events_responsible_staff_id FOREIGN KEY (responsible_staff_id) REFERENCES staff_members (id)\n);\n\nCREATE TABLE youths (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    contact VARCHAR(255),\n    registration_date DATE NOT NULL,\n    CONSTRAINT pk_youths PRIMARY KEY (id)\n);\n\nCREATE TABLE event_youth (\n    event_id INTEGER NOT NULL,\n    youth_id INTEGER NOT NULL,\n    participation_status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_event_youth PRIMARY KEY (event_id, youth_id),\n    CONSTRAINT fk_event_youth_event_id FOREIGN KEY (event_id) REFERENCES events (id),\n    CONSTRAINT fk_event_youth_youth_id FOREIGN KEY (youth_id) REFERENCES youths (id)\n);\n\nCREATE TABLE offerings (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    offering_type VARCHAR(255) NOT NULL,\n    weekday VARCHAR(255),\n    min_age INTEGER,\n    max_age INTEGER,\n    capacity INTEGER,\n    registration_required BOOLEAN NOT NULL,\n    CONSTRAINT pk_offerings PRIMARY KEY (id)\n);\n\nCREATE TABLE offering_staff (\n    offering_id INTEGER NOT NULL,\n    staff_member_id INTEGER NOT NULL,\n    CONSTRAINT pk_offering_staff PRIMARY KEY (offering_id, staff_member_id),\n    CONSTRAINT fk_offering_staff_offering_id FOREIGN KEY (offering_id) REFERENCES offerings (id),\n    CONSTRAINT fk_offering_staff_staff_member_id FOREIGN KEY (staff_member_id) REFERENCES staff_members (id)\n);\n\nCREATE TABLE youth_offerings (\n    youth_id INTEGER NOT NULL,\n    offering_id INTEGER NOT NULL,\n    enrollment_date DATE NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_youth_offerings PRIMARY KEY (youth_id, offering_id),\n    CONSTRAINT fk_youth_offerings_youth_id FOREIGN KEY (youth_id) REFERENCES youths (id),\n    CONSTRAINT fk_youth_offerings_offering_id FOREIGN KEY (offering_id) REFERENCES offerings (id)\n);\n",
