    "final_ddl": "CREATE TABLE balance_groups (\n    id INTEGER NOT NULL,\n    code VARCHAR(255) NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_balance_groups PRIMARY KEY (id)\n);\n\nCREATE TABLE market_partners (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    partner_type VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_market_partners PRIMARY KEY (id)\n);\n\nCREATE TABLE contacts (\n    id INTEGER NOT NULL,\n    market_partner_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    department VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_contacts_market_partner_id FOREIGN KEY (market_partner_id) REFERENCES market_partners (id)\n);\n\nCREATE TABLE contracts (\n    id INTEGER NOT NULL,\n    contract_number VARCHAR(255) NOT NULL,\n    contract_type VARCHAR(255) NOT NULL,\n    is_standardized BOOLEAN NOT NULL,\n    delivery_terms TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_contracts PRIMARY KEY (id)\n);\n\nCREATE TABLE traders (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_traders PRIMARY KEY (id)\n);\n\nCREATE TABLE products (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    product_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    unit VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_products PRIMARY KEY (id)\n);\n\nCREATE TABLE trading_venues (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_trading_venues PRIMARY KEY (id)\n);\n\nCREATE TABLE deals (\n    id INTEGER NOT NULL,\n    deal_number VARCHAR(255) NOT NULL,\n    contract_id INTEGER,\n    trader_id INTEGER NOT NULL,\n    counterparty_id INTEGER NOT NULL,\n    broker_id INTEGER,\n    product_id INTEGER NOT NULL,\n    trading_venue_id INTEGER,\n    deal_type VARCHAR(255) NOT NULL,\n    transaction_type VARCHAR(255) NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    quantity_type VARCHAR(255),\n    price DECIMAL(18,2) NOT NULL,\n    currency VARCHAR(255) NOT NULL,\n    contract_start_date DATE NOT NULL,\n    contract_end_date DATE NOT NULL,\n    delivery_start_date DATE NOT NULL,\n    delivery_end_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_deals PRIMARY KEY (id),\n    CONSTRAINT fk_deals_contract_id FOREIGN KEY (contract_id) REFERENCES contracts (id),\n    CONSTRAINT fk_deals_trader_id FOREIGN KEY (trader_id) REFERENCES traders (id),\n    CONSTRAINT fk_deals_counterparty_id FOREIGN KEY (counterparty_id) REFERENCES market_partners (id),\n    CONSTRAINT fk_deals_broker_id FOREIGN KEY (broker_id) REFERENCES market_partners (id),\n    CONSTRAINT fk_deals_product_id FOREIGN KEY (product_id) REFERENCES products (id),\n    CONSTRAINT fk_deals_trading_venue_id FOREIGN KEY (trading_venue_id) REFERENCES trading_venues (id)\n);\n\nCREATE TABLE deal_balance_groups (\n    id INTEGER NOT NULL,\n    deal_id INTEGER NOT NULL,\n    balance_group_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_deal_balance_groups PRIMARY KEY (id),\n    CONSTRAINT fk_deal_balance_groups_deal_id FOREIGN KEY (deal_id) REFERENCES deals (id),\n    CONSTRAINT fk_deal_balance_groups_balance_group_id FOREIGN KEY (balance_group_id) REFERENCES balance_groups (id)\n);\n\nCREATE TABLE deal_events (\n    id INTEGER NOT NULL,\n    deal_id INTEGER NOT NULL,\n    event_type VARCHAR(255) NOT NULL,\n    event_date TIMESTAMP NOT NULL,\n    description TEXT,\n    created_by VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_deal_events PRIMARY KEY (id),\n    CONSTRAINT fk_deal_events_deal_id FOREIGN KEY (deal_id) REFERENCES deals (id)\n);\n\nCREATE TABLE grid_zones (\n    id INTEGER NOT NULL,\n    code VARCHAR(255) NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_grid_zones PRIMARY KEY (id)\n);\n\nCREATE TABLE deal_grid_zones (\n    id INTEGER NOT NULL,\n    deal_id INTEGER NOT NULL,\n    grid_zone_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_deal_grid_zones PRIMARY KEY (id),\n    CONSTRAINT fk_deal_grid_zones_deal_id FOREIGN KEY (deal_id) REFERENCES deals (id),\n    CONSTRAINT fk_deal_grid_zones_grid_zone_id FOREIGN KEY (grid_zone_id) REFERENCES grid_zones (id)\n);\n\nCREATE TABLE product_trading_venues (\n    id INTEGER NOT NULL,\n    product_id INTEGER NOT NULL,\n    trading_venue_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_product_trading_venues PRIMARY KEY (id),\n    CONSTRAINT fk_product_trading_venues_product_id FOREIGN KEY (product_id) REFERENCES products (id),\n    CONSTRAINT fk_product_trading_venues_trading_venue_id FOREIGN KEY (trading_venue_id) REFERENCES trading_venues (id)\n);\n\nCREATE TABLE schedules (\n    id INTEGER NOT NULL,\n    deal_id INTEGER NOT NULL,\n    schedule_date DATE NOT NULL,\n    volume DECIMAL(18,2) NOT NULL,\n    position_number INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_schedules PRIMARY KEY (id),\n    CONSTRAINT fk_schedules_deal_id FOREIGN KEY (deal_id) REFERENCES deals (id)\n);\n",
