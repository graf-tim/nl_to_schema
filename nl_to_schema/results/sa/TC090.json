    "final_ddl": "CREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location_type VARCHAR(255) NOT NULL,\n    address VARCHAR(255),\n    street_section VARCHAR(255),\n    latitude DECIMAL(18,2),\n    longitude DECIMAL(18,2),\n    description TEXT,\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE citizen_reports (\n    id INTEGER NOT NULL,\n    report_type VARCHAR(255) NOT NULL,\n    location_id INTEGER,\n    area_description VARCHAR(255),\n    report_timestamp TIMESTAMP NOT NULL,\n    description TEXT NOT NULL,\n    is_anonymous BOOLEAN NOT NULL,\n    contact_email VARCHAR(255),\n    contact_phone VARCHAR(255),\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_citizen_reports PRIMARY KEY (id),\n    CONSTRAINT fk_citizen_reports_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE sensors (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    sensor_type VARCHAR(255) NOT NULL,\n    location_id INTEGER NOT NULL,\n    installation_date DATE,\n    decommission_date DATE,\n    is_active BOOLEAN NOT NULL,\n    operation_mode VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_sensors PRIMARY KEY (id),\n    CONSTRAINT fk_sensors_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE incidents (\n    id INTEGER NOT NULL,\n    sensor_id INTEGER NOT NULL,\n    incident_type VARCHAR(255) NOT NULL,\n    reported_timestamp TIMESTAMP NOT NULL,\n    reported_by VARCHAR(255),\n    description TEXT,\n    status VARCHAR(255) NOT NULL,\n    resolved_timestamp TIMESTAMP,\n    CONSTRAINT pk_incidents PRIMARY KEY (id),\n    CONSTRAINT fk_incidents_sensor_id FOREIGN KEY (sensor_id) REFERENCES sensors (id)\n);\n\nCREATE TABLE maintenances (\n    id INTEGER NOT NULL,\n    maintenance_type VARCHAR(255) NOT NULL,\n    scheduled_date DATE,\n    actual_date DATE,\n    work_description TEXT,\n    status VARCHAR(255) NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_maintenances PRIMARY KEY (id)\n);\n\nCREATE TABLE maintenance_sensors (\n    id INTEGER NOT NULL,\n    maintenance_id INTEGER NOT NULL,\n    sensor_id INTEGER NOT NULL,\n    CONSTRAINT pk_maintenance_sensors PRIMARY KEY (id),\n    CONSTRAINT fk_maintenance_sensors_maintenance_id FOREIGN KEY (maintenance_id) REFERENCES maintenances (id),\n    CONSTRAINT fk_maintenance_sensors_sensor_id FOREIGN KEY (sensor_id) REFERENCES sensors (id)\n);\n\nCREATE TABLE measurement_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    unit VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_measurement_types PRIMARY KEY (id)\n);\n\nCREATE TABLE sensor_measurements (\n    id INTEGER NOT NULL,\n    sensor_id INTEGER NOT NULL,\n    measurement_type_id INTEGER NOT NULL,\n    CONSTRAINT pk_sensor_measurements PRIMARY KEY (id),\n    CONSTRAINT fk_sensor_measurements_sensor_id FOREIGN KEY (sensor_id) REFERENCES sensors (id),\n    CONSTRAINT fk_sensor_measurements_measurement_type_id FOREIGN KEY (measurement_type_id) REFERENCES measurement_types (id)\n);\n\nCREATE TABLE measurements (\n    id INTEGER NOT NULL,\n    sensor_measurement_id INTEGER NOT NULL,\n    measurement_timestamp TIMESTAMP NOT NULL,\n    value DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_measurements PRIMARY KEY (id),\n    CONSTRAINT fk_measurements_sensor_measurement_id FOREIGN KEY (sensor_measurement_id) REFERENCES sensor_measurements (id)\n);\n\nCREATE TABLE operators (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    operator_type VARCHAR(255) NOT NULL,\n    contact_email VARCHAR(255),\n    contact_phone VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_operators PRIMARY KEY (id)\n);\n\nCREATE TABLE projects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_projects PRIMARY KEY (id)\n);\n\nCREATE TABLE project_operators (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    operator_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    start_date DATE,\n    end_date DATE,\n    CONSTRAINT pk_project_operators PRIMARY KEY (id),\n    CONSTRAINT fk_project_operators_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_operators_operator_id FOREIGN KEY (operator_id) REFERENCES operators (id)\n);\n\nCREATE TABLE project_sensors (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    sensor_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    start_date DATE,\n    end_date DATE,\n    CONSTRAINT pk_project_sensors PRIMARY KEY (id),\n    CONSTRAINT fk_project_sensors_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_sensors_sensor_id FOREIGN KEY (sensor_id) REFERENCES sensors (id)\n);\n\nCREATE TABLE sensor_operators (\n    id INTEGER NOT NULL,\n    sensor_id INTEGER NOT NULL,\n    operator_id INTEGER NOT NULL,\n    responsibility_type VARCHAR(255),\n    start_date DATE,\n    end_date DATE,\n    CONSTRAINT pk_sensor_operators PRIMARY KEY (id),\n    CONSTRAINT fk_sensor_operators_sensor_id FOREIGN KEY (sensor_id) REFERENCES sensors (id),\n    CONSTRAINT fk_sensor_operators_operator_id FOREIGN KEY (operator_id) REFERENCES operators (id)\n);\n",
