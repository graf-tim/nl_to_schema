    "final_ddl": "CREATE TABLE areas (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_areas PRIMARY KEY (id)\n);\n\nCREATE TABLE area_municipalities (\n    area_id INTEGER NOT NULL,\n    municipality_name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_area_municipalities PRIMARY KEY (area_id, municipality_name),\n    CONSTRAINT fk_area_municipalities_area_id FOREIGN KEY (area_id) REFERENCES areas (id)\n);\n\nCREATE TABLE equipment (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_equipment PRIMARY KEY (id)\n);\n\nCREATE TABLE functions (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_functions PRIMARY KEY (id)\n);\n\nCREATE TABLE incidents (\n    id INTEGER NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    start_time TIMESTAMP NOT NULL,\n    end_time TIMESTAMP,\n    classification VARCHAR(255),\n    area_id INTEGER NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_incidents PRIMARY KEY (id),\n    CONSTRAINT fk_incidents_area_id FOREIGN KEY (area_id) REFERENCES areas (id)\n);\n\nCREATE TABLE organizations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255),\n    contact_email VARCHAR(255),\n    contact_phone VARCHAR(255),\n    CONSTRAINT pk_organizations PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    primary_organization_id INTEGER NOT NULL,\n    CONSTRAINT pk_persons PRIMARY KEY (id),\n    CONSTRAINT fk_persons_primary_organization_id FOREIGN KEY (primary_organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE messages (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    sender_person_id INTEGER,\n    sender_callsign VARCHAR(255),\n    sender_unit VARCHAR(255),\n    message_time TIMESTAMP NOT NULL,\n    priority VARCHAR(255),\n    content TEXT NOT NULL,\n    CONSTRAINT pk_messages PRIMARY KEY (id),\n    CONSTRAINT fk_messages_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_messages_sender_person_id FOREIGN KEY (sender_person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE operations (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    responsible_organization_id INTEGER NOT NULL,\n    start_time TIMESTAMP,\n    end_time TIMESTAMP,\n    CONSTRAINT pk_operations PRIMARY KEY (id),\n    CONSTRAINT fk_operations_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_operations_responsible_organization_id FOREIGN KEY (responsible_organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE operation_equipment (\n    operation_id INTEGER NOT NULL,\n    equipment_id INTEGER NOT NULL,\n    assignment_time TIMESTAMP,\n    release_time TIMESTAMP,\n    CONSTRAINT pk_operation_equipment PRIMARY KEY (operation_id, equipment_id),\n    CONSTRAINT fk_operation_equipment_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_operation_equipment_equipment_id FOREIGN KEY (equipment_id) REFERENCES equipment (id)\n);\n\nCREATE TABLE operation_personnel (\n    operation_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    assignment_organization_id INTEGER,\n    start_time TIMESTAMP,\n    end_time TIMESTAMP,\n    CONSTRAINT pk_operation_personnel PRIMARY KEY (operation_id, person_id),\n    CONSTRAINT fk_operation_personnel_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_operation_personnel_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_operation_personnel_assignment_organization_id FOREIGN KEY (assignment_organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE person_functions (\n    person_id INTEGER NOT NULL,\n    operation_id INTEGER NOT NULL,\n    function_id INTEGER NOT NULL,\n    start_time TIMESTAMP,\n    end_time TIMESTAMP,\n    CONSTRAINT pk_person_functions PRIMARY KEY (person_id, operation_id, function_id),\n    CONSTRAINT fk_person_functions_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_functions_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_person_functions_function_id FOREIGN KEY (function_id) REFERENCES functions (id)\n);\n\nCREATE TABLE person_organizations (\n    person_id INTEGER NOT NULL,\n    organization_id INTEGER NOT NULL,\n    assignment_date DATE,\n    end_date DATE,\n    CONSTRAINT pk_person_organizations PRIMARY KEY (person_id, organization_id),\n    CONSTRAINT fk_person_organizations_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_organizations_organization_id FOREIGN KEY (organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE qualifications (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_qualifications PRIMARY KEY (id)\n);\n\nCREATE TABLE person_qualifications (\n    person_id INTEGER NOT NULL,\n    qualification_id INTEGER NOT NULL,\n    acquired_date DATE,\n    expiry_date DATE,\n    CONSTRAINT pk_person_qualifications PRIMARY KEY (person_id, qualification_id),\n    CONSTRAINT fk_person_qualifications_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_qualifications_qualification_id FOREIGN KEY (qualification_id) REFERENCES qualifications (id)\n);\n\nCREATE TABLE vehicles (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255),\n    registration_number VARCHAR(255),\n    home_organization_id INTEGER NOT NULL,\n    CONSTRAINT pk_vehicles PRIMARY KEY (id),\n    CONSTRAINT fk_vehicles_home_organization_id FOREIGN KEY (home_organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE resource_deployments (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    vehicle_id INTEGER,\n    equipment_id INTEGER,\n    requested_time TIMESTAMP NOT NULL,\n    arrival_time TIMESTAMP,\n    released_time TIMESTAMP,\n    CONSTRAINT pk_resource_deployments PRIMARY KEY (id),\n    CONSTRAINT fk_resource_deployments_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_resource_deployments_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id),\n    CONSTRAINT fk_resource_deployments_equipment_id FOREIGN KEY (equipment_id) REFERENCES equipment (id)\n);\n\nCREATE TABLE vehicle_equipment (\n    vehicle_id INTEGER NOT NULL,\n    equipment_id INTEGER NOT NULL,\n    assignment_date DATE,\n    removal_date DATE,\n    CONSTRAINT pk_vehicle_equipment PRIMARY KEY (vehicle_id, equipment_id),\n    CONSTRAINT fk_vehicle_equipment_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id),\n    CONSTRAINT fk_vehicle_equipment_equipment_id FOREIGN KEY (equipment_id) REFERENCES equipment (id)\n);\n",
