    "final_ddl": "CREATE TABLE tenants (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    address TEXT,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_tenants PRIMARY KEY (id)\n);\n\nCREATE TABLE invoices (\n    id INTEGER NOT NULL,\n    tenant_id INTEGER NOT NULL,\n    invoice_number VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    invoice_date DATE NOT NULL,\n    due_date DATE,\n    total_amount DECIMAL(18,2) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_invoices PRIMARY KEY (id),\n    CONSTRAINT fk_invoices_tenant_id FOREIGN KEY (tenant_id) REFERENCES tenants (id)\n);\n\nCREATE TABLE projects (\n    id INTEGER NOT NULL,\n    tenant_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_projects PRIMARY KEY (id),\n    CONSTRAINT fk_projects_tenant_id FOREIGN KEY (tenant_id) REFERENCES tenants (id)\n);\n\nCREATE TABLE users (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    status VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_users PRIMARY KEY (id)\n);\n\nCREATE TABLE services (\n    id INTEGER NOT NULL,\n    tenant_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    hourly_rate DECIMAL(18,2),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_services PRIMARY KEY (id),\n    CONSTRAINT fk_services_tenant_id FOREIGN KEY (tenant_id) REFERENCES tenants (id)\n);\n\nCREATE TABLE time_entries (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    user_id INTEGER NOT NULL,\n    service_id INTEGER,\n    hours DECIMAL(18,2) NOT NULL,\n    entry_date DATE NOT NULL,\n    description TEXT,\n    is_billable BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_time_entries PRIMARY KEY (id),\n    CONSTRAINT fk_time_entries_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_time_entries_user_id FOREIGN KEY (user_id) REFERENCES users (id),\n    CONSTRAINT fk_time_entries_service_id FOREIGN KEY (service_id) REFERENCES services (id)\n);\n\nCREATE TABLE invoice_line_items (\n    id INTEGER NOT NULL,\n    invoice_id INTEGER NOT NULL,\n    time_entry_id INTEGER NOT NULL,\n    hours DECIMAL(18,2) NOT NULL,\n    hourly_rate DECIMAL(18,2) NOT NULL,\n    line_amount DECIMAL(18,2) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_invoice_line_items PRIMARY KEY (id),\n    CONSTRAINT fk_invoice_line_items_invoice_id FOREIGN KEY (invoice_id) REFERENCES invoices (id),\n    CONSTRAINT fk_invoice_line_items_time_entry_id FOREIGN KEY (time_entry_id) REFERENCES time_entries (id)\n);\n\nCREATE TABLE packages (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    max_users INTEGER,\n    max_active_projects INTEGER,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_packages PRIMARY KEY (id)\n);\n\nCREATE TABLE project_members (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    user_id INTEGER NOT NULL,\n    is_billable BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_project_members PRIMARY KEY (id),\n    CONSTRAINT fk_project_members_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_members_user_id FOREIGN KEY (user_id) REFERENCES users (id)\n);\n\nCREATE TABLE project_service_rates (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    service_id INTEGER NOT NULL,\n    hourly_rate DECIMAL(18,2) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_project_service_rates PRIMARY KEY (id),\n    CONSTRAINT fk_project_service_rates_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_service_rates_service_id FOREIGN KEY (service_id) REFERENCES services (id)\n);\n\nCREATE TABLE tags (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    tenant_id INTEGER,\n    is_global BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_tags PRIMARY KEY (id),\n    CONSTRAINT fk_tags_tenant_id FOREIGN KEY (tenant_id) REFERENCES tenants (id)\n);\n\nCREATE TABLE project_tags (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    tag_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_project_tags PRIMARY KEY (id),\n    CONSTRAINT fk_project_tags_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_tags_tag_id FOREIGN KEY (tag_id) REFERENCES tags (id)\n);\n\nCREATE TABLE roles (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    tenant_id INTEGER,\n    is_global BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_roles PRIMARY KEY (id),\n    CONSTRAINT fk_roles_tenant_id FOREIGN KEY (tenant_id) REFERENCES tenants (id)\n);\n\nCREATE TABLE tenant_packages (\n    id INTEGER NOT NULL,\n    tenant_id INTEGER NOT NULL,\n    package_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_tenant_packages PRIMARY KEY (id),\n    CONSTRAINT fk_tenant_packages_tenant_id FOREIGN KEY (tenant_id) REFERENCES tenants (id),\n    CONSTRAINT fk_tenant_packages_package_id FOREIGN KEY (package_id) REFERENCES packages (id)\n);\n\nCREATE TABLE user_tenant_roles (\n    id INTEGER NOT NULL,\n    user_id INTEGER NOT NULL,\n    tenant_id INTEGER NOT NULL,\n    role_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_user_tenant_roles PRIMARY KEY (id),\n    CONSTRAINT fk_user_tenant_roles_user_id FOREIGN KEY (user_id) REFERENCES users (id),\n    CONSTRAINT fk_user_tenant_roles_tenant_id FOREIGN KEY (tenant_id) REFERENCES tenants (id),\n    CONSTRAINT fk_user_tenant_roles_role_id FOREIGN KEY (role_id) REFERENCES roles (id)\n);\n",
