    "final_ddl": "CREATE TABLE studies (\n    id INTEGER NOT NULL,\n    short_name VARCHAR(255) NOT NULL,\n    official_title VARCHAR(255) NOT NULL,\n    therapeutic_area VARCHAR(255),\n    phase VARCHAR(255),\n    start_date DATE,\n    end_date DATE,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_studies PRIMARY KEY (id)\n);\n\nCREATE TABLE sites (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address TEXT,\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_sites PRIMARY KEY (id)\n);\n\nCREATE TABLE participants (\n    id INTEGER NOT NULL,\n    study_id INTEGER NOT NULL,\n    site_id INTEGER NOT NULL,\n    screening_number VARCHAR(255) NOT NULL,\n    randomization_number VARCHAR(255),\n    birthdate DATE NOT NULL,\n    gender VARCHAR(255) NOT NULL,\n    recruitment_status VARCHAR(255) NOT NULL,\n    enrollment_date DATE,\n    CONSTRAINT pk_participants PRIMARY KEY (id),\n    CONSTRAINT fk_participants_study_id FOREIGN KEY (study_id) REFERENCES studies (id),\n    CONSTRAINT fk_participants_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE treatment_arms (\n    id INTEGER NOT NULL,\n    study_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    dosage VARCHAR(255),\n    CONSTRAINT pk_treatment_arms PRIMARY KEY (id),\n    CONSTRAINT fk_treatment_arms_study_id FOREIGN KEY (study_id) REFERENCES studies (id)\n);\n\nCREATE TABLE planned_visits (\n    id INTEGER NOT NULL,\n    study_id INTEGER NOT NULL,\n    treatment_arm_id INTEGER,\n    visit_name VARCHAR(255) NOT NULL,\n    visit_order INTEGER,\n    description TEXT,\n    CONSTRAINT pk_planned_visits PRIMARY KEY (id),\n    CONSTRAINT fk_planned_visits_study_id FOREIGN KEY (study_id) REFERENCES studies (id),\n    CONSTRAINT fk_planned_visits_treatment_arm_id FOREIGN KEY (treatment_arm_id) REFERENCES treatment_arms (id)\n);\n\nCREATE TABLE actual_visits (\n    id INTEGER NOT NULL,\n    participant_id INTEGER NOT NULL,\n    planned_visit_id INTEGER NOT NULL,\n    visit_date DATE NOT NULL,\n    is_complete BOOLEAN NOT NULL,\n    deviations TEXT,\n    remarks TEXT,\n    CONSTRAINT pk_actual_visits PRIMARY KEY (id),\n    CONSTRAINT fk_actual_visits_participant_id FOREIGN KEY (participant_id) REFERENCES participants (id),\n    CONSTRAINT fk_actual_visits_planned_visit_id FOREIGN KEY (planned_visit_id) REFERENCES planned_visits (id)\n);\n\nCREATE TABLE adverse_events (\n    id INTEGER NOT NULL,\n    participant_id INTEGER NOT NULL,\n    event_name VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    severity VARCHAR(255) NOT NULL,\n    causality_assessment VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_adverse_events PRIMARY KEY (id),\n    CONSTRAINT fk_adverse_events_participant_id FOREIGN KEY (participant_id) REFERENCES participants (id)\n);\n\nCREATE TABLE participant_arm_assignments (\n    id INTEGER NOT NULL,\n    participant_id INTEGER NOT NULL,\n    treatment_arm_id INTEGER NOT NULL,\n    assignment_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_participant_arm_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_participant_arm_assignments_participant_id FOREIGN KEY (participant_id) REFERENCES participants (id),\n    CONSTRAINT fk_participant_arm_assignments_treatment_arm_id FOREIGN KEY (treatment_arm_id) REFERENCES treatment_arms (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255),\n    lastname VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    role VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE study_sites (\n    id INTEGER NOT NULL,\n    study_id INTEGER NOT NULL,\n    site_id INTEGER NOT NULL,\n    CONSTRAINT pk_study_sites PRIMARY KEY (id),\n    CONSTRAINT fk_study_sites_study_id FOREIGN KEY (study_id) REFERENCES studies (id),\n    CONSTRAINT fk_study_sites_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE study_staff (\n    id INTEGER NOT NULL,\n    study_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role VARCHAR(255) NOT NULL,\n    is_principal_investigator BOOLEAN NOT NULL,\n    CONSTRAINT pk_study_staff PRIMARY KEY (id),\n    CONSTRAINT fk_study_staff_study_id FOREIGN KEY (study_id) REFERENCES studies (id),\n    CONSTRAINT fk_study_staff_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n",
