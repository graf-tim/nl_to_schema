    "final_ddl": "CREATE TABLE attorneys (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    role VARCHAR(255) NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_attorneys PRIMARY KEY (id)\n);\n\nCREATE TABLE courts (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    court_type VARCHAR(255) NOT NULL,\n    address TEXT,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_courts PRIMARY KEY (id)\n);\n\nCREATE TABLE mandates (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    legal_area VARCHAR(255) NOT NULL,\n    opened_date DATE NOT NULL,\n    closed_date DATE,\n    is_active BOOLEAN NOT NULL,\n    lead_attorney_id INTEGER NOT NULL,\n    court_id INTEGER,\n    case_number VARCHAR(255),\n    instance_level VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_mandates PRIMARY KEY (id),\n    CONSTRAINT fk_mandates_lead_attorney_id FOREIGN KEY (lead_attorney_id) REFERENCES attorneys (id),\n    CONSTRAINT fk_mandates_court_id FOREIGN KEY (court_id) REFERENCES courts (id)\n);\n\nCREATE TABLE court_appointments (\n    id INTEGER NOT NULL,\n    mandate_id INTEGER NOT NULL,\n    appointment_date DATE NOT NULL,\n    appointment_time VARCHAR(255),\n    location VARCHAR(255),\n    appointment_type VARCHAR(255) NOT NULL,\n    is_cancelled BOOLEAN NOT NULL,\n    remarks TEXT,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_court_appointments PRIMARY KEY (id),\n    CONSTRAINT fk_court_appointments_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id)\n);\n\nCREATE TABLE appointment_attendees (\n    appointment_id INTEGER NOT NULL,\n    attorney_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_appointment_attendees PRIMARY KEY (appointment_id, attorney_id),\n    CONSTRAINT fk_appointment_attendees_appointment_id FOREIGN KEY (appointment_id) REFERENCES court_appointments (id),\n    CONSTRAINT fk_appointment_attendees_attorney_id FOREIGN KEY (attorney_id) REFERENCES attorneys (id)\n);\n\nCREATE TABLE case_notes (\n    id INTEGER NOT NULL,\n    mandate_id INTEGER NOT NULL,\n    attorney_id INTEGER NOT NULL,\n    note_text TEXT NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_case_notes PRIMARY KEY (id),\n    CONSTRAINT fk_case_notes_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id),\n    CONSTRAINT fk_case_notes_attorney_id FOREIGN KEY (attorney_id) REFERENCES attorneys (id)\n);\n\nCREATE TABLE clients (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_clients PRIMARY KEY (id)\n);\n\nCREATE TABLE documents (\n    id INTEGER NOT NULL,\n    mandate_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    document_type VARCHAR(255) NOT NULL,\n    created_date DATE,\n    received_date DATE,\n    is_official BOOLEAN NOT NULL,\n    remarks TEXT,\n    file_path VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_documents PRIMARY KEY (id),\n    CONSTRAINT fk_documents_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id)\n);\n\nCREATE TABLE deadlines (\n    id INTEGER NOT NULL,\n    mandate_id INTEGER NOT NULL,\n    document_id INTEGER,\n    title VARCHAR(255) NOT NULL,\n    deadline_date DATE NOT NULL,\n    pre_deadline_date DATE,\n    responsible_attorney_id INTEGER,\n    is_secretary_responsible BOOLEAN NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    remarks TEXT,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_deadlines PRIMARY KEY (id),\n    CONSTRAINT fk_deadlines_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id),\n    CONSTRAINT fk_deadlines_document_id FOREIGN KEY (document_id) REFERENCES documents (id),\n    CONSTRAINT fk_deadlines_responsible_attorney_id FOREIGN KEY (responsible_attorney_id) REFERENCES attorneys (id)\n);\n\nCREATE TABLE insurance_providers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_insurance_providers PRIMARY KEY (id)\n);\n\nCREATE TABLE parties (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_parties PRIMARY KEY (id)\n);\n\nCREATE TABLE invoices (\n    id INTEGER NOT NULL,\n    mandate_id INTEGER NOT NULL,\n    invoice_date DATE NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    billed_to VARCHAR(255) NOT NULL,\n    client_id INTEGER,\n    insurance_provider_id INTEGER,\n    third_party_id INTEGER,\n    remarks TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_invoices PRIMARY KEY (id),\n    CONSTRAINT fk_invoices_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id),\n    CONSTRAINT fk_invoices_client_id FOREIGN KEY (client_id) REFERENCES clients (id),\n    CONSTRAINT fk_invoices_insurance_provider_id FOREIGN KEY (insurance_provider_id) REFERENCES insurance_providers (id),\n    CONSTRAINT fk_invoices_third_party_id FOREIGN KEY (third_party_id) REFERENCES parties (id)\n);\n\nCREATE TABLE mandate_attorneys (\n    mandate_id INTEGER NOT NULL,\n    attorney_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_mandate_attorneys PRIMARY KEY (mandate_id, attorney_id),\n    CONSTRAINT fk_mandate_attorneys_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id),\n    CONSTRAINT fk_mandate_attorneys_attorney_id FOREIGN KEY (attorney_id) REFERENCES attorneys (id)\n);\n\nCREATE TABLE mandate_clients (\n    mandate_id INTEGER NOT NULL,\n    client_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_mandate_clients PRIMARY KEY (mandate_id, client_id),\n    CONSTRAINT fk_mandate_clients_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id),\n    CONSTRAINT fk_mandate_clients_client_id FOREIGN KEY (client_id) REFERENCES clients (id)\n);\n\nCREATE TABLE mandate_insurance (\n    mandate_id INTEGER NOT NULL,\n    insurance_provider_id INTEGER NOT NULL,\n    policy_number VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_mandate_insurance PRIMARY KEY (mandate_id, insurance_provider_id),\n    CONSTRAINT fk_mandate_insurance_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id),\n    CONSTRAINT fk_mandate_insurance_insurance_provider_id FOREIGN KEY (insurance_provider_id) REFERENCES insurance_providers (id)\n);\n\nCREATE TABLE mandate_parties (\n    mandate_id INTEGER NOT NULL,\n    party_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_mandate_parties PRIMARY KEY (mandate_id, party_id),\n    CONSTRAINT fk_mandate_parties_mandate_id FOREIGN KEY (mandate_id) REFERENCES mandates (id),\n    CONSTRAINT fk_mandate_parties_party_id FOREIGN KEY (party_id) REFERENCES parties (id)\n);\n",
