    "final_ddl": "CREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE vehicles (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    licensplate VARCHAR(255) NOT NULL,\n    brand VARCHAR(255) NOT NULL,\n    model VARCHAR(255) NOT NULL,\n    builtyear INTEGER,\n    CONSTRAINT pk_vehicles PRIMARY KEY (id),\n    CONSTRAINT fk_vehicles_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE appointments (\n    id INTEGER NOT NULL,\n    vehicle_id INTEGER NOT NULL,\n    appointmentdate DATE NOT NULL,\n    description TEXT,\n    is_completed BOOLEAN NOT NULL,\n    costs DECIMAL(18,2),\n    CONSTRAINT pk_appointments PRIMARY KEY (id),\n    CONSTRAINT fk_appointments_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id)\n);\n",
