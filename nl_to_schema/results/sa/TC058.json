    "final_ddl": "CREATE TABLE employees (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id)\n);\n\nCREATE TABLE vehicle_types (\n    id INTEGER NOT NULL,\n    type_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_vehicle_types PRIMARY KEY (id)\n);\n\nCREATE TABLE vehicles (\n    id INTEGER NOT NULL,\n    license_plate VARCHAR(255) NOT NULL,\n    manufacturer VARCHAR(255) NOT NULL,\n    model VARCHAR(255) NOT NULL,\n    year_of_manufacture INTEGER NOT NULL,\n    current_mileage INTEGER NOT NULL,\n    vehicle_type_id INTEGER,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_vehicles PRIMARY KEY (id),\n    CONSTRAINT fk_vehicles_vehicle_type_id FOREIGN KEY (vehicle_type_id) REFERENCES vehicle_types (id)\n);\n\nCREATE TABLE workshops (\n    id INTEGER NOT NULL,\n    workshop_name VARCHAR(255) NOT NULL,\n    address TEXT,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_workshops PRIMARY KEY (id)\n);\n\nCREATE TABLE maintenance_records (\n    id INTEGER NOT NULL,\n    vehicle_id INTEGER NOT NULL,\n    workshop_id INTEGER NOT NULL,\n    maintenance_date DATE NOT NULL,\n    description TEXT NOT NULL,\n    cost DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_maintenance_records PRIMARY KEY (id),\n    CONSTRAINT fk_maintenance_records_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id),\n    CONSTRAINT fk_maintenance_records_workshop_id FOREIGN KEY (workshop_id) REFERENCES workshops (id)\n);\n\nCREATE TABLE vehicle_assignments (\n    id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    vehicle_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_vehicle_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_vehicle_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_vehicle_assignments_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id)\n);\n",
