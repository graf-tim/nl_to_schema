    "final_ddl": "CREATE TABLE guests (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    street VARCHAR(255),\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_guests PRIMARY KEY (id)\n);\n\nCREATE TABLE room_categories (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    price_per_night DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_room_categories PRIMARY KEY (id)\n);\n\nCREATE TABLE rooms (\n    id INTEGER NOT NULL,\n    room_number VARCHAR(255) NOT NULL,\n    floor INTEGER NOT NULL,\n    max_occupancy INTEGER NOT NULL,\n    room_category_id INTEGER NOT NULL,\n    CONSTRAINT pk_rooms PRIMARY KEY (id),\n    CONSTRAINT fk_rooms_room_category_id FOREIGN KEY (room_category_id) REFERENCES room_categories (id)\n);\n\nCREATE TABLE bookings (\n    id INTEGER NOT NULL,\n    guest_id INTEGER NOT NULL,\n    room_id INTEGER NOT NULL,\n    checkin_date DATE NOT NULL,\n    checkout_date DATE NOT NULL,\n    booking_date TIMESTAMP NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_bookings PRIMARY KEY (id),\n    CONSTRAINT fk_bookings_guest_id FOREIGN KEY (guest_id) REFERENCES guests (id),\n    CONSTRAINT fk_bookings_room_id FOREIGN KEY (room_id) REFERENCES rooms (id)\n);\n\nCREATE TABLE services (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    price DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_services PRIMARY KEY (id)\n);\n\nCREATE TABLE booking_services (\n    id INTEGER NOT NULL,\n    booking_id INTEGER NOT NULL,\n    service_id INTEGER NOT NULL,\n    quantity INTEGER,\n    days INTEGER,\n    CONSTRAINT pk_booking_services PRIMARY KEY (id),\n    CONSTRAINT fk_booking_services_booking_id FOREIGN KEY (booking_id) REFERENCES bookings (id),\n    CONSTRAINT fk_booking_services_service_id FOREIGN KEY (service_id) REFERENCES services (id)\n);\n\nCREATE TABLE room_unavailability (\n    id INTEGER NOT NULL,\n    room_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    reason VARCHAR(255) NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_room_unavailability PRIMARY KEY (id),\n    CONSTRAINT fk_room_unavailability_room_id FOREIGN KEY (room_id) REFERENCES rooms (id)\n);\n",
