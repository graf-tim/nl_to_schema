    "final_ddl": "CREATE TABLE disciplines (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_disciplines PRIMARY KEY (id)\n);\n\nCREATE TABLE manufacturers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_manufacturers PRIMARY KEY (id)\n);\n\nCREATE TABLE hardware (\n    id INTEGER NOT NULL,\n    manufacturer_id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    hardware_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_hardware PRIMARY KEY (id),\n    CONSTRAINT fk_hardware_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id)\n);\n\nCREATE TABLE milestone_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_milestone_types PRIMARY KEY (id)\n);\n\nCREATE TABLE programs (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_programs PRIMARY KEY (id)\n);\n\nCREATE TABLE missions (\n    id INTEGER NOT NULL,\n    program_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    is_study BOOLEAN NOT NULL,\n    planned_start DATE NOT NULL,\n    actual_start DATE,\n    mission_end DATE,\n    CONSTRAINT pk_missions PRIMARY KEY (id),\n    CONSTRAINT fk_missions_program_id FOREIGN KEY (program_id) REFERENCES programs (id)\n);\n\nCREATE TABLE milestones (\n    id INTEGER NOT NULL,\n    mission_id INTEGER NOT NULL,\n    milestone_type_id INTEGER NOT NULL,\n    milestone_date DATE NOT NULL,\n    CONSTRAINT pk_milestones PRIMARY KEY (id),\n    CONSTRAINT fk_milestones_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id),\n    CONSTRAINT fk_milestones_milestone_type_id FOREIGN KEY (milestone_type_id) REFERENCES milestone_types (id)\n);\n\nCREATE TABLE mission_hardware (\n    mission_id INTEGER NOT NULL,\n    hardware_id INTEGER NOT NULL,\n    CONSTRAINT pk_mission_hardware PRIMARY KEY (mission_id, hardware_id),\n    CONSTRAINT fk_mission_hardware_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id),\n    CONSTRAINT fk_mission_hardware_hardware_id FOREIGN KEY (hardware_id) REFERENCES hardware (id)\n);\n\nCREATE TABLE teams (\n    id INTEGER NOT NULL,\n    discipline_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_teams PRIMARY KEY (id),\n    CONSTRAINT fk_teams_discipline_id FOREIGN KEY (discipline_id) REFERENCES disciplines (id)\n);\n\nCREATE TABLE mission_teams (\n    mission_id INTEGER NOT NULL,\n    team_id INTEGER NOT NULL,\n    CONSTRAINT pk_mission_teams PRIMARY KEY (mission_id, team_id),\n    CONSTRAINT fk_mission_teams_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id),\n    CONSTRAINT fk_mission_teams_team_id FOREIGN KEY (team_id) REFERENCES teams (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE roles (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_roles PRIMARY KEY (id)\n);\n\nCREATE TABLE person_roles (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role_id INTEGER NOT NULL,\n    team_id INTEGER,\n    mission_id INTEGER,\n    CONSTRAINT pk_person_roles PRIMARY KEY (id),\n    CONSTRAINT fk_person_roles_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_roles_role_id FOREIGN KEY (role_id) REFERENCES roles (id),\n    CONSTRAINT fk_person_roles_team_id FOREIGN KEY (team_id) REFERENCES teams (id),\n    CONSTRAINT fk_person_roles_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id)\n);\n\nCREATE TABLE risks (\n    id INTEGER NOT NULL,\n    description TEXT NOT NULL,\n    probability DECIMAL(18,2) NOT NULL,\n    impact DECIMAL(18,2) NOT NULL,\n    is_open BOOLEAN NOT NULL,\n    mission_id INTEGER,\n    hardware_id INTEGER,\n    team_id INTEGER,\n    CONSTRAINT pk_risks PRIMARY KEY (id),\n    CONSTRAINT fk_risks_mission_id FOREIGN KEY (mission_id) REFERENCES missions (id),\n    CONSTRAINT fk_risks_hardware_id FOREIGN KEY (hardware_id) REFERENCES hardware (id),\n    CONSTRAINT fk_risks_team_id FOREIGN KEY (team_id) REFERENCES teams (id)\n);\n",
