    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    registrationdate DATE NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE movies (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    publicationyear INTEGER NOT NULL,\n    genre VARCHAR(255) NOT NULL,\n    agerating INTEGER NOT NULL,\n    CONSTRAINT pk_movies PRIMARY KEY (id)\n);\n\nCREATE TABLE rentals (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    movie_id INTEGER NOT NULL,\n    checkoutdate DATE NOT NULL,\n    duedate DATE NOT NULL,\n    returndate DATE,\n    CONSTRAINT pk_rentals PRIMARY KEY (id),\n    CONSTRAINT fk_rentals_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_rentals_movie_id FOREIGN KEY (movie_id) REFERENCES movies (id)\n);\n",
