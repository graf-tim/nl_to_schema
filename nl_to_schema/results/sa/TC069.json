    "final_ddl": "CREATE TABLE product_families (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_product_families PRIMARY KEY (id)\n);\n\nCREATE TABLE articles (\n    id INTEGER NOT NULL,\n    material_number VARCHAR(255) NOT NULL,\n    description VARCHAR(255),\n    product_family_id INTEGER NOT NULL,\n    is_in_planning BOOLEAN NOT NULL,\n    CONSTRAINT pk_articles PRIMARY KEY (id),\n    CONSTRAINT fk_articles_product_family_id FOREIGN KEY (product_family_id) REFERENCES product_families (id)\n);\n\nCREATE TABLE components (\n    id INTEGER NOT NULL,\n    material_number VARCHAR(255) NOT NULL,\n    description VARCHAR(255),\n    unit VARCHAR(255),\n    CONSTRAINT pk_components PRIMARY KEY (id)\n);\n\nCREATE TABLE bill_of_materials (\n    id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    component_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    unit VARCHAR(255),\n    CONSTRAINT pk_bill_of_materials PRIMARY KEY (id),\n    CONSTRAINT fk_bill_of_materials_article_id FOREIGN KEY (article_id) REFERENCES articles (id),\n    CONSTRAINT fk_bill_of_materials_component_id FOREIGN KEY (component_id) REFERENCES components (id)\n);\n\nCREATE TABLE production_orders (\n    id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    planned_quantity DECIMAL(18,2) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP,\n    CONSTRAINT pk_production_orders PRIMARY KEY (id),\n    CONSTRAINT fk_production_orders_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE storage_locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_storage_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE material_reservations (\n    id INTEGER NOT NULL,\n    production_order_id INTEGER NOT NULL,\n    component_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    storage_location_id INTEGER,\n    reserved_at TIMESTAMP,\n    CONSTRAINT pk_material_reservations PRIMARY KEY (id),\n    CONSTRAINT fk_material_reservations_production_order_id FOREIGN KEY (production_order_id) REFERENCES production_orders (id),\n    CONSTRAINT fk_material_reservations_component_id FOREIGN KEY (component_id) REFERENCES components (id),\n    CONSTRAINT fk_material_reservations_storage_location_id FOREIGN KEY (storage_location_id) REFERENCES storage_locations (id)\n);\n\nCREATE TABLE work_plans (\n    id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    version INTEGER NOT NULL,\n    is_released BOOLEAN NOT NULL,\n    created_at TIMESTAMP,\n    CONSTRAINT pk_work_plans PRIMARY KEY (id),\n    CONSTRAINT fk_work_plans_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE operations (\n    id INTEGER NOT NULL,\n    work_plan_id INTEGER NOT NULL,\n    sequence_number INTEGER NOT NULL,\n    operation_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    estimated_duration_minutes INTEGER,\n    CONSTRAINT pk_operations PRIMARY KEY (id),\n    CONSTRAINT fk_operations_work_plan_id FOREIGN KEY (work_plan_id) REFERENCES work_plans (id)\n);\n\nCREATE TABLE workstations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_workstations PRIMARY KEY (id)\n);\n\nCREATE TABLE operation_workstations (\n    id INTEGER NOT NULL,\n    operation_id INTEGER NOT NULL,\n    workstation_id INTEGER NOT NULL,\n    CONSTRAINT pk_operation_workstations PRIMARY KEY (id),\n    CONSTRAINT fk_operation_workstations_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_operation_workstations_workstation_id FOREIGN KEY (workstation_id) REFERENCES workstations (id)\n);\n\nCREATE TABLE scheduled_operations (\n    id INTEGER NOT NULL,\n    production_order_id INTEGER NOT NULL,\n    operation_id INTEGER,\n    sequence_number INTEGER NOT NULL,\n    operation_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    estimated_duration_minutes INTEGER,\n    scheduled_start TIMESTAMP,\n    scheduled_end TIMESTAMP,\n    CONSTRAINT pk_scheduled_operations PRIMARY KEY (id),\n    CONSTRAINT fk_scheduled_operations_production_order_id FOREIGN KEY (production_order_id) REFERENCES production_orders (id),\n    CONSTRAINT fk_scheduled_operations_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id)\n);\n\nCREATE TABLE scheduled_operation_workstations (\n    id INTEGER NOT NULL,\n    scheduled_operation_id INTEGER NOT NULL,\n    workstation_id INTEGER NOT NULL,\n    CONSTRAINT pk_scheduled_operation_workstations PRIMARY KEY (id),\n    CONSTRAINT fk_scheduled_operation_workstations_scheduled_operation_id FOREIGN KEY (scheduled_operation_id) REFERENCES scheduled_operations (id),\n    CONSTRAINT fk_scheduled_operation_workstations_workstation_id FOREIGN KEY (workstation_id) REFERENCES workstations (id)\n);\n\nCREATE TABLE workstation_availabilities (\n    id INTEGER NOT NULL,\n    workstation_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    available_hours DECIMAL(18,2) NOT NULL,\n    reason VARCHAR(255),\n    CONSTRAINT pk_workstation_availabilities PRIMARY KEY (id),\n    CONSTRAINT fk_workstation_availabilities_workstation_id FOREIGN KEY (workstation_id) REFERENCES workstations (id)\n);\n",
