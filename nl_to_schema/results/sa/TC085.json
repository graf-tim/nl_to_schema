    "final_ddl": "CREATE TABLE units (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    unit_type VARCHAR(255),\n    parent_unit_id INTEGER,\n    CONSTRAINT pk_units PRIMARY KEY (id),\n    CONSTRAINT fk_units_parent_unit_id FOREIGN KEY (parent_unit_id) REFERENCES units (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location_type VARCHAR(255) NOT NULL,\n    unit_id INTEGER,\n    description TEXT,\n    CONSTRAINT pk_locations PRIMARY KEY (id),\n    CONSTRAINT fk_locations_unit_id FOREIGN KEY (unit_id) REFERENCES units (id)\n);\n\nCREATE TABLE material_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    material_category VARCHAR(255) NOT NULL,\n    unit_of_measure VARCHAR(255) NOT NULL,\n    is_piece_counted BOOLEAN NOT NULL,\n    hazard_class VARCHAR(255),\n    storage_note TEXT,\n    CONSTRAINT pk_material_types PRIMARY KEY (id)\n);\n\nCREATE TABLE stock (\n    id INTEGER NOT NULL,\n    material_type_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    batch_number VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_stock PRIMARY KEY (id),\n    CONSTRAINT fk_stock_material_type_id FOREIGN KEY (material_type_id) REFERENCES material_types (id),\n    CONSTRAINT fk_stock_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE personnel (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    rank VARCHAR(255),\n    unit_id INTEGER,\n    role VARCHAR(255),\n    CONSTRAINT pk_personnel PRIMARY KEY (id),\n    CONSTRAINT fk_personnel_unit_id FOREIGN KEY (unit_id) REFERENCES units (id)\n);\n\nCREATE TABLE material_movements (\n    id INTEGER NOT NULL,\n    stock_id INTEGER NOT NULL,\n    movement_type VARCHAR(255) NOT NULL,\n    quantity_moved DECIMAL(18,2) NOT NULL,\n    from_location_id INTEGER,\n    to_location_id INTEGER,\n    movement_time TIMESTAMP NOT NULL,\n    initiated_by_personnel_id INTEGER NOT NULL,\n    confirmed_by_personnel_id INTEGER,\n    reason TEXT,\n    CONSTRAINT pk_material_movements PRIMARY KEY (id),\n    CONSTRAINT fk_material_movements_stock_id FOREIGN KEY (stock_id) REFERENCES stock (id),\n    CONSTRAINT fk_material_movements_from_location_id FOREIGN KEY (from_location_id) REFERENCES locations (id),\n    CONSTRAINT fk_material_movements_to_location_id FOREIGN KEY (to_location_id) REFERENCES locations (id),\n    CONSTRAINT fk_material_movements_initiated_by_personnel_id FOREIGN KEY (initiated_by_personnel_id) REFERENCES personnel (id),\n    CONSTRAINT fk_material_movements_confirmed_by_personnel_id FOREIGN KEY (confirmed_by_personnel_id) REFERENCES personnel (id)\n);\n\nCREATE TABLE material_requests (\n    id INTEGER NOT NULL,\n    requesting_unit_id INTEGER NOT NULL,\n    demand_bearer_unit_id INTEGER,\n    requested_at TIMESTAMP NOT NULL,\n    priority VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_material_requests PRIMARY KEY (id),\n    CONSTRAINT fk_material_requests_requesting_unit_id FOREIGN KEY (requesting_unit_id) REFERENCES units (id),\n    CONSTRAINT fk_material_requests_demand_bearer_unit_id FOREIGN KEY (demand_bearer_unit_id) REFERENCES units (id)\n);\n\nCREATE TABLE request_items (\n    id INTEGER NOT NULL,\n    material_request_id INTEGER NOT NULL,\n    material_type_id INTEGER NOT NULL,\n    quantity_requested DECIMAL(18,2) NOT NULL,\n    quantity_fulfilled DECIMAL(18,2),\n    CONSTRAINT pk_request_items PRIMARY KEY (id),\n    CONSTRAINT fk_request_items_material_request_id FOREIGN KEY (material_request_id) REFERENCES material_requests (id),\n    CONSTRAINT fk_request_items_material_type_id FOREIGN KEY (material_type_id) REFERENCES material_types (id)\n);\n\nCREATE TABLE services (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location_id INTEGER NOT NULL,\n    CONSTRAINT pk_services PRIMARY KEY (id),\n    CONSTRAINT fk_services_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE vehicles (\n    id INTEGER NOT NULL,\n    registration_number VARCHAR(255) NOT NULL,\n    vehicle_type VARCHAR(255) NOT NULL,\n    payload_capacity DECIMAL(18,2),\n    unit_id INTEGER,\n    CONSTRAINT pk_vehicles PRIMARY KEY (id),\n    CONSTRAINT fk_vehicles_unit_id FOREIGN KEY (unit_id) REFERENCES units (id)\n);\n\nCREATE TABLE transports (\n    id INTEGER NOT NULL,\n    vehicle_id INTEGER NOT NULL,\n    origin_location_id INTEGER NOT NULL,\n    destination_location_id INTEGER NOT NULL,\n    departure_time TIMESTAMP NOT NULL,\n    arrival_time TIMESTAMP,\n    status VARCHAR(255) NOT NULL,\n    initiated_by_personnel_id INTEGER NOT NULL,\n    confirmed_by_personnel_id INTEGER,\n    CONSTRAINT pk_transports PRIMARY KEY (id),\n    CONSTRAINT fk_transports_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id),\n    CONSTRAINT fk_transports_origin_location_id FOREIGN KEY (origin_location_id) REFERENCES locations (id),\n    CONSTRAINT fk_transports_destination_location_id FOREIGN KEY (destination_location_id) REFERENCES locations (id),\n    CONSTRAINT fk_transports_initiated_by_personnel_id FOREIGN KEY (initiated_by_personnel_id) REFERENCES personnel (id),\n    CONSTRAINT fk_transports_confirmed_by_personnel_id FOREIGN KEY (confirmed_by_personnel_id) REFERENCES personnel (id)\n);\n\nCREATE TABLE shipments (\n    id INTEGER NOT NULL,\n    transport_id INTEGER NOT NULL,\n    material_request_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_shipments PRIMARY KEY (id),\n    CONSTRAINT fk_shipments_transport_id FOREIGN KEY (transport_id) REFERENCES transports (id),\n    CONSTRAINT fk_shipments_material_request_id FOREIGN KEY (material_request_id) REFERENCES material_requests (id)\n);\n\nCREATE TABLE shipment_items (\n    id INTEGER NOT NULL,\n    shipment_id INTEGER NOT NULL,\n    stock_id INTEGER NOT NULL,\n    quantity_shipped DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_shipment_items PRIMARY KEY (id),\n    CONSTRAINT fk_shipment_items_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id),\n    CONSTRAINT fk_shipment_items_stock_id FOREIGN KEY (stock_id) REFERENCES stock (id)\n);\n\nCREATE TABLE transport_personnel (\n    transport_id INTEGER NOT NULL,\n    personnel_id INTEGER NOT NULL,\n    role VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_transport_personnel PRIMARY KEY (transport_id, personnel_id),\n    CONSTRAINT fk_transport_personnel_transport_id FOREIGN KEY (transport_id) REFERENCES transports (id),\n    CONSTRAINT fk_transport_personnel_personnel_id FOREIGN KEY (personnel_id) REFERENCES personnel (id)\n);\n",
