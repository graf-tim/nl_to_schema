    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    customer_since DATE NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE products (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    category VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_products PRIMARY KEY (id)\n);\n\nCREATE TABLE devices (\n    id INTEGER NOT NULL,\n    product_id INTEGER NOT NULL,\n    serial_number VARCHAR(255) NOT NULL,\n    customer_id INTEGER NOT NULL,\n    purchase_date DATE,\n    CONSTRAINT pk_devices PRIMARY KEY (id),\n    CONSTRAINT fk_devices_product_id FOREIGN KEY (product_id) REFERENCES products (id),\n    CONSTRAINT fk_devices_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_employees PRIMARY KEY (id)\n);\n\nCREATE TABLE specializations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_specializations PRIMARY KEY (id)\n);\n\nCREATE TABLE employee_specializations (\n    employee_id INTEGER NOT NULL,\n    specialization_id INTEGER NOT NULL,\n    CONSTRAINT pk_employee_specializations PRIMARY KEY (employee_id, specialization_id),\n    CONSTRAINT fk_employee_specializations_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_employee_specializations_specialization_id FOREIGN KEY (specialization_id) REFERENCES specializations (id)\n);\n\nCREATE TABLE tickets (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    device_id INTEGER,\n    subject VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    priority VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    resolved_at TIMESTAMP,\n    resolution TEXT,\n    CONSTRAINT pk_tickets PRIMARY KEY (id),\n    CONSTRAINT fk_tickets_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_tickets_device_id FOREIGN KEY (device_id) REFERENCES devices (id)\n);\n\nCREATE TABLE ticket_assignments (\n    id INTEGER NOT NULL,\n    ticket_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    assigned_at TIMESTAMP NOT NULL,\n    unassigned_at TIMESTAMP,\n    CONSTRAINT pk_ticket_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_ticket_assignments_ticket_id FOREIGN KEY (ticket_id) REFERENCES tickets (id),\n    CONSTRAINT fk_ticket_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n",
