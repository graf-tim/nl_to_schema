    "final_ddl": "CREATE TABLE owners (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address VARCHAR(255),\n    CONSTRAINT pk_owners PRIMARY KEY (id)\n);\n\nCREATE TABLE apartments (\n    id INTEGER NOT NULL,\n    owner_id INTEGER NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    size_sqm DECIMAL(18,2) NOT NULL,\n    room_count INTEGER NOT NULL,\n    rent_amount DECIMAL(18,2) NOT NULL,\n    description TEXT,\n    available_from DATE,\n    CONSTRAINT pk_apartments PRIMARY KEY (id),\n    CONSTRAINT fk_apartments_owner_id FOREIGN KEY (owner_id) REFERENCES owners (id)\n);\n\nCREATE TABLE interested_parties (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    inquiry_date TIMESTAMP NOT NULL,\n    CONSTRAINT pk_interested_parties PRIMARY KEY (id)\n);\n\nCREATE TABLE apartment_registrations (\n    id INTEGER NOT NULL,\n    apartment_id INTEGER NOT NULL,\n    interested_party_id INTEGER NOT NULL,\n    registration_date TIMESTAMP NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_apartment_registrations PRIMARY KEY (id),\n    CONSTRAINT fk_apartment_registrations_apartment_id FOREIGN KEY (apartment_id) REFERENCES apartments (id),\n    CONSTRAINT fk_apartment_registrations_interested_party_id FOREIGN KEY (interested_party_id) REFERENCES interested_parties (id)\n);\n\nCREATE TABLE feedbacks (\n    id INTEGER NOT NULL,\n    apartment_id INTEGER NOT NULL,\n    interested_party_id INTEGER NOT NULL,\n    rating DECIMAL(18,2),\n    comment TEXT,\n    feedback_date TIMESTAMP NOT NULL,\n    CONSTRAINT pk_feedbacks PRIMARY KEY (id),\n    CONSTRAINT fk_feedbacks_apartment_id FOREIGN KEY (apartment_id) REFERENCES apartments (id),\n    CONSTRAINT fk_feedbacks_interested_party_id FOREIGN KEY (interested_party_id) REFERENCES interested_parties (id)\n);\n\nCREATE TABLE viewing_appointments (\n    id INTEGER NOT NULL,\n    apartment_id INTEGER NOT NULL,\n    appointment_date DATE NOT NULL,\n    appointment_time VARCHAR(255) NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_viewing_appointments PRIMARY KEY (id),\n    CONSTRAINT fk_viewing_appointments_apartment_id FOREIGN KEY (apartment_id) REFERENCES apartments (id)\n);\n\nCREATE TABLE viewing_participants (\n    id INTEGER NOT NULL,\n    viewing_appointment_id INTEGER NOT NULL,\n    interested_party_id INTEGER NOT NULL,\n    CONSTRAINT pk_viewing_participants PRIMARY KEY (id),\n    CONSTRAINT fk_viewing_participants_viewing_appointment_id FOREIGN KEY (viewing_appointment_id) REFERENCES viewing_appointments (id),\n    CONSTRAINT fk_viewing_participants_interested_party_id FOREIGN KEY (interested_party_id) REFERENCES interested_parties (id)\n);\n",
