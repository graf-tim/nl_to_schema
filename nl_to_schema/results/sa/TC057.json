    "final_ddl": "CREATE TABLE authors (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_authors PRIMARY KEY (id)\n);\n\nCREATE TABLE books (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    publication_year INTEGER,\n    language VARCHAR(255),\n    isbn VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_books PRIMARY KEY (id)\n);\n\nCREATE TABLE author_books (\n    author_id INTEGER NOT NULL,\n    book_id INTEGER NOT NULL,\n    CONSTRAINT pk_author_books PRIMARY KEY (author_id, book_id),\n    CONSTRAINT fk_author_books_author_id FOREIGN KEY (author_id) REFERENCES authors (id),\n    CONSTRAINT fk_author_books_book_id FOREIGN KEY (book_id) REFERENCES books (id)\n);\n\nCREATE TABLE readers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    registration_date DATE NOT NULL,\n    CONSTRAINT pk_readers PRIMARY KEY (id)\n);\n\nCREATE TABLE libraries (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    contact_address VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_libraries PRIMARY KEY (id)\n);\n\nCREATE TABLE library_inventory (\n    id INTEGER NOT NULL,\n    library_id INTEGER NOT NULL,\n    book_id INTEGER NOT NULL,\n    is_available BOOLEAN NOT NULL,\n    CONSTRAINT pk_library_inventory PRIMARY KEY (id),\n    CONSTRAINT fk_library_inventory_library_id FOREIGN KEY (library_id) REFERENCES libraries (id),\n    CONSTRAINT fk_library_inventory_book_id FOREIGN KEY (book_id) REFERENCES books (id)\n);\n\nCREATE TABLE checkouts (\n    id INTEGER NOT NULL,\n    reader_id INTEGER NOT NULL,\n    library_inventory_id INTEGER NOT NULL,\n    library_id INTEGER NOT NULL,\n    checkout_date DATE NOT NULL,\n    due_date DATE NOT NULL,\n    return_date DATE,\n    CONSTRAINT pk_checkouts PRIMARY KEY (id),\n    CONSTRAINT fk_checkouts_reader_id FOREIGN KEY (reader_id) REFERENCES readers (id),\n    CONSTRAINT fk_checkouts_library_inventory_id FOREIGN KEY (library_inventory_id) REFERENCES library_inventory (id),\n    CONSTRAINT fk_checkouts_library_id FOREIGN KEY (library_id) REFERENCES libraries (id)\n);\n",
