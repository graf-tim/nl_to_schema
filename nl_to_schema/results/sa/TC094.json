    "final_ddl": "CREATE TABLE provenance_sources (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    source_type VARCHAR(255),\n    CONSTRAINT pk_provenance_sources PRIMARY KEY (id)\n);\n\nCREATE TABLE submissions (\n    id INTEGER NOT NULL,\n    provenance_source_id INTEGER NOT NULL,\n    submission_date DATE NOT NULL,\n    access_title VARCHAR(255) NOT NULL,\n    reference_number VARCHAR(255),\n    CONSTRAINT pk_submissions PRIMARY KEY (id),\n    CONSTRAINT fk_submissions_provenance_source_id FOREIGN KEY (provenance_source_id) REFERENCES provenance_sources (id)\n);\n\nCREATE TABLE archival_units (\n    id INTEGER NOT NULL,\n    submission_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    start_date DATE,\n    end_date DATE,\n    extent_value DECIMAL(18,2),\n    extent_unit VARCHAR(255),\n    retention_note TEXT,\n    CONSTRAINT pk_archival_units PRIMARY KEY (id),\n    CONSTRAINT fk_archival_units_submission_id FOREIGN KEY (submission_id) REFERENCES submissions (id)\n);\n\nCREATE TABLE keywords (\n    id INTEGER NOT NULL,\n    keyword VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_keywords PRIMARY KEY (id)\n);\n\nCREATE TABLE archival_unit_keywords (\n    id INTEGER NOT NULL,\n    archival_unit_id INTEGER NOT NULL,\n    keyword_id INTEGER NOT NULL,\n    CONSTRAINT pk_archival_unit_keywords PRIMARY KEY (id),\n    CONSTRAINT fk_archival_unit_keywords_archival_unit_id FOREIGN KEY (archival_unit_id) REFERENCES archival_units (id),\n    CONSTRAINT fk_archival_unit_keywords_keyword_id FOREIGN KEY (keyword_id) REFERENCES keywords (id)\n);\n\nCREATE TABLE decision_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_decision_types PRIMARY KEY (id)\n);\n\nCREATE TABLE digitals (\n    id INTEGER NOT NULL,\n    archival_unit_id INTEGER NOT NULL,\n    filename VARCHAR(255) NOT NULL,\n    file_path VARCHAR(255),\n    digitalization_date DATE,\n    access_level VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_digitals PRIMARY KEY (id),\n    CONSTRAINT fk_digitals_archival_unit_id FOREIGN KEY (archival_unit_id) REFERENCES archival_units (id)\n);\n\nCREATE TABLE institutions (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    institution_type VARCHAR(255),\n    CONSTRAINT pk_institutions PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255),\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE loans (\n    id INTEGER NOT NULL,\n    archival_unit_id INTEGER NOT NULL,\n    person_id INTEGER,\n    institution_id INTEGER,\n    loan_start_date DATE NOT NULL,\n    loan_end_date DATE,\n    loan_purpose VARCHAR(255),\n    condition_at_loan TEXT,\n    condition_at_return TEXT,\n    CONSTRAINT pk_loans PRIMARY KEY (id),\n    CONSTRAINT fk_loans_archival_unit_id FOREIGN KEY (archival_unit_id) REFERENCES archival_units (id),\n    CONSTRAINT fk_loans_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_loans_institution_id FOREIGN KEY (institution_id) REFERENCES institutions (id)\n);\n\nCREATE TABLE relationship_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_relationship_types PRIMARY KEY (id)\n);\n\nCREATE TABLE usage_requests (\n    id INTEGER NOT NULL,\n    person_id INTEGER,\n    institution_id INTEGER,\n    request_date DATE NOT NULL,\n    request_purpose TEXT,\n    CONSTRAINT pk_usage_requests PRIMARY KEY (id),\n    CONSTRAINT fk_usage_requests_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_usage_requests_institution_id FOREIGN KEY (institution_id) REFERENCES institutions (id)\n);\n\nCREATE TABLE request_units (\n    id INTEGER NOT NULL,\n    usage_request_id INTEGER NOT NULL,\n    archival_unit_id INTEGER NOT NULL,\n    CONSTRAINT pk_request_units PRIMARY KEY (id),\n    CONSTRAINT fk_request_units_usage_request_id FOREIGN KEY (usage_request_id) REFERENCES usage_requests (id),\n    CONSTRAINT fk_request_units_archival_unit_id FOREIGN KEY (archival_unit_id) REFERENCES archival_units (id)\n);\n\nCREATE TABLE request_decisions (\n    id INTEGER NOT NULL,\n    request_unit_id INTEGER NOT NULL,\n    decision_type_id INTEGER NOT NULL,\n    decision_date DATE NOT NULL,\n    conditions TEXT,\n    CONSTRAINT pk_request_decisions PRIMARY KEY (id),\n    CONSTRAINT fk_request_decisions_request_unit_id FOREIGN KEY (request_unit_id) REFERENCES request_units (id),\n    CONSTRAINT fk_request_decisions_decision_type_id FOREIGN KEY (decision_type_id) REFERENCES decision_types (id)\n);\n\nCREATE TABLE restriction_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_restriction_types PRIMARY KEY (id)\n);\n\nCREATE TABLE restrictions (\n    id INTEGER NOT NULL,\n    archival_unit_id INTEGER NOT NULL,\n    restriction_type_id INTEGER NOT NULL,\n    restriction_reason TEXT,\n    restriction_start_date DATE,\n    restriction_end_date DATE,\n    CONSTRAINT pk_restrictions PRIMARY KEY (id),\n    CONSTRAINT fk_restrictions_archival_unit_id FOREIGN KEY (archival_unit_id) REFERENCES archival_units (id),\n    CONSTRAINT fk_restrictions_restriction_type_id FOREIGN KEY (restriction_type_id) REFERENCES restriction_types (id)\n);\n\nCREATE TABLE unit_relationships (\n    id INTEGER NOT NULL,\n    source_unit_id INTEGER NOT NULL,\n    target_unit_id INTEGER NOT NULL,\n    relationship_type_id INTEGER NOT NULL,\n    CONSTRAINT pk_unit_relationships PRIMARY KEY (id),\n    CONSTRAINT fk_unit_relationships_source_unit_id FOREIGN KEY (source_unit_id) REFERENCES archival_units (id),\n    CONSTRAINT fk_unit_relationships_target_unit_id FOREIGN KEY (target_unit_id) REFERENCES archival_units (id),\n    CONSTRAINT fk_unit_relationships_relationship_type_id FOREIGN KEY (relationship_type_id) REFERENCES relationship_types (id)\n);\n",
