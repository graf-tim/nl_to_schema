    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    company VARCHAR(255),\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE bookings (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    start_date TIMESTAMP NOT NULL,\n    end_date TIMESTAMP NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_bookings PRIMARY KEY (id),\n    CONSTRAINT fk_bookings_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE offerings (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_offerings PRIMARY KEY (id)\n);\n\nCREATE TABLE booking_offerings (\n    booking_id INTEGER NOT NULL,\n    offering_id INTEGER NOT NULL,\n    CONSTRAINT pk_booking_offerings PRIMARY KEY (booking_id, offering_id),\n    CONSTRAINT fk_booking_offerings_booking_id FOREIGN KEY (booking_id) REFERENCES bookings (id),\n    CONSTRAINT fk_booking_offerings_offering_id FOREIGN KEY (offering_id) REFERENCES offerings (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address VARCHAR(255),\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE spaces (\n    id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    offering_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    max_capacity INTEGER NOT NULL,\n    is_bookable BOOLEAN NOT NULL,\n    CONSTRAINT pk_spaces PRIMARY KEY (id),\n    CONSTRAINT fk_spaces_location_id FOREIGN KEY (location_id) REFERENCES locations (id),\n    CONSTRAINT fk_spaces_offering_id FOREIGN KEY (offering_id) REFERENCES offerings (id)\n);\n\nCREATE TABLE booking_spaces (\n    booking_id INTEGER NOT NULL,\n    space_id INTEGER NOT NULL,\n    CONSTRAINT pk_booking_spaces PRIMARY KEY (booking_id, space_id),\n    CONSTRAINT fk_booking_spaces_booking_id FOREIGN KEY (booking_id) REFERENCES bookings (id),\n    CONSTRAINT fk_booking_spaces_space_id FOREIGN KEY (space_id) REFERENCES spaces (id)\n);\n\nCREATE TABLE offering_locations (\n    offering_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    is_available BOOLEAN NOT NULL,\n    CONSTRAINT pk_offering_locations PRIMARY KEY (offering_id, location_id),\n    CONSTRAINT fk_offering_locations_offering_id FOREIGN KEY (offering_id) REFERENCES offerings (id),\n    CONSTRAINT fk_offering_locations_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n",
