    "final_ddl": "CREATE TABLE articles (\n    id INTEGER NOT NULL,\n    article_number VARCHAR(255) NOT NULL,\n    description TEXT,\n    commodity_group VARCHAR(255),\n    origin_country VARCHAR(255),\n    tariff_number VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_articles PRIMARY KEY (id)\n);\n\nCREATE TABLE companies (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    company_type VARCHAR(255) NOT NULL,\n    street VARCHAR(255),\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    tax_id VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_companies PRIMARY KEY (id)\n);\n\nCREATE TABLE article_prices (\n    id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    currency VARCHAR(255) NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    valid_from DATE NOT NULL,\n    valid_until DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_article_prices PRIMARY KEY (id),\n    CONSTRAINT fk_article_prices_article_id FOREIGN KEY (article_id) REFERENCES articles (id),\n    CONSTRAINT fk_article_prices_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE contacts (\n    id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_contacts_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE contact_responsibilities (\n    id INTEGER NOT NULL,\n    contact_id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    responsibility_type VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_contact_responsibilities PRIMARY KEY (id),\n    CONSTRAINT fk_contact_responsibilities_contact_id FOREIGN KEY (contact_id) REFERENCES contacts (id),\n    CONSTRAINT fk_contact_responsibilities_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE documents (\n    id INTEGER NOT NULL,\n    document_type VARCHAR(255) NOT NULL,\n    document_number VARCHAR(255),\n    file_path VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_documents PRIMARY KEY (id)\n);\n\nCREATE TABLE purchase_orders (\n    id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    order_number VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    order_date DATE NOT NULL,\n    currency VARCHAR(255) NOT NULL,\n    incoterms VARCHAR(255),\n    preferred_transport VARCHAR(255),\n    payment_terms VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_purchase_orders PRIMARY KEY (id),\n    CONSTRAINT fk_purchase_orders_supplier_id FOREIGN KEY (supplier_id) REFERENCES companies (id)\n);\n\nCREATE TABLE purchase_order_items (\n    id INTEGER NOT NULL,\n    purchase_order_id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    unit_price DECIMAL(18,2) NOT NULL,\n    discount_percent DECIMAL(18,2),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_purchase_order_items PRIMARY KEY (id),\n    CONSTRAINT fk_purchase_order_items_purchase_order_id FOREIGN KEY (purchase_order_id) REFERENCES purchase_orders (id),\n    CONSTRAINT fk_purchase_order_items_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE sales_orders (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    order_number VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    order_date DATE NOT NULL,\n    currency VARCHAR(255) NOT NULL,\n    incoterms VARCHAR(255),\n    preferred_transport VARCHAR(255),\n    payment_terms VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_sales_orders PRIMARY KEY (id),\n    CONSTRAINT fk_sales_orders_customer_id FOREIGN KEY (customer_id) REFERENCES companies (id)\n);\n\nCREATE TABLE sales_order_items (\n    id INTEGER NOT NULL,\n    sales_order_id INTEGER NOT NULL,\n    article_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    unit_price DECIMAL(18,2) NOT NULL,\n    discount_percent DECIMAL(18,2),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_sales_order_items PRIMARY KEY (id),\n    CONSTRAINT fk_sales_order_items_sales_order_id FOREIGN KEY (sales_order_id) REFERENCES sales_orders (id),\n    CONSTRAINT fk_sales_order_items_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE item_documents (\n    id INTEGER NOT NULL,\n    document_id INTEGER NOT NULL,\n    purchase_order_item_id INTEGER,\n    sales_order_item_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_item_documents PRIMARY KEY (id),\n    CONSTRAINT fk_item_documents_document_id FOREIGN KEY (document_id) REFERENCES documents (id),\n    CONSTRAINT fk_item_documents_purchase_order_item_id FOREIGN KEY (purchase_order_item_id) REFERENCES purchase_order_items (id),\n    CONSTRAINT fk_item_documents_sales_order_item_id FOREIGN KEY (sales_order_item_id) REFERENCES sales_order_items (id)\n);\n\nCREATE TABLE order_documents (\n    id INTEGER NOT NULL,\n    document_id INTEGER NOT NULL,\n    purchase_order_id INTEGER,\n    sales_order_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_order_documents PRIMARY KEY (id),\n    CONSTRAINT fk_order_documents_document_id FOREIGN KEY (document_id) REFERENCES documents (id),\n    CONSTRAINT fk_order_documents_purchase_order_id FOREIGN KEY (purchase_order_id) REFERENCES purchase_orders (id),\n    CONSTRAINT fk_order_documents_sales_order_id FOREIGN KEY (sales_order_id) REFERENCES sales_orders (id)\n);\n\nCREATE TABLE shipments (\n    id INTEGER NOT NULL,\n    shipment_number VARCHAR(255) NOT NULL,\n    shipment_type VARCHAR(255) NOT NULL,\n    origin_country VARCHAR(255),\n    destination_country VARCHAR(255),\n    currency VARCHAR(255),\n    payment_terms VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_shipments PRIMARY KEY (id)\n);\n\nCREATE TABLE shipment_orders (\n    id INTEGER NOT NULL,\n    shipment_id INTEGER NOT NULL,\n    purchase_order_id INTEGER,\n    sales_order_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_shipment_orders PRIMARY KEY (id),\n    CONSTRAINT fk_shipment_orders_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id),\n    CONSTRAINT fk_shipment_orders_purchase_order_id FOREIGN KEY (purchase_order_id) REFERENCES purchase_orders (id),\n    CONSTRAINT fk_shipment_orders_sales_order_id FOREIGN KEY (sales_order_id) REFERENCES sales_orders (id)\n);\n",
