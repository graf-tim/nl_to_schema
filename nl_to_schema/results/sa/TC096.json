    "final_ddl": "CREATE TABLE suppliers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    country VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_suppliers PRIMARY KEY (id)\n);\n\nCREATE TABLE materials (\n    id INTEGER NOT NULL,\n    material_number VARCHAR(255) NOT NULL,\n    description TEXT,\n    unit VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_materials PRIMARY KEY (id)\n);\n\nCREATE TABLE plants (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255),\n    country VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_plants PRIMARY KEY (id)\n);\n\nCREATE TABLE certificates (\n    id INTEGER NOT NULL,\n    certificate_type VARCHAR(255) NOT NULL,\n    certificate_number VARCHAR(255),\n    description TEXT,\n    supplier_id INTEGER,\n    material_id INTEGER,\n    plant_id INTEGER,\n    valid_from DATE NOT NULL,\n    valid_to DATE NOT NULL,\n    document_reference VARCHAR(255),\n    document_path TEXT,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_certificates PRIMARY KEY (id),\n    CONSTRAINT fk_certificates_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id),\n    CONSTRAINT fk_certificates_material_id FOREIGN KEY (material_id) REFERENCES materials (id),\n    CONSTRAINT fk_certificates_plant_id FOREIGN KEY (plant_id) REFERENCES plants (id)\n);\n\nCREATE TABLE forwarders (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    country VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_forwarders PRIMARY KEY (id)\n);\n\nCREATE TABLE forwarder_contacts (\n    id INTEGER NOT NULL,\n    forwarder_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    department VARCHAR(255),\n    is_primary BOOLEAN NOT NULL,\n    CONSTRAINT pk_forwarder_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_forwarder_contacts_forwarder_id FOREIGN KEY (forwarder_id) REFERENCES forwarders (id)\n);\n\nCREATE TABLE plant_contacts (\n    id INTEGER NOT NULL,\n    plant_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    department VARCHAR(255),\n    is_primary BOOLEAN NOT NULL,\n    CONSTRAINT pk_plant_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_plant_contacts_plant_id FOREIGN KEY (plant_id) REFERENCES plants (id)\n);\n\nCREATE TABLE plant_materials (\n    id INTEGER NOT NULL,\n    plant_id INTEGER NOT NULL,\n    material_id INTEGER NOT NULL,\n    is_allowed_to_use BOOLEAN NOT NULL,\n    is_allowed_to_store BOOLEAN NOT NULL,\n    valid_from DATE,\n    valid_to DATE,\n    CONSTRAINT pk_plant_materials PRIMARY KEY (id),\n    CONSTRAINT fk_plant_materials_plant_id FOREIGN KEY (plant_id) REFERENCES plants (id),\n    CONSTRAINT fk_plant_materials_material_id FOREIGN KEY (material_id) REFERENCES materials (id)\n);\n\nCREATE TABLE purchase_orders (\n    id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    order_number VARCHAR(255) NOT NULL,\n    order_date DATE NOT NULL,\n    delivery_plant_id INTEGER NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_purchase_orders PRIMARY KEY (id),\n    CONSTRAINT fk_purchase_orders_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id),\n    CONSTRAINT fk_purchase_orders_delivery_plant_id FOREIGN KEY (delivery_plant_id) REFERENCES plants (id)\n);\n\nCREATE TABLE purchase_order_positions (\n    id INTEGER NOT NULL,\n    purchase_order_id INTEGER NOT NULL,\n    material_id INTEGER NOT NULL,\n    position_number INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    unit_price DECIMAL(18,2),\n    requested_delivery_date DATE,\n    quantity_received DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_purchase_order_positions PRIMARY KEY (id),\n    CONSTRAINT fk_purchase_order_positions_purchase_order_id FOREIGN KEY (purchase_order_id) REFERENCES purchase_orders (id),\n    CONSTRAINT fk_purchase_order_positions_material_id FOREIGN KEY (material_id) REFERENCES materials (id)\n);\n\nCREATE TABLE shipments (\n    id INTEGER NOT NULL,\n    purchase_order_position_id INTEGER NOT NULL,\n    shipment_number VARCHAR(255) NOT NULL,\n    forwarder_id INTEGER,\n    quantity DECIMAL(18,2) NOT NULL,\n    incoterm VARCHAR(255),\n    tracking_number VARCHAR(255),\n    planned_shipment_date DATE,\n    actual_shipment_date DATE,\n    planned_arrival_date DATE,\n    actual_arrival_date DATE,\n    status VARCHAR(255) NOT NULL,\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_shipments PRIMARY KEY (id),\n    CONSTRAINT fk_shipments_purchase_order_position_id FOREIGN KEY (purchase_order_position_id) REFERENCES purchase_order_positions (id),\n    CONSTRAINT fk_shipments_forwarder_id FOREIGN KEY (forwarder_id) REFERENCES forwarders (id)\n);\n\nCREATE TABLE quality_events (\n    id INTEGER NOT NULL,\n    event_type VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    severity VARCHAR(255),\n    event_date DATE NOT NULL,\n    shipment_id INTEGER,\n    material_id INTEGER,\n    responsible_supplier_id INTEGER,\n    responsible_plant_id INTEGER,\n    responsible_forwarder_id INTEGER,\n    status VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_quality_events PRIMARY KEY (id),\n    CONSTRAINT fk_quality_events_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id),\n    CONSTRAINT fk_quality_events_material_id FOREIGN KEY (material_id) REFERENCES materials (id),\n    CONSTRAINT fk_quality_events_responsible_supplier_id FOREIGN KEY (responsible_supplier_id) REFERENCES suppliers (id),\n    CONSTRAINT fk_quality_events_responsible_plant_id FOREIGN KEY (responsible_plant_id) REFERENCES plants (id),\n    CONSTRAINT fk_quality_events_responsible_forwarder_id FOREIGN KEY (responsible_forwarder_id) REFERENCES forwarders (id)\n);\n\nCREATE TABLE quality_event_assignments (\n    id INTEGER NOT NULL,\n    quality_event_id INTEGER NOT NULL,\n    assigned_to_supplier_id INTEGER,\n    assigned_to_plant_id INTEGER,\n    assigned_to_forwarder_id INTEGER,\n    assigned_date DATE NOT NULL,\n    CONSTRAINT pk_quality_event_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_quality_event_assignments_quality_event_id FOREIGN KEY (quality_event_id) REFERENCES quality_events (id),\n    CONSTRAINT fk_quality_event_assignments_assigned_to_supplier_id FOREIGN KEY (assigned_to_supplier_id) REFERENCES suppliers (id),\n    CONSTRAINT fk_quality_event_assignments_assigned_to_plant_id FOREIGN KEY (assigned_to_plant_id) REFERENCES plants (id),\n    CONSTRAINT fk_quality_event_assignments_assigned_to_forwarder_id FOREIGN KEY (assigned_to_forwarder_id) REFERENCES forwarders (id)\n);\n\nCREATE TABLE supplier_contacts (\n    id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    department VARCHAR(255),\n    is_primary BOOLEAN NOT NULL,\n    CONSTRAINT pk_supplier_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_supplier_contacts_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id)\n);\n\nCREATE TABLE supplier_materials (\n    id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    material_id INTEGER NOT NULL,\n    supplier_article_number VARCHAR(255),\n    is_approved BOOLEAN NOT NULL,\n    is_preferred BOOLEAN NOT NULL,\n    lead_time_days INTEGER,\n    minimum_order_quantity DECIMAL(18,2),\n    price DECIMAL(18,2),\n    valid_from DATE,\n    valid_to DATE,\n    CONSTRAINT pk_supplier_materials PRIMARY KEY (id),\n    CONSTRAINT fk_supplier_materials_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id),\n    CONSTRAINT fk_supplier_materials_material_id FOREIGN KEY (material_id) REFERENCES materials (id)\n);\n",
