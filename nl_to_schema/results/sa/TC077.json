    "final_ddl": "CREATE TABLE aircraft_models (\n    id INTEGER NOT NULL,\n    manufacturer VARCHAR(255) NOT NULL,\n    model VARCHAR(255) NOT NULL,\n    seat_capacity INTEGER NOT NULL,\n    CONSTRAINT pk_aircraft_models PRIMARY KEY (id)\n);\n\nCREATE TABLE airlines (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    iata_code VARCHAR(255),\n    icao_code VARCHAR(255),\n    CONSTRAINT pk_airlines PRIMARY KEY (id)\n);\n\nCREATE TABLE aircraft (\n    id INTEGER NOT NULL,\n    registration VARCHAR(255) NOT NULL,\n    aircraft_model_id INTEGER NOT NULL,\n    airline_id INTEGER,\n    CONSTRAINT pk_aircraft PRIMARY KEY (id),\n    CONSTRAINT fk_aircraft_aircraft_model_id FOREIGN KEY (aircraft_model_id) REFERENCES aircraft_models (id),\n    CONSTRAINT fk_aircraft_airline_id FOREIGN KEY (airline_id) REFERENCES airlines (id)\n);\n\nCREATE TABLE flights (\n    id INTEGER NOT NULL,\n    flight_number VARCHAR(255) NOT NULL,\n    operating_airline_id INTEGER NOT NULL,\n    aircraft_id INTEGER,\n    origin_airport_code VARCHAR(255),\n    destination_airport_code VARCHAR(255),\n    scheduled_departure TIMESTAMP,\n    actual_departure TIMESTAMP,\n    scheduled_arrival TIMESTAMP,\n    actual_arrival TIMESTAMP,\n    status VARCHAR(255) NOT NULL,\n    flight_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_flights PRIMARY KEY (id),\n    CONSTRAINT fk_flights_operating_airline_id FOREIGN KEY (operating_airline_id) REFERENCES airlines (id),\n    CONSTRAINT fk_flights_aircraft_id FOREIGN KEY (aircraft_id) REFERENCES aircraft (id)\n);\n\nCREATE TABLE flight_codeshares (\n    id INTEGER NOT NULL,\n    flight_id INTEGER NOT NULL,\n    airline_id INTEGER NOT NULL,\n    codeshare_flight_number VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_flight_codeshares PRIMARY KEY (id),\n    CONSTRAINT fk_flight_codeshares_flight_id FOREIGN KEY (flight_id) REFERENCES flights (id),\n    CONSTRAINT fk_flight_codeshares_airline_id FOREIGN KEY (airline_id) REFERENCES airlines (id)\n);\n\nCREATE TABLE 