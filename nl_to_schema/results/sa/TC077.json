,\n    CONSTRAINT pk_runways PRIMARY KEY (id)\n);\n\nCREATE TABLE flight_runways (\n    id INTEGER NOT NULL,\n    flight_id INTEGER NOT NULL,\n    runway_id INTEGER NOT NULL,\n    movement_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_flight_runways PRIMARY KEY (id),\n    CONSTRAINT fk_flight_runways_flight_id FOREIGN KEY (flight_id) REFERENCES flights (id),\n    CONSTRAINT fk_flight_runways_runway_id FOREIGN KEY (runway_id) REFERENCES runways (id)\n);\n\nCREATE TABLE provider_services (\n    id INTEGER NOT NULL,\n    provider_id INTEGER NOT NULL,\n    service_id INTEGER NOT NULL,\n    CONSTRAINT pk_provider_services PRIMARY KEY (id),\n    CONSTRAINT fk_provider_services_provider_id FOREIGN KEY (provider_id) REFERENCES ground_service_providers (id),\n    CONSTRAINT fk_provider_services_service_id FOREIGN KEY (service_id) REFERENCES ground_services (id)\n);\n",
