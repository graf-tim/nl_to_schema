    "final_ddl": "CREATE TABLE parties (\n    id INTEGER NOT NULL,\n    party_type VARCHAR(255) NOT NULL,\n    firstname VARCHAR(255),\n    lastname VARCHAR(255),\n    company_name VARCHAR(255),\n    tax_id VARCHAR(255),\n    business_id VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_parties PRIMARY KEY (id)\n);\n\nCREATE TABLE addresses (\n    id INTEGER NOT NULL,\n    party_id INTEGER NOT NULL,\n    street VARCHAR(255) NOT NULL,\n    house_number VARCHAR(255) NOT NULL,\n    postal_code VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    country VARCHAR(255),\n    valid_from DATE NOT NULL,\n    valid_to DATE,\n    CONSTRAINT pk_addresses PRIMARY KEY (id),\n    CONSTRAINT fk_addresses_party_id FOREIGN KEY (party_id) REFERENCES parties (id)\n);\n\nCREATE TABLE address_purposes (\n    id INTEGER NOT NULL,\n    address_id INTEGER NOT NULL,\n    purpose VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_address_purposes PRIMARY KEY (id),\n    CONSTRAINT fk_address_purposes_address_id FOREIGN KEY (address_id) REFERENCES addresses (id)\n);\n\nCREATE TABLE tax_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    code VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_tax_types PRIMARY KEY (id)\n);\n\nCREATE TABLE tax_cases (\n    id INTEGER NOT NULL,\n    party_id INTEGER NOT NULL,\n    tax_type_id INTEGER NOT NULL,\n    fiscal_year_start DATE NOT NULL,\n    fiscal_year_end DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_tax_cases PRIMARY KEY (id),\n    CONSTRAINT fk_tax_cases_party_id FOREIGN KEY (party_id) REFERENCES parties (id),\n    CONSTRAINT fk_tax_cases_tax_type_id FOREIGN KEY (tax_type_id) REFERENCES tax_types (id)\n);\n\nCREATE TABLE assessments (\n    id INTEGER NOT NULL,\n    tax_case_id INTEGER NOT NULL,\n    assessment_date DATE NOT NULL,\n    assessment_type VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_assessments PRIMARY KEY (id),\n    CONSTRAINT fk_assessments_tax_case_id FOREIGN KEY (tax_case_id) REFERENCES tax_cases (id)\n);\n\nCREATE TABLE documents (\n    id INTEGER NOT NULL,\n    document_type VARCHAR(255) NOT NULL,\n    filename VARCHAR(255) NOT NULL,\n    file_path VARCHAR(255) NOT NULL,\n    file_size INTEGER,\n    uploaded_date DATE NOT NULL,\n    reference_number VARCHAR(255),\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_documents PRIMARY KEY (id)\n);\n\nCREATE TABLE representatives (\n    id INTEGER NOT NULL,\n    representative_type VARCHAR(255) NOT NULL,\n    firstname VARCHAR(255),\n    lastname VARCHAR(255),\n    company_name VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_representatives PRIMARY KEY (id)\n);\n\nCREATE TABLE tax_declarations (\n    id INTEGER NOT NULL,\n    tax_case_id INTEGER NOT NULL,\n    submitted_by_party BOOLEAN NOT NULL,\n    representative_id INTEGER,\n    submission_date DATE NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_tax_declarations PRIMARY KEY (id),\n    CONSTRAINT fk_tax_declarations_tax_case_id FOREIGN KEY (tax_case_id) REFERENCES tax_cases (id),\n    CONSTRAINT fk_tax_declarations_representative_id FOREIGN KEY (representative_id) REFERENCES representatives (id)\n);\n\nCREATE TABLE powers_of_attorney (\n    id INTEGER NOT NULL,\n    party_id INTEGER NOT NULL,\n    representative_id INTEGER NOT NULL,\n    valid_from DATE NOT NULL,\n    valid_to DATE,\n    scope VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_powers_of_attorney PRIMARY KEY (id),\n    CONSTRAINT fk_powers_of_attorney_party_id FOREIGN KEY (party_id) REFERENCES parties (id),\n    CONSTRAINT fk_powers_of_attorney_representative_id FOREIGN KEY (representative_id) REFERENCES representatives (id)\n);\n\nCREATE TABLE objections (\n    id INTEGER NOT NULL,\n    assessment_id INTEGER NOT NULL,\n    objection_date DATE NOT NULL,\n    deadline DATE NOT NULL,\n    received_date DATE,\n    decision_date DATE,\n    decision VARCHAR(255),\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_objections PRIMARY KEY (id),\n    CONSTRAINT fk_objections_assessment_id FOREIGN KEY (assessment_id) REFERENCES assessments (id)\n);\n\nCREATE TABLE payments (\n    id INTEGER NOT NULL,\n    tax_case_id INTEGER NOT NULL,\n    payment_date DATE NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    payment_type VARCHAR(255) NOT NULL,\n    reference VARCHAR(255),\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_payments PRIMARY KEY (id),\n    CONSTRAINT fk_payments_tax_case_id FOREIGN KEY (tax_case_id) REFERENCES tax_cases (id)\n);\n\nCREATE TABLE document_assignments (\n    id INTEGER NOT NULL,\n    document_id INTEGER NOT NULL,\n    tax_case_id INTEGER,\n    assessment_id INTEGER,\n    tax_declaration_id INTEGER,\n    power_of_attorney_id INTEGER,\n    objection_id INTEGER,\n    payment_id INTEGER,\n    CONSTRAINT pk_document_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_document_assignments_document_id FOREIGN KEY (document_id) REFERENCES documents (id),\n    CONSTRAINT fk_document_assignments_tax_case_id FOREIGN KEY (tax_case_id) REFERENCES tax_cases (id),\n    CONSTRAINT fk_document_assignments_assessment_id FOREIGN KEY (assessment_id) REFERENCES assessments (id),\n    CONSTRAINT fk_document_assignments_tax_declaration_id FOREIGN KEY (tax_declaration_id) REFERENCES tax_declarations (id),\n    CONSTRAINT fk_document_assignments_power_of_attorney_id FOREIGN KEY (power_of_attorney_id) REFERENCES powers_of_attorney (id),\n    CONSTRAINT fk_document_assignments_objection_id FOREIGN KEY (objection_id) REFERENCES objections (id),\n    CONSTRAINT fk_document_assignments_payment_id FOREIGN KEY (payment_id) REFERENCES payments (id)\n);\n\nCREATE TABLE late_payment_surcharges (\n    id INTEGER NOT NULL,\n    tax_case_id INTEGER NOT NULL,\n    assessment_id INTEGER,\n    surcharge_date DATE NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    reason TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_late_payment_surcharges PRIMARY KEY (id),\n    CONSTRAINT fk_late_payment_surcharges_tax_case_id FOREIGN KEY (tax_case_id) REFERENCES tax_cases (id),\n    CONSTRAINT fk_late_payment_surcharges_assessment_id FOREIGN KEY (assessment_id) REFERENCES assessments (id)\n);\n\nCREATE TABLE power_of_attorney_tax_types (\n    id INTEGER NOT NULL,\n    power_of_attorney_id INTEGER NOT NULL,\n    tax_type_id INTEGER NOT NULL,\n    CONSTRAINT pk_power_of_attorney_tax_types PRIMARY KEY (id),\n    CONSTRAINT fk_power_of_attorney_tax_types_power_of_attorney_id FOREIGN KEY (power_of_attorney_id) REFERENCES powers_of_attorney (id),\n    CONSTRAINT fk_power_of_attorney_tax_types_tax_type_id FOREIGN KEY (tax_type_id) REFERENCES tax_types (id)\n);\n",
