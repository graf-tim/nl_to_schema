    "final_ddl": "CREATE TABLE objects (\n    id INTEGER NOT NULL,\n    inventory_number VARCHAR(255) NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    object_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    dating_text VARCHAR(255),\n    dating_start_year INTEGER,\n    dating_end_year INTEGER,\n    height_cm DECIMAL(18,2),\n    width_cm DECIMAL(18,2),\n    depth_cm DECIMAL(18,2),\n    weight_kg DECIMAL(18,2),\n    condition_status VARCHAR(255),\n    condition_notes TEXT,\n    is_ensemble BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_objects PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255),\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    deathdate DATE,\n    biography TEXT,\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE conservation_inspections (\n    id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    inspection_date DATE NOT NULL,\n    conservator_id INTEGER NOT NULL,\n    condition_report TEXT NOT NULL,\n    recommendations TEXT,\n    CONSTRAINT pk_conservation_inspections PRIMARY KEY (id),\n    CONSTRAINT fk_conservation_inspections_object_id FOREIGN KEY (object_id) REFERENCES objects (id),\n    CONSTRAINT fk_conservation_inspections_conservator_id FOREIGN KEY (conservator_id) REFERENCES persons (id)\n);\n\nCREATE TABLE conservation_treatments (\n    id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    treatment_date DATE NOT NULL,\n    conservator_id INTEGER NOT NULL,\n    treatment_description TEXT NOT NULL,\n    materials_used TEXT,\n    CONSTRAINT pk_conservation_treatments PRIMARY KEY (id),\n    CONSTRAINT fk_conservation_treatments_object_id FOREIGN KEY (object_id) REFERENCES objects (id),\n    CONSTRAINT fk_conservation_treatments_conservator_id FOREIGN KEY (conservator_id) REFERENCES persons (id)\n);\n\nCREATE TABLE corporations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_corporations PRIMARY KEY (id)\n);\n\nCREATE TABLE digital_documents (\n    id INTEGER NOT NULL,\n    filename VARCHAR(255) NOT NULL,\n    document_type VARCHAR(255) NOT NULL,\n    file_path VARCHAR(255) NOT NULL,\n    description TEXT,\n    upload_date TIMESTAMP NOT NULL,\n    CONSTRAINT pk_digital_documents PRIMARY KEY (id)\n);\n\nCREATE TABLE document_objects (\n    id INTEGER NOT NULL,\n    document_id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    CONSTRAINT pk_document_objects PRIMARY KEY (id),\n    CONSTRAINT fk_document_objects_document_id FOREIGN KEY (document_id) REFERENCES digital_documents (id),\n    CONSTRAINT fk_document_objects_object_id FOREIGN KEY (object_id) REFERENCES objects (id)\n);\n\nCREATE TABLE ensemble_members (\n    id INTEGER NOT NULL,\n    ensemble_id INTEGER NOT NULL,\n    member_id INTEGER NOT NULL,\n    sequence_number INTEGER,\n    notes TEXT,\n    CONSTRAINT pk_ensemble_members PRIMARY KEY (id),\n    CONSTRAINT fk_ensemble_members_ensemble_id FOREIGN KEY (ensemble_id) REFERENCES objects (id),\n    CONSTRAINT fk_ensemble_members_member_id FOREIGN KEY (member_id) REFERENCES objects (id)\n);\n\nCREATE TABLE exhibitions (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    description TEXT,\n    CONSTRAINT pk_exhibitions PRIMARY KEY (id)\n);\n\nCREATE TABLE exhibition_objects (\n    id INTEGER NOT NULL,\n    exhibition_id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    display_location VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_exhibition_objects PRIMARY KEY (id),\n    CONSTRAINT fk_exhibition_objects_exhibition_id FOREIGN KEY (exhibition_id) REFERENCES exhibitions (id),\n    CONSTRAINT fk_exhibition_objects_object_id FOREIGN KEY (object_id) REFERENCES objects (id)\n);\n\nCREATE TABLE loans (\n    id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    loan_type VARCHAR(255) NOT NULL,\n    lender_id INTEGER,\n    borrower_id INTEGER,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    insurance_value DECIMAL(18,2),\n    insurance_currency VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_loans PRIMARY KEY (id),\n    CONSTRAINT fk_loans_object_id FOREIGN KEY (object_id) REFERENCES objects (id),\n    CONSTRAINT fk_loans_lender_id FOREIGN KEY (lender_id) REFERENCES corporations (id),\n    CONSTRAINT fk_loans_borrower_id FOREIGN KEY (borrower_id) REFERENCES corporations (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE materials (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_materials PRIMARY KEY (id)\n);\n\nCREATE TABLE object_corporations (\n    id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    corporation_id INTEGER NOT NULL,\n    role VARCHAR(255) NOT NULL,\n    attribution_certainty VARCHAR(255),\n    CONSTRAINT pk_object_corporations PRIMARY KEY (id),\n    CONSTRAINT fk_object_corporations_object_id FOREIGN KEY (object_id) REFERENCES objects (id),\n    CONSTRAINT fk_object_corporations_corporation_id FOREIGN KEY (corporation_id) REFERENCES corporations (id)\n);\n\nCREATE TABLE object_locations (\n    id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    notes TEXT,\n    CONSTRAINT pk_object_locations PRIMARY KEY (id),\n    CONSTRAINT fk_object_locations_object_id FOREIGN KEY (object_id) REFERENCES objects (id),\n    CONSTRAINT fk_object_locations_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE object_materials (\n    id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    material_id INTEGER NOT NULL,\n    percentage DECIMAL(18,2),\n    CONSTRAINT pk_object_materials PRIMARY KEY (id),\n    CONSTRAINT fk_object_materials_object_id FOREIGN KEY (object_id) REFERENCES objects (id),\n    CONSTRAINT fk_object_materials_material_id FOREIGN KEY (material_id) REFERENCES materials (id)\n);\n\nCREATE TABLE object_persons (\n    id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role VARCHAR(255) NOT NULL,\n    attribution_certainty VARCHAR(255),\n    CONSTRAINT pk_object_persons PRIMARY KEY (id),\n    CONSTRAINT fk_object_persons_object_id FOREIGN KEY (object_id) REFERENCES objects (id),\n    CONSTRAINT fk_object_persons_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE provenance_entries (\n    id INTEGER NOT NULL,\n    object_id INTEGER NOT NULL,\n    sequence_number INTEGER NOT NULL,\n    collection_name VARCHAR(255),\n    previous_owner VARCHAR(255),\n    acquisition_type VARCHAR(255) NOT NULL,\n    acquisition_date DATE,\n    acquisition_notes TEXT,\n    CONSTRAINT pk_provenance_entries PRIMARY KEY (id),\n    CONSTRAINT fk_provenance_entries_object_id FOREIGN KEY (object_id) REFERENCES objects (id)\n);\n",
