    "final_ddl": "CREATE TABLE diagnoses (\n    id INTEGER NOT NULL,\n    icd_code VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_diagnoses PRIMARY KEY (id)\n);\n\nCREATE TABLE patients (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_patients PRIMARY KEY (id)\n);\n\nCREATE TABLE facilities (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    facility_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_facilities PRIMARY KEY (id)\n);\n\nCREATE TABLE encounters (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    facility_id INTEGER NOT NULL,\n    encounter_type VARCHAR(255) NOT NULL,\n    encounter_date DATE NOT NULL,\n    admission_date DATE,\n    discharge_date DATE,\n    notes TEXT,\n    CONSTRAINT pk_encounters PRIMARY KEY (id),\n    CONSTRAINT fk_encounters_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_encounters_facility_id FOREIGN KEY (facility_id) REFERENCES facilities (id)\n);\n\nCREATE TABLE service_catalogs (\n    id INTEGER NOT NULL,\n    catalog_code VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_service_catalogs PRIMARY KEY (id)\n);\n\nCREATE TABLE facility_service_catalogs (\n    id INTEGER NOT NULL,\n    facility_id INTEGER NOT NULL,\n    service_catalog_id INTEGER NOT NULL,\n    facility_specific_amount DECIMAL(18,2),\n    CONSTRAINT pk_facility_service_catalogs PRIMARY KEY (id),\n    CONSTRAINT fk_facility_service_catalogs_facility_id FOREIGN KEY (facility_id) REFERENCES facilities (id),\n    CONSTRAINT fk_facility_service_catalogs_service_catalog_id FOREIGN KEY (service_catalog_id) REFERENCES service_catalogs (id)\n);\n\nCREATE TABLE healthcare_professionals (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    license_number VARCHAR(255),\n    CONSTRAINT pk_healthcare_professionals PRIMARY KEY (id)\n);\n\nCREATE TABLE insurances (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    insurance_type VARCHAR(255),\n    CONSTRAINT pk_insurances PRIMARY KEY (id)\n);\n\nCREATE TABLE patient_diagnoses (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    diagnosis_id INTEGER NOT NULL,\n    documented_by_id INTEGER NOT NULL,\n    documented_date DATE NOT NULL,\n    is_permanent BOOLEAN NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_patient_diagnoses PRIMARY KEY (id),\n    CONSTRAINT fk_patient_diagnoses_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_patient_diagnoses_diagnosis_id FOREIGN KEY (diagnosis_id) REFERENCES diagnoses (id),\n    CONSTRAINT fk_patient_diagnoses_documented_by_id FOREIGN KEY (documented_by_id) REFERENCES healthcare_professionals (id)\n);\n\nCREATE TABLE patient_insurances (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    insurance_id INTEGER NOT NULL,\n    policy_number VARCHAR(255),\n    start_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_patient_insurances PRIMARY KEY (id),\n    CONSTRAINT fk_patient_insurances_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_patient_insurances_insurance_id FOREIGN KEY (insurance_id) REFERENCES insurances (id)\n);\n\nCREATE TABLE professional_facility_assignments (\n    id INTEGER NOT NULL,\n    professional_id INTEGER NOT NULL,\n    facility_id INTEGER NOT NULL,\n    assignment_type VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_professional_facility_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_professional_facility_assignments_professional_id FOREIGN KEY (professional_id) REFERENCES healthcare_professionals (id),\n    CONSTRAINT fk_professional_facility_assignments_facility_id FOREIGN KEY (facility_id) REFERENCES facilities (id)\n);\n\nCREATE TABLE specializations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_specializations PRIMARY KEY (id)\n);\n\nCREATE TABLE professional_specializations (\n    id INTEGER NOT NULL,\n    professional_id INTEGER NOT NULL,\n    specialization_id INTEGER NOT NULL,\n    CONSTRAINT pk_professional_specializations PRIMARY KEY (id),\n    CONSTRAINT fk_professional_specializations_professional_id FOREIGN KEY (professional_id) REFERENCES healthcare_professionals (id),\n    CONSTRAINT fk_professional_specializations_specialization_id FOREIGN KEY (specialization_id) REFERENCES specializations (id)\n);\n\nCREATE TABLE referrals (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    referring_facility_id INTEGER NOT NULL,\n    referred_facility_id INTEGER NOT NULL,\n    referred_by_id INTEGER NOT NULL,\n    referral_date DATE NOT NULL,\n    clinical_question TEXT,\n    status VARCHAR(255) NOT NULL,\n    completion_date DATE,\n    CONSTRAINT pk_referrals PRIMARY KEY (id),\n    CONSTRAINT fk_referrals_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_referrals_referring_facility_id FOREIGN KEY (referring_facility_id) REFERENCES facilities (id),\n    CONSTRAINT fk_referrals_referred_facility_id FOREIGN KEY (referred_facility_id) REFERENCES facilities (id),\n    CONSTRAINT fk_referrals_referred_by_id FOREIGN KEY (referred_by_id) REFERENCES healthcare_professionals (id)\n);\n\nCREATE TABLE services (\n    id INTEGER NOT NULL,\n    encounter_id INTEGER NOT NULL,\n    service_catalog_id INTEGER NOT NULL,\n    facility_id INTEGER NOT NULL,\n    performed_by_id INTEGER,\n    service_date DATE NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_services PRIMARY KEY (id),\n    CONSTRAINT fk_services_encounter_id FOREIGN KEY (encounter_id) REFERENCES encounters (id),\n    CONSTRAINT fk_services_service_catalog_id FOREIGN KEY (service_catalog_id) REFERENCES service_catalogs (id),\n    CONSTRAINT fk_services_facility_id FOREIGN KEY (facility_id) REFERENCES facilities (id),\n    CONSTRAINT fk_services_performed_by_id FOREIGN KEY (performed_by_id) REFERENCES healthcare_professionals (id)\n);\n\nCREATE TABLE service_diagnoses (\n    id INTEGER NOT NULL,\n    service_id INTEGER NOT NULL,\n    diagnosis_id INTEGER NOT NULL,\n    CONSTRAINT pk_service_diagnoses PRIMARY KEY (id),\n    CONSTRAINT fk_service_diagnoses_service_id FOREIGN KEY (service_id) REFERENCES services (id),\n    CONSTRAINT fk_service_diagnoses_diagnosis_id FOREIGN KEY (diagnosis_id) REFERENCES diagnoses (id)\n);\n",
