    "final_ddl": "CREATE TABLE hazmat_classes (\n    id INTEGER NOT NULL,\n    class_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_hazmat_classes PRIMARY KEY (id)\n);\n\nCREATE TABLE location_functions (\n    id INTEGER NOT NULL,\n    function_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_location_functions PRIMARY KEY (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    street VARCHAR(255),\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    contact_email VARCHAR(255),\n    contact_phone VARCHAR(255),\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE location_location_functions (\n    location_id INTEGER NOT NULL,\n    location_function_id INTEGER NOT NULL,\n    CONSTRAINT pk_location_location_functions PRIMARY KEY (location_id, location_function_id),\n    CONSTRAINT fk_location_location_functions_location_id FOREIGN KEY (location_id) REFERENCES locations (id),\n    CONSTRAINT fk_location_location_functions_location_function_id FOREIGN KEY (location_function_id) REFERENCES location_functions (id)\n);\n\nCREATE TABLE partners (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    partner_type VARCHAR(255) NOT NULL,\n    street VARCHAR(255),\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    contact_email VARCHAR(255),\n    contact_phone VARCHAR(255),\n    CONSTRAINT pk_partners PRIMARY KEY (id)\n);\n\nCREATE TABLE shipments (\n    id INTEGER NOT NULL,\n    shipment_number VARCHAR(255) NOT NULL,\n    origin_location_id INTEGER NOT NULL,\n    destination_location_id INTEGER NOT NULL,\n    customer_id INTEGER,\n    recipient_id INTEGER,\n    expected_arrival_date DATE,\n    actual_arrival_date DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_shipments PRIMARY KEY (id),\n    CONSTRAINT fk_shipments_origin_location_id FOREIGN KEY (origin_location_id) REFERENCES locations (id),\n    CONSTRAINT fk_shipments_destination_location_id FOREIGN KEY (destination_location_id) REFERENCES locations (id),\n    CONSTRAINT fk_shipments_customer_id FOREIGN KEY (customer_id) REFERENCES partners (id),\n    CONSTRAINT fk_shipments_recipient_id FOREIGN KEY (recipient_id) REFERENCES partners (id)\n);\n\nCREATE TABLE packages (\n    id INTEGER NOT NULL,\n    shipment_id INTEGER NOT NULL,\n    package_number VARCHAR(255) NOT NULL,\n    weight_kg DECIMAL(18,2),\n    volume_cbm DECIMAL(18,2),\n    description TEXT,\n    CONSTRAINT pk_packages PRIMARY KEY (id),\n    CONSTRAINT fk_packages_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id)\n);\n\nCREATE TABLE package_hazmat (\n    id INTEGER NOT NULL,\n    package_id INTEGER NOT NULL,\n    un_number VARCHAR(255) NOT NULL,\n    hazmat_class_id INTEGER NOT NULL,\n    CONSTRAINT pk_package_hazmat PRIMARY KEY (id),\n    CONSTRAINT fk_package_hazmat_package_id FOREIGN KEY (package_id) REFERENCES packages (id),\n    CONSTRAINT fk_package_hazmat_hazmat_class_id FOREIGN KEY (hazmat_class_id) REFERENCES hazmat_classes (id)\n);\n\nCREATE TABLE services (\n    id INTEGER NOT NULL,\n    service_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_services PRIMARY KEY (id)\n);\n\nCREATE TABLE shipment_services (\n    shipment_id INTEGER NOT NULL,\n    service_id INTEGER NOT NULL,\n    CONSTRAINT pk_shipment_services PRIMARY KEY (shipment_id, service_id),\n    CONSTRAINT fk_shipment_services_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id),\n    CONSTRAINT fk_shipment_services_service_id FOREIGN KEY (service_id) REFERENCES services (id)\n);\n\nCREATE TABLE transport_modes (\n    id INTEGER NOT NULL,\n    mode_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_transport_modes PRIMARY KEY (id)\n);\n\nCREATE TABLE transports (\n    id INTEGER NOT NULL,\n    transport_number VARCHAR(255) NOT NULL,\n    partner_id INTEGER NOT NULL,\n    transport_mode_id INTEGER,\n    origin_location_id INTEGER NOT NULL,\n    destination_location_id INTEGER NOT NULL,\n    scheduled_departure DATE,\n    actual_departure DATE,\n    scheduled_arrival DATE,\n    actual_arrival DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_transports PRIMARY KEY (id),\n    CONSTRAINT fk_transports_partner_id FOREIGN KEY (partner_id) REFERENCES partners (id),\n    CONSTRAINT fk_transports_transport_mode_id FOREIGN KEY (transport_mode_id) REFERENCES transport_modes (id),\n    CONSTRAINT fk_transports_origin_location_id FOREIGN KEY (origin_location_id) REFERENCES locations (id),\n    CONSTRAINT fk_transports_destination_location_id FOREIGN KEY (destination_location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE shipment_transports (\n    shipment_id INTEGER NOT NULL,\n    transport_id INTEGER NOT NULL,\n    sequence_number INTEGER NOT NULL,\n    CONSTRAINT pk_shipment_transports PRIMARY KEY (shipment_id, transport_id),\n    CONSTRAINT fk_shipment_transports_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id),\n    CONSTRAINT fk_shipment_transports_transport_id FOREIGN KEY (transport_id) REFERENCES transports (id)\n);\n\nCREATE TABLE status_types (\n    id INTEGER NOT NULL,\n    status_name VARCHAR(255) NOT NULL,\n    description TEXT,\n    applies_to VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_status_types PRIMARY KEY (id)\n);\n\nCREATE TABLE status_messages (\n    id INTEGER NOT NULL,\n    status_type_id INTEGER NOT NULL,\n    shipment_id INTEGER,\n    transport_id INTEGER,\n    location_id INTEGER,\n    message_timestamp TIMESTAMP NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_status_messages PRIMARY KEY (id),\n    CONSTRAINT fk_status_messages_status_type_id FOREIGN KEY (status_type_id) REFERENCES status_types (id),\n    CONSTRAINT fk_status_messages_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id),\n    CONSTRAINT fk_status_messages_transport_id FOREIGN KEY (transport_id) REFERENCES transports (id),\n    CONSTRAINT fk_status_messages_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE temperature_requirements (\n    id INTEGER NOT NULL,\n    shipment_id INTEGER NOT NULL,\n    min_temperature_celsius DECIMAL(18,2) NOT NULL,\n    max_temperature_celsius DECIMAL(18,2) NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_temperature_requirements PRIMARY KEY (id),\n    CONSTRAINT fk_temperature_requirements_shipment_id FOREIGN KEY (shipment_id) REFERENCES shipments (id)\n);\n",
