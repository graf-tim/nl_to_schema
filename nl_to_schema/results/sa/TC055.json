    "final_ddl": "CREATE TABLE areas (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_areas PRIMARY KEY (id)\n);\n\nCREATE TABLE fairs (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_fairs PRIMARY KEY (id)\n);\n\nCREATE TABLE booths (\n    id INTEGER NOT NULL,\n    fair_id INTEGER NOT NULL,\n    area_id INTEGER NOT NULL,\n    hall VARCHAR(255) NOT NULL,\n    booth_number VARCHAR(255),\n    CONSTRAINT pk_booths PRIMARY KEY (id),\n    CONSTRAINT fk_booths_fair_id FOREIGN KEY (fair_id) REFERENCES fairs (id),\n    CONSTRAINT fk_booths_area_id FOREIGN KEY (area_id) REFERENCES areas (id)\n);\n\nCREATE TABLE exhibitors (\n    id INTEGER NOT NULL,\n    company_name VARCHAR(255) NOT NULL,\n    contact_person VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    CONSTRAINT pk_exhibitors PRIMARY KEY (id)\n);\n\nCREATE TABLE booth_exhibitors (\n    booth_id INTEGER NOT NULL,\n    exhibitor_id INTEGER NOT NULL,\n    CONSTRAINT pk_booth_exhibitors PRIMARY KEY (booth_id, exhibitor_id),\n    CONSTRAINT fk_booth_exhibitors_booth_id FOREIGN KEY (booth_id) REFERENCES booths (id),\n    CONSTRAINT fk_booth_exhibitors_exhibitor_id FOREIGN KEY (exhibitor_id) REFERENCES exhibitors (id)\n);\n\nCREATE TABLE fair_exhibitors (\n    fair_id INTEGER NOT NULL,\n    exhibitor_id INTEGER NOT NULL,\n    registration_date DATE,\n    CONSTRAINT pk_fair_exhibitors PRIMARY KEY (fair_id, exhibitor_id),\n    CONSTRAINT fk_fair_exhibitors_fair_id FOREIGN KEY (fair_id) REFERENCES fairs (id),\n    CONSTRAINT fk_fair_exhibitors_exhibitor_id FOREIGN KEY (exhibitor_id) REFERENCES exhibitors (id)\n);\n\nCREATE TABLE program_items (\n    id INTEGER NOT NULL,\n    fair_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    event_date DATE NOT NULL,\n    start_time VARCHAR(255),\n    end_time VARCHAR(255),\n    CONSTRAINT pk_program_items PRIMARY KEY (id),\n    CONSTRAINT fk_program_items_fair_id FOREIGN KEY (fair_id) REFERENCES fairs (id)\n);\n\nCREATE TABLE program_exhibitors (\n    program_item_id INTEGER NOT NULL,\n    exhibitor_id INTEGER NOT NULL,\n    CONSTRAINT pk_program_exhibitors PRIMARY KEY (program_item_id, exhibitor_id),\n    CONSTRAINT fk_program_exhibitors_program_item_id FOREIGN KEY (program_item_id) REFERENCES program_items (id),\n    CONSTRAINT fk_program_exhibitors_exhibitor_id FOREIGN KEY (exhibitor_id) REFERENCES exhibitors (id)\n);\n",
