    "final_ddl": "CREATE TABLE patients (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address TEXT,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_patients PRIMARY KEY (id)\n);\n\nCREATE TABLE allergies (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    allergen VARCHAR(255) NOT NULL,\n    reaction TEXT,\n    severity VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_allergies PRIMARY KEY (id),\n    CONSTRAINT fk_allergies_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id)\n);\n\nCREATE TABLE visits (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    visit_date DATE NOT NULL,\n    visit_time VARCHAR(255),\n    reason TEXT,\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_visits PRIMARY KEY (id),\n    CONSTRAINT fk_visits_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id)\n);\n\nCREATE TABLE diagnoses (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    visit_id INTEGER,\n    icd_code VARCHAR(255) NOT NULL,\n    description TEXT,\n    diagnosis_type VARCHAR(255),\n    diagnosis_date DATE,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_diagnoses PRIMARY KEY (id),\n    CONSTRAINT fk_diagnoses_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_diagnoses_visit_id FOREIGN KEY (visit_id) REFERENCES visits (id)\n);\n\nCREATE TABLE documents (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    visit_id INTEGER,\n    document_type VARCHAR(255) NOT NULL,\n    filename VARCHAR(255) NOT NULL,\n    file_path TEXT NOT NULL,\n    description TEXT,\n    uploaded_by VARCHAR(255) NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_documents PRIMARY KEY (id),\n    CONSTRAINT fk_documents_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_documents_visit_id FOREIGN KEY (visit_id) REFERENCES visits (id)\n);\n\nCREATE TABLE emergency_contacts (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    relationship VARCHAR(255),\n    phone VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_emergency_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_emergency_contacts_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id)\n);\n\nCREATE TABLE insurances (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    insurance_type VARCHAR(255) NOT NULL,\n    insurance_number VARCHAR(255),\n    insurance_company VARCHAR(255),\n    valid_from DATE,\n    valid_until DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_insurances PRIMARY KEY (id),\n    CONSTRAINT fk_insurances_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id)\n);\n\nCREATE TABLE physicians (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    specialty VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_physicians PRIMARY KEY (id)\n);\n\nCREATE TABLE lab_requests (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    visit_id INTEGER,\n    physician_id INTEGER NOT NULL,\n    request_date DATE NOT NULL,\n    test_type VARCHAR(255) NOT NULL,\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_lab_requests PRIMARY KEY (id),\n    CONSTRAINT fk_lab_requests_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_lab_requests_visit_id FOREIGN KEY (visit_id) REFERENCES visits (id),\n    CONSTRAINT fk_lab_requests_physician_id FOREIGN KEY (physician_id) REFERENCES physicians (id)\n);\n\nCREATE TABLE lab_results (\n    id INTEGER NOT NULL,\n    lab_request_id INTEGER NOT NULL,\n    test_name VARCHAR(255) NOT NULL,\n    result_value VARCHAR(255),\n    unit VARCHAR(255),\n    reference_range VARCHAR(255),\n    assessment VARCHAR(255),\n    result_date DATE,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_lab_results PRIMARY KEY (id),\n    CONSTRAINT fk_lab_results_lab_request_id FOREIGN KEY (lab_request_id) REFERENCES lab_requests (id)\n);\n\nCREATE TABLE medications (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    visit_id INTEGER,\n    medication_name VARCHAR(255) NOT NULL,\n    dosage VARCHAR(255),\n    instructions TEXT,\n    start_date DATE,\n    end_date DATE,\n    is_active BOOLEAN NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_medications PRIMARY KEY (id),\n    CONSTRAINT fk_medications_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_medications_visit_id FOREIGN KEY (visit_id) REFERENCES visits (id)\n);\n\nCREATE TABLE visit_physicians (\n    visit_id INTEGER NOT NULL,\n    physician_id INTEGER NOT NULL,\n    CONSTRAINT pk_visit_physicians PRIMARY KEY (visit_id, physician_id),\n    CONSTRAINT fk_visit_physicians_visit_id FOREIGN KEY (visit_id) REFERENCES visits (id),\n    CONSTRAINT fk_visit_physicians_physician_id FOREIGN KEY (physician_id) REFERENCES physicians (id)\n);\n",
