    "final_ddl": "CREATE TABLE substances (\n    id INTEGER NOT NULL,\n    internal_designation VARCHAR(255) NOT NULL,\n    substance_type VARCHAR(255) NOT NULL,\n    form VARCHAR(255),\n    CONSTRAINT pk_substances PRIMARY KEY (id)\n);\n\nCREATE TABLE assays (\n    id INTEGER NOT NULL,\n    substance_id INTEGER NOT NULL,\n    assay_type VARCHAR(255) NOT NULL,\n    method VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_assays PRIMARY KEY (id),\n    CONSTRAINT fk_assays_substance_id FOREIGN KEY (substance_id) REFERENCES substances (id)\n);\n\nCREATE TABLE laboratories (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    is_external BOOLEAN NOT NULL,\n    address TEXT,\n    contact_person VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_laboratories PRIMARY KEY (id)\n);\n\nCREATE TABLE assay_runs (\n    id INTEGER NOT NULL,\n    assay_id INTEGER NOT NULL,\n    laboratory_id INTEGER NOT NULL,\n    rundate DATE NOT NULL,\n    concentration VARCHAR(255),\n    cellline VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_assay_runs PRIMARY KEY (id),\n    CONSTRAINT fk_assay_runs_assay_id FOREIGN KEY (assay_id) REFERENCES assays (id),\n    CONSTRAINT fk_assay_runs_laboratory_id FOREIGN KEY (laboratory_id) REFERENCES laboratories (id)\n);\n\nCREATE TABLE adverse_observations (\n    id INTEGER NOT NULL,\n    substance_id INTEGER NOT NULL,\n    assay_run_id INTEGER,\n    observation_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    observation_date DATE,\n    CONSTRAINT pk_adverse_observations PRIMARY KEY (id),\n    CONSTRAINT fk_adverse_observations_substance_id FOREIGN KEY (substance_id) REFERENCES substances (id),\n    CONSTRAINT fk_adverse_observations_assay_run_id FOREIGN KEY (assay_run_id) REFERENCES assay_runs (id)\n);\n\nCREATE TABLE assay_results (\n    id INTEGER NOT NULL,\n    assay_run_id INTEGER,\n    assay_id INTEGER,\n    result_type VARCHAR(255) NOT NULL,\n    value DECIMAL(18,2),\n    unit VARCHAR(255),\n    measurement_date DATE,\n    CONSTRAINT pk_assay_results PRIMARY KEY (id),\n    CONSTRAINT fk_assay_results_assay_run_id FOREIGN KEY (assay_run_id) REFERENCES assay_runs (id),\n    CONSTRAINT fk_assay_results_assay_id FOREIGN KEY (assay_id) REFERENCES assays (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    discipline VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE projects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    startdate DATE,\n    enddate DATE,\n    CONSTRAINT pk_projects PRIMARY KEY (id)\n);\n\nCREATE TABLE project_approvals (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    approved_by VARCHAR(255) NOT NULL,\n    approval_date DATE NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_project_approvals PRIMARY KEY (id),\n    CONSTRAINT fk_project_approvals_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE project_reports (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    author_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    content TEXT,\n    creation_date DATE NOT NULL,\n    CONSTRAINT pk_project_reports PRIMARY KEY (id),\n    CONSTRAINT fk_project_reports_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_reports_author_id FOREIGN KEY (author_id) REFERENCES persons (id)\n);\n\nCREATE TABLE project_substances (\n    project_id INTEGER NOT NULL,\n    substance_id INTEGER NOT NULL,\n    CONSTRAINT pk_project_substances PRIMARY KEY (project_id, substance_id),\n    CONSTRAINT fk_project_substances_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_substances_substance_id FOREIGN KEY (substance_id) REFERENCES substances (id)\n);\n\nCREATE TABLE targets (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_targets PRIMARY KEY (id)\n);\n\nCREATE TABLE project_targets (\n    project_id INTEGER NOT NULL,\n    target_id INTEGER NOT NULL,\n    CONSTRAINT pk_project_targets PRIMARY KEY (project_id, target_id),\n    CONSTRAINT fk_project_targets_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_targets_target_id FOREIGN KEY (target_id) REFERENCES targets (id)\n);\n\nCREATE TABLE project_team_members (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    startdate DATE,\n    enddate DATE,\n    CONSTRAINT pk_project_team_members PRIMARY KEY (id),\n    CONSTRAINT fk_project_team_members_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_team_members_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE substance_targets (\n    substance_id INTEGER NOT NULL,\n    target_id INTEGER NOT NULL,\n    CONSTRAINT pk_substance_targets PRIMARY KEY (substance_id, target_id),\n    CONSTRAINT fk_substance_targets_substance_id FOREIGN KEY (substance_id) REFERENCES substances (id),\n    CONSTRAINT fk_substance_targets_target_id FOREIGN KEY (target_id) REFERENCES targets (id)\n);\n",
