    "final_ddl": "CREATE TABLE companies (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    industry VARCHAR(255),\n    billing_address TEXT,\n    CONSTRAINT pk_companies PRIMARY KEY (id)\n);\n\nCREATE TABLE contacts (\n    id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_contacts_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE venues (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    address TEXT NOT NULL,\n    max_capacity INTEGER NOT NULL,\n    CONSTRAINT pk_venues PRIMARY KEY (id)\n);\n\nCREATE TABLE events (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    event_datetime TIMESTAMP NOT NULL,\n    planning_status VARCHAR(255) NOT NULL,\n    expected_costs DECIMAL(18,2),\n    venue_id INTEGER NOT NULL,\n    contact_id INTEGER NOT NULL,\n    is_cancelled BOOLEAN NOT NULL,\n    CONSTRAINT pk_events PRIMARY KEY (id),\n    CONSTRAINT fk_events_venue_id FOREIGN KEY (venue_id) REFERENCES venues (id),\n    CONSTRAINT fk_events_contact_id FOREIGN KEY (contact_id) REFERENCES contacts (id)\n);\n\nCREATE TABLE service_providers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    service_type VARCHAR(255) NOT NULL,\n    contact_person VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_service_providers PRIMARY KEY (id)\n);\n\nCREATE TABLE event_service_providers (\n    event_id INTEGER NOT NULL,\n    service_provider_id INTEGER NOT NULL,\n    task_description TEXT,\n    CONSTRAINT pk_event_service_providers PRIMARY KEY (event_id, service_provider_id),\n    CONSTRAINT fk_event_service_providers_event_id FOREIGN KEY (event_id) REFERENCES events (id),\n    CONSTRAINT fk_event_service_providers_service_provider_id FOREIGN KEY (service_provider_id) REFERENCES service_providers (id)\n);\n\nCREATE TABLE service_provider_event_types (\n    service_provider_id INTEGER NOT NULL,\n    event_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_service_provider_event_types PRIMARY KEY (service_provider_id, event_type),\n    CONSTRAINT fk_service_provider_event_types_service_provider_id FOREIGN KEY (service_provider_id) REFERENCES service_providers (id)\n);\n",
