    "final_ddl": "CREATE TABLE advisors (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_advisors PRIMARY KEY (id)\n);\n\nCREATE TABLE banks (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    bic VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_banks PRIMARY KEY (id)\n);\n\nCREATE TABLE customers (\n    id INTEGER NOT NULL,\n    customer_type VARCHAR(255) NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE customer_persons (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    CONSTRAINT pk_customer_persons PRIMARY KEY (id),\n    CONSTRAINT fk_customer_persons_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_customer_persons_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE depots (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    bank_id INTEGER NOT NULL,\n    depot_number VARCHAR(255) NOT NULL,\n    base_currency VARCHAR(255) NOT NULL,\n    opened_at DATE,\n    closed_at DATE,\n    CONSTRAINT pk_depots PRIMARY KEY (id),\n    CONSTRAINT fk_depots_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id),\n    CONSTRAINT fk_depots_bank_id FOREIGN KEY (bank_id) REFERENCES banks (id)\n);\n\nCREATE TABLE instruments (\n    id INTEGER NOT NULL,\n    isin VARCHAR(255) NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    instrument_type VARCHAR(255) NOT NULL,\n    issuer_id INTEGER,\n    description TEXT,\n    CONSTRAINT pk_instruments PRIMARY KEY (id),\n    CONSTRAINT fk_instruments_issuer_id FOREIGN KEY (issuer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE depot_holdings (\n    id INTEGER NOT NULL,\n    depot_id INTEGER NOT NULL,\n    instrument_id INTEGER NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    holding_from DATE NOT NULL,\n    holding_until DATE,\n    CONSTRAINT pk_depot_holdings PRIMARY KEY (id),\n    CONSTRAINT fk_depot_holdings_depot_id FOREIGN KEY (depot_id) REFERENCES depots (id),\n    CONSTRAINT fk_depot_holdings_instrument_id FOREIGN KEY (instrument_id) REFERENCES instruments (id)\n);\n\nCREATE TABLE trading_venues (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    country VARCHAR(255),\n    mic_code VARCHAR(255),\n    CONSTRAINT pk_trading_venues PRIMARY KEY (id)\n);\n\nCREATE TABLE instrument_listings (\n    id INTEGER NOT NULL,\n    instrument_id INTEGER NOT NULL,\n    trading_venue_id INTEGER NOT NULL,\n    ticker_symbol VARCHAR(255),\n    trading_currency VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_instrument_listings PRIMARY KEY (id),\n    CONSTRAINT fk_instrument_listings_instrument_id FOREIGN KEY (instrument_id) REFERENCES instruments (id),\n    CONSTRAINT fk_instrument_listings_trading_venue_id FOREIGN KEY (trading_venue_id) REFERENCES trading_venues (id)\n);\n\nCREATE TABLE price_quotes (\n    id INTEGER NOT NULL,\n    instrument_id INTEGER NOT NULL,\n    trading_venue_id INTEGER NOT NULL,\n    quote_date DATE NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    currency VARCHAR(255) NOT NULL,\n    quote_time TIMESTAMP,\n    CONSTRAINT pk_price_quotes PRIMARY KEY (id),\n    CONSTRAINT fk_price_quotes_instrument_id FOREIGN KEY (instrument_id) REFERENCES instruments (id),\n    CONSTRAINT fk_price_quotes_trading_venue_id FOREIGN KEY (trading_venue_id) REFERENCES trading_venues (id)\n);\n\nCREATE TABLE transactions (\n    id INTEGER NOT NULL,\n    depot_id INTEGER NOT NULL,\n    instrument_id INTEGER NOT NULL,\n    trading_venue_id INTEGER NOT NULL,\n    transaction_type VARCHAR(255) NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    trading_currency VARCHAR(255) NOT NULL,\n    trading_date DATE NOT NULL,\n    settlement_date DATE NOT NULL,\n    advisor_id INTEGER,\n    order_reference VARCHAR(255),\n    notes TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_transactions PRIMARY KEY (id),\n    CONSTRAINT fk_transactions_depot_id FOREIGN KEY (depot_id) REFERENCES depots (id),\n    CONSTRAINT fk_transactions_instrument_id FOREIGN KEY (instrument_id) REFERENCES instruments (id),\n    CONSTRAINT fk_transactions_trading_venue_id FOREIGN KEY (trading_venue_id) REFERENCES trading_venues (id),\n    CONSTRAINT fk_transactions_advisor_id FOREIGN KEY (advisor_id) REFERENCES advisors (id)\n);\n\nCREATE TABLE transaction_fees (\n    id INTEGER NOT NULL,\n    transaction_id INTEGER NOT NULL,\n    fee_type VARCHAR(255) NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    currency VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_transaction_fees PRIMARY KEY (id),\n    CONSTRAINT fk_transaction_fees_transaction_id FOREIGN KEY (transaction_id) REFERENCES transactions (id)\n);\n",
