    "final_ddl": "CREATE TABLE access_conditions (\n    id INTEGER NOT NULL,\n    condition_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_access_conditions PRIMARY KEY (id)\n);\n\nCREATE TABLE datasets (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    creation_date DATE,\n    CONSTRAINT pk_datasets PRIMARY KEY (id)\n);\n\nCREATE TABLE dataset_versions (\n    id INTEGER NOT NULL,\n    dataset_id INTEGER NOT NULL,\n    version_number VARCHAR(255) NOT NULL,\n    version_type VARCHAR(255),\n    file_path VARCHAR(255),\n    doi VARCHAR(255),\n    format VARCHAR(255),\n    size_bytes INTEGER,\n    publication_status VARCHAR(255),\n    creation_date TIMESTAMP,\n    CONSTRAINT pk_dataset_versions PRIMARY KEY (id),\n    CONSTRAINT fk_dataset_versions_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id)\n);\n\nCREATE TABLE dataset_access_conditions (\n    id INTEGER NOT NULL,\n    dataset_id INTEGER,\n    dataset_version_id INTEGER,\n    access_condition_id INTEGER NOT NULL,\n    CONSTRAINT pk_dataset_access_conditions PRIMARY KEY (id),\n    CONSTRAINT fk_dataset_access_conditions_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id),\n    CONSTRAINT fk_dataset_access_conditions_dataset_version_id FOREIGN KEY (dataset_version_id) REFERENCES dataset_versions (id),\n    CONSTRAINT fk_dataset_access_conditions_access_condition_id FOREIGN KEY (access_condition_id) REFERENCES access_conditions (id)\n);\n\nCREATE TABLE methods (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_methods PRIMARY KEY (id)\n);\n\nCREATE TABLE dataset_methods (\n    id INTEGER NOT NULL,\n    dataset_id INTEGER NOT NULL,\n    method_id INTEGER NOT NULL,\n    CONSTRAINT pk_dataset_methods PRIMARY KEY (id),\n    CONSTRAINT fk_dataset_methods_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id),\n    CONSTRAINT fk_dataset_methods_method_id FOREIGN KEY (method_id) REFERENCES methods (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE dataset_persons (\n    id INTEGER NOT NULL,\n    dataset_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    CONSTRAINT pk_dataset_persons PRIMARY KEY (id),\n    CONSTRAINT fk_dataset_persons_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id),\n    CONSTRAINT fk_dataset_persons_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE projects (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    start_date DATE,\n    is_active BOOLEAN NOT NULL,\n    responsible_person_id INTEGER NOT NULL,\n    CONSTRAINT pk_projects PRIMARY KEY (id),\n    CONSTRAINT fk_projects_responsible_person_id FOREIGN KEY (responsible_person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE dataset_projects (\n    id INTEGER NOT NULL,\n    dataset_id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    CONSTRAINT pk_dataset_projects PRIMARY KEY (id),\n    CONSTRAINT fk_dataset_projects_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id),\n    CONSTRAINT fk_dataset_projects_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE funding_sources (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_funding_sources PRIMARY KEY (id)\n);\n\nCREATE TABLE project_funding (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    funding_source_id INTEGER NOT NULL,\n    funding_code VARCHAR(255),\n    approval_start_date DATE,\n    approval_end_date DATE,\n    CONSTRAINT pk_project_funding PRIMARY KEY (id),\n    CONSTRAINT fk_project_funding_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_funding_funding_source_id FOREIGN KEY (funding_source_id) REFERENCES funding_sources (id)\n);\n\nCREATE TABLE project_persons (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    CONSTRAINT pk_project_persons PRIMARY KEY (id),\n    CONSTRAINT fk_project_persons_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_persons_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n",
