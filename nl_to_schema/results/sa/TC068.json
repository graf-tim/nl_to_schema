    "final_ddl": "CREATE TABLE modules (\n    id INTEGER NOT NULL,\n    code VARCHAR(255) NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    credit_points INTEGER,\n    workload_hours INTEGER,\n    CONSTRAINT pk_modules PRIMARY KEY (id)\n);\n\nCREATE TABLE semesters (\n    id INTEGER NOT NULL,\n    year INTEGER NOT NULL,\n    season VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    CONSTRAINT pk_semesters PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    person_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE faculties (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_faculties PRIMARY KEY (id)\n);\n\nCREATE TABLE institutes (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    faculty_id INTEGER NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_institutes PRIMARY KEY (id),\n    CONSTRAINT fk_institutes_faculty_id FOREIGN KEY (faculty_id) REFERENCES faculties (id)\n);\n\nCREATE TABLE teaching_staff (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    institute_id INTEGER NOT NULL,\n    staff_type VARCHAR(255) NOT NULL,\n    title VARCHAR(255),\n    CONSTRAINT pk_teaching_staff PRIMARY KEY (id),\n    CONSTRAINT fk_teaching_staff_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_teaching_staff_institute_id FOREIGN KEY (institute_id) REFERENCES institutes (id)\n);\n\nCREATE TABLE course_offerings (\n    id INTEGER NOT NULL,\n    module_id INTEGER NOT NULL,\n    semester_id INTEGER NOT NULL,\n    responsible_staff_id INTEGER NOT NULL,\n    instructor_staff_id INTEGER NOT NULL,\n    max_participants INTEGER,\n    description TEXT,\n    CONSTRAINT pk_course_offerings PRIMARY KEY (id),\n    CONSTRAINT fk_course_offerings_module_id FOREIGN KEY (module_id) REFERENCES modules (id),\n    CONSTRAINT fk_course_offerings_semester_id FOREIGN KEY (semester_id) REFERENCES semesters (id),\n    CONSTRAINT fk_course_offerings_responsible_staff_id FOREIGN KEY (responsible_staff_id) REFERENCES teaching_staff (id),\n    CONSTRAINT fk_course_offerings_instructor_staff_id FOREIGN KEY (instructor_staff_id) REFERENCES teaching_staff (id)\n);\n\nCREATE TABLE students (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    student_number VARCHAR(255) NOT NULL,\n    enrollment_date DATE NOT NULL,\n    CONSTRAINT pk_students PRIMARY KEY (id),\n    CONSTRAINT fk_students_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE course_registrations (\n    id INTEGER NOT NULL,\n    student_id INTEGER NOT NULL,\n    course_offering_id INTEGER NOT NULL,\n    registration_date TIMESTAMP NOT NULL,\n    registration_status VARCHAR(255) NOT NULL,\n    waitlist_position INTEGER,\n    CONSTRAINT pk_course_registrations PRIMARY KEY (id),\n    CONSTRAINT fk_course_registrations_student_id FOREIGN KEY (student_id) REFERENCES students (id),\n    CONSTRAINT fk_course_registrations_course_offering_id FOREIGN KEY (course_offering_id) REFERENCES course_offerings (id)\n);\n\nCREATE TABLE course_sessions (\n    id INTEGER NOT NULL,\n    course_offering_id INTEGER NOT NULL,\n    session_date DATE NOT NULL,\n    start_time VARCHAR(255),\n    end_time VARCHAR(255),\n    room VARCHAR(255),\n    CONSTRAINT pk_course_sessions PRIMARY KEY (id),\n    CONSTRAINT fk_course_sessions_course_offering_id FOREIGN KEY (course_offering_id) REFERENCES course_offerings (id)\n);\n\nCREATE TABLE degree_programs (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    faculty_id INTEGER NOT NULL,\n    degree_type VARCHAR(255),\n    standard_duration_semesters INTEGER,\n    description TEXT,\n    CONSTRAINT pk_degree_programs PRIMARY KEY (id),\n    CONSTRAINT fk_degree_programs_faculty_id FOREIGN KEY (faculty_id) REFERENCES faculties (id)\n);\n\nCREATE TABLE degree_program_modules (\n    id INTEGER NOT NULL,\n    degree_program_id INTEGER NOT NULL,\n    module_id INTEGER NOT NULL,\n    semester INTEGER,\n    is_mandatory BOOLEAN NOT NULL,\n    exam_regulation_version VARCHAR(255),\n    CONSTRAINT pk_degree_program_modules PRIMARY KEY (id),\n    CONSTRAINT fk_degree_program_modules_degree_program_id FOREIGN KEY (degree_program_id) REFERENCES degree_programs (id),\n    CONSTRAINT fk_degree_program_modules_module_id FOREIGN KEY (module_id) REFERENCES modules (id)\n);\n\nCREATE TABLE exam_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_exam_types PRIMARY KEY (id)\n);\n\nCREATE TABLE exams (\n    id INTEGER NOT NULL,\n    module_id INTEGER,\n    course_offering_id INTEGER,\n    exam_type_id INTEGER NOT NULL,\n    exam_date DATE NOT NULL,\n    start_time VARCHAR(255),\n    end_time VARCHAR(255),\n    room VARCHAR(255),\n    examiner_staff_id INTEGER NOT NULL,\n    CONSTRAINT pk_exams PRIMARY KEY (id),\n    CONSTRAINT fk_exams_module_id FOREIGN KEY (module_id) REFERENCES modules (id),\n    CONSTRAINT fk_exams_course_offering_id FOREIGN KEY (course_offering_id) REFERENCES course_offerings (id),\n    CONSTRAINT fk_exams_exam_type_id FOREIGN KEY (exam_type_id) REFERENCES exam_types (id),\n    CONSTRAINT fk_exams_examiner_staff_id FOREIGN KEY (examiner_staff_id) REFERENCES teaching_staff (id)\n);\n\nCREATE TABLE exam_results (\n    id INTEGER NOT NULL,\n    student_id INTEGER NOT NULL,\n    exam_id INTEGER NOT NULL,\n    attempt_number INTEGER NOT NULL,\n    grade VARCHAR(255),\n    points DECIMAL(18,2),\n    passed BOOLEAN NOT NULL,\n    exam_date DATE NOT NULL,\n    semester_id INTEGER NOT NULL,\n    CONSTRAINT pk_exam_results PRIMARY KEY (id),\n    CONSTRAINT fk_exam_results_student_id FOREIGN KEY (student_id) REFERENCES students (id),\n    CONSTRAINT fk_exam_results_exam_id FOREIGN KEY (exam_id) REFERENCES exams (id),\n    CONSTRAINT fk_exam_results_semester_id FOREIGN KEY (semester_id) REFERENCES semesters (id)\n);\n\nCREATE TABLE module_prerequisites (\n    id INTEGER NOT NULL,\n    module_id INTEGER NOT NULL,\n    prerequisite_module_id INTEGER NOT NULL,\n    is_mandatory BOOLEAN NOT NULL,\n    CONSTRAINT pk_module_prerequisites PRIMARY KEY (id),\n    CONSTRAINT fk_module_prerequisites_module_id FOREIGN KEY (module_id) REFERENCES modules (id),\n    CONSTRAINT fk_module_prerequisites_prerequisite_module_id FOREIGN KEY (prerequisite_module_id) REFERENCES modules (id)\n);\n\nCREATE TABLE student_enrollments (\n    id INTEGER NOT NULL,\n    student_id INTEGER NOT NULL,\n    degree_program_id INTEGER NOT NULL,\n    current_semester INTEGER NOT NULL,\n    enrollment_type VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_student_enrollments PRIMARY KEY (id),\n    CONSTRAINT fk_student_enrollments_student_id FOREIGN KEY (student_id) REFERENCES students (id),\n    CONSTRAINT fk_student_enrollments_degree_program_id FOREIGN KEY (degree_program_id) REFERENCES degree_programs (id)\n);\n",
