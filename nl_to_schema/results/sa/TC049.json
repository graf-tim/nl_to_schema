    "final_ddl": "CREATE TABLE account_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_account_types PRIMARY KEY (id)\n);\n\nCREATE TABLE branches (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_branches PRIMARY KEY (id)\n);\n\nCREATE TABLE accounts (\n    id INTEGER NOT NULL,\n    account_number VARCHAR(255) NOT NULL,\n    account_type_id INTEGER NOT NULL,\n    branch_id INTEGER NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    opening_date DATE NOT NULL,\n    closing_date DATE,\n    CONSTRAINT pk_accounts PRIMARY KEY (id),\n    CONSTRAINT fk_accounts_account_type_id FOREIGN KEY (account_type_id) REFERENCES account_types (id),\n    CONSTRAINT fk_accounts_branch_id FOREIGN KEY (branch_id) REFERENCES branches (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE account_holders (\n    id INTEGER NOT NULL,\n    account_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    access_level VARCHAR(255) NOT NULL,\n    valid_from DATE NOT NULL,\n    valid_to DATE,\n    CONSTRAINT pk_account_holders PRIMARY KEY (id),\n    CONSTRAINT fk_account_holders_account_id FOREIGN KEY (account_id) REFERENCES accounts (id),\n    CONSTRAINT fk_account_holders_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE contact_information (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    street VARCHAR(255),\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    valid_from DATE NOT NULL,\n    valid_to DATE,\n    CONSTRAINT pk_contact_information PRIMARY KEY (id),\n    CONSTRAINT fk_contact_information_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    branch_id INTEGER NOT NULL,\n    employee_number VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id),\n    CONSTRAINT fk_employees_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_employees_branch_id FOREIGN KEY (branch_id) REFERENCES branches (id)\n);\n\nCREATE TABLE customer_advisors (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    valid_from DATE NOT NULL,\n    valid_to DATE,\n    CONSTRAINT pk_customer_advisors PRIMARY KEY (id),\n    CONSTRAINT fk_customer_advisors_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_customer_advisors_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n\nCREATE TABLE transaction_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_transaction_types PRIMARY KEY (id)\n);\n\nCREATE TABLE transactions (\n    id INTEGER NOT NULL,\n    account_id INTEGER NOT NULL,\n    transaction_type_id INTEGER NOT NULL,\n    transaction_date DATE NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    purpose TEXT,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_transactions PRIMARY KEY (id),\n    CONSTRAINT fk_transactions_account_id FOREIGN KEY (account_id) REFERENCES accounts (id),\n    CONSTRAINT fk_transactions_transaction_type_id FOREIGN KEY (transaction_type_id) REFERENCES transaction_types (id)\n);\n",
