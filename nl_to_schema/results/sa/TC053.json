    "final_ddl": "CREATE TABLE venues (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    max_capacity INTEGER NOT NULL,\n    CONSTRAINT pk_venues PRIMARY KEY (id)\n);\n\nCREATE TABLE clubs (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    founded_date DATE NOT NULL,\n    contact_email VARCHAR(255) NOT NULL,\n    venue_id INTEGER NOT NULL,\n    CONSTRAINT pk_clubs PRIMARY KEY (id),\n    CONSTRAINT fk_clubs_venue_id FOREIGN KEY (venue_id) REFERENCES venues (id)\n);\n\nCREATE TABLE seasons (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_seasons PRIMARY KEY (id)\n);\n\nCREATE TABLE matches (\n    id INTEGER NOT NULL,\n    season_id INTEGER NOT NULL,\n    home_club_id INTEGER NOT NULL,\n    away_club_id INTEGER NOT NULL,\n    venue_id INTEGER NOT NULL,\n    match_date DATE NOT NULL,\n    match_time VARCHAR(255) NOT NULL,\n    home_goals INTEGER,\n    away_goals INTEGER,\n    CONSTRAINT pk_matches PRIMARY KEY (id),\n    CONSTRAINT fk_matches_season_id FOREIGN KEY (season_id) REFERENCES seasons (id),\n    CONSTRAINT fk_matches_home_club_id FOREIGN KEY (home_club_id) REFERENCES clubs (id),\n    CONSTRAINT fk_matches_away_club_id FOREIGN KEY (away_club_id) REFERENCES clubs (id),\n    CONSTRAINT fk_matches_venue_id FOREIGN KEY (venue_id) REFERENCES venues (id)\n);\n\nCREATE TABLE players (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    shirt_number INTEGER NOT NULL,\n    position VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_players PRIMARY KEY (id)\n);\n\nCREATE TABLE match_player_appearances (\n    id INTEGER NOT NULL,\n    match_id INTEGER NOT NULL,\n    player_id INTEGER NOT NULL,\n    is_starter BOOLEAN NOT NULL,\n    CONSTRAINT pk_match_player_appearances PRIMARY KEY (id),\n    CONSTRAINT fk_match_player_appearances_match_id FOREIGN KEY (match_id) REFERENCES matches (id),\n    CONSTRAINT fk_match_player_appearances_player_id FOREIGN KEY (player_id) REFERENCES players (id)\n);\n\nCREATE TABLE player_club_memberships (\n    id INTEGER NOT NULL,\n    player_id INTEGER NOT NULL,\n    club_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_player_club_memberships PRIMARY KEY (id),\n    CONSTRAINT fk_player_club_memberships_player_id FOREIGN KEY (player_id) REFERENCES players (id),\n    CONSTRAINT fk_player_club_memberships_club_id FOREIGN KEY (club_id) REFERENCES clubs (id)\n);\n",
