    "final_ddl": "CREATE TABLE contribution_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_contribution_types PRIMARY KEY (id)\n);\n\nCREATE TABLE journals (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    issn VARCHAR(255),\n    CONSTRAINT pk_journals PRIMARY KEY (id)\n);\n\nCREATE TABLE issues (\n    id INTEGER NOT NULL,\n    journal_id INTEGER NOT NULL,\n    volume INTEGER NOT NULL,\n    issue_number INTEGER,\n    publication_date DATE,\n    CONSTRAINT pk_issues PRIMARY KEY (id),\n    CONSTRAINT fk_issues_journal_id FOREIGN KEY (journal_id) REFERENCES journals (id)\n);\n\nCREATE TABLE contributions (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    abstract TEXT,\n    contribution_type_id INTEGER NOT NULL,\n    submission_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    issue_id INTEGER,\n    CONSTRAINT pk_contributions PRIMARY KEY (id),\n    CONSTRAINT fk_contributions_contribution_type_id FOREIGN KEY (contribution_type_id) REFERENCES contribution_types (id),\n    CONSTRAINT fk_contributions_issue_id FOREIGN KEY (issue_id) REFERENCES issues (id)\n);\n\nCREATE TABLE institutions (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    city VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_institutions PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    orcid VARCHAR(255),\n    institution_id INTEGER,\n    CONSTRAINT pk_persons PRIMARY KEY (id),\n    CONSTRAINT fk_persons_institution_id FOREIGN KEY (institution_id) REFERENCES institutions (id)\n);\n\nCREATE TABLE contribution_authors (\n    id INTEGER NOT NULL,\n    contribution_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    author_order INTEGER NOT NULL,\n    is_corresponding BOOLEAN,\n    institution_id INTEGER,\n    CONSTRAINT pk_contribution_authors PRIMARY KEY (id),\n    CONSTRAINT fk_contribution_authors_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id),\n    CONSTRAINT fk_contribution_authors_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_contribution_authors_institution_id FOREIGN KEY (institution_id) REFERENCES institutions (id)\n);\n\nCREATE TABLE keywords (\n    id INTEGER NOT NULL,\n    keyword VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_keywords PRIMARY KEY (id)\n);\n\nCREATE TABLE contribution_keywords (\n    contribution_id INTEGER NOT NULL,\n    keyword_id INTEGER NOT NULL,\n    CONSTRAINT pk_contribution_keywords PRIMARY KEY (contribution_id, keyword_id),\n    CONSTRAINT fk_contribution_keywords_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id),\n    CONSTRAINT fk_contribution_keywords_keyword_id FOREIGN KEY (keyword_id) REFERENCES keywords (id)\n);\n\nCREATE TABLE subjects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_subjects PRIMARY KEY (id)\n);\n\nCREATE TABLE contribution_subjects (\n    contribution_id INTEGER NOT NULL,\n    subject_id INTEGER NOT NULL,\n    CONSTRAINT pk_contribution_subjects PRIMARY KEY (contribution_id, subject_id),\n    CONSTRAINT fk_contribution_subjects_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id),\n    CONSTRAINT fk_contribution_subjects_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id)\n);\n\nCREATE TABLE decisions (\n    id INTEGER NOT NULL,\n    contribution_id INTEGER NOT NULL,\n    decision_date DATE NOT NULL,\n    decision_type VARCHAR(255) NOT NULL,\n    comment TEXT,\n    revision_round INTEGER,\n    CONSTRAINT pk_decisions PRIMARY KEY (id),\n    CONSTRAINT fk_decisions_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id)\n);\n\nCREATE TABLE journal_editors (\n    journal_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    CONSTRAINT pk_journal_editors PRIMARY KEY (journal_id, person_id),\n    CONSTRAINT fk_journal_editors_journal_id FOREIGN KEY (journal_id) REFERENCES journals (id),\n    CONSTRAINT fk_journal_editors_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE reviews (\n    id INTEGER NOT NULL,\n    contribution_id INTEGER NOT NULL,\n    reviewer_id INTEGER NOT NULL,\n    request_date DATE NOT NULL,\n    submission_date DATE,\n    recommendation VARCHAR(255),\n    comment TEXT,\n    is_anonymous BOOLEAN,\n    CONSTRAINT pk_reviews PRIMARY KEY (id),\n    CONSTRAINT fk_reviews_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id),\n    CONSTRAINT fk_reviews_reviewer_id FOREIGN KEY (reviewer_id) REFERENCES persons (id)\n);\n",
