    "final_ddl": "CREATE TABLE organizations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    type VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_organizations PRIMARY KEY (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    organization_id INTEGER,\n    CONSTRAINT pk_persons PRIMARY KEY (id),\n    CONSTRAINT fk_persons_organization_id FOREIGN KEY (organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE event_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_event_types PRIMARY KEY (id)\n);\n\nCREATE TABLE incidents (\n    id INTEGER NOT NULL,\n    call_timestamp TIMESTAMP NOT NULL,\n    caller_id INTEGER,\n    location VARCHAR(255),\n    incident_keyword VARCHAR(255) NOT NULL,\n    priority INTEGER NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    dispatcher_id INTEGER NOT NULL,\n    event_type_id INTEGER,\n    created_at TIMESTAMP NOT NULL,\n    updated_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_incidents PRIMARY KEY (id),\n    CONSTRAINT fk_incidents_caller_id FOREIGN KEY (caller_id) REFERENCES persons (id),\n    CONSTRAINT fk_incidents_dispatcher_id FOREIGN KEY (dispatcher_id) REFERENCES persons (id),\n    CONSTRAINT fk_incidents_event_type_id FOREIGN KEY (event_type_id) REFERENCES event_types (id)\n);\n\nCREATE TABLE vehicles (\n    id INTEGER NOT NULL,\n    callsign VARCHAR(255) NOT NULL,\n    vehicle_type VARCHAR(255) NOT NULL,\n    organization_id INTEGER NOT NULL,\n    current_organization_id INTEGER,\n    description TEXT,\n    CONSTRAINT pk_vehicles PRIMARY KEY (id),\n    CONSTRAINT fk_vehicles_organization_id FOREIGN KEY (organization_id) REFERENCES organizations (id),\n    CONSTRAINT fk_vehicles_current_organization_id FOREIGN KEY (current_organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE incident_units (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    vehicle_id INTEGER,\n    organization_id INTEGER,\n    alarm_timestamp TIMESTAMP NOT NULL,\n    CONSTRAINT pk_incident_units PRIMARY KEY (id),\n    CONSTRAINT fk_incident_units_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_units_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id),\n    CONSTRAINT fk_incident_units_organization_id FOREIGN KEY (organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE activities (\n    id INTEGER NOT NULL,\n    incident_id INTEGER NOT NULL,\n    incident_unit_id INTEGER,\n    activity_type VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    timestamp TIMESTAMP NOT NULL,\n    CONSTRAINT pk_activities PRIMARY KEY (id),\n    CONSTRAINT fk_activities_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_activities_incident_unit_id FOREIGN KEY (incident_unit_id) REFERENCES incident_units (id)\n);\n\nCREATE TABLE incident_organizations (\n    incident_id INTEGER NOT NULL,\n    organization_id INTEGER NOT NULL,\n    involvement_timestamp TIMESTAMP NOT NULL,\n    CONSTRAINT pk_incident_organizations PRIMARY KEY (incident_id, organization_id),\n    CONSTRAINT fk_incident_organizations_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_organizations_organization_id FOREIGN KEY (organization_id) REFERENCES organizations (id)\n);\n\nCREATE TABLE incident_unit_personnel (\n    incident_unit_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    function VARCHAR(255) NOT NULL,\n    assigned_timestamp TIMESTAMP NOT NULL,\n    CONSTRAINT pk_incident_unit_personnel PRIMARY KEY (incident_unit_id, person_id),\n    CONSTRAINT fk_incident_unit_personnel_incident_unit_id FOREIGN KEY (incident_unit_id) REFERENCES incident_units (id),\n    CONSTRAINT fk_incident_unit_personnel_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE qualifications (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_qualifications PRIMARY KEY (id)\n);\n\nCREATE TABLE person_qualifications (\n    person_id INTEGER NOT NULL,\n    qualification_id INTEGER NOT NULL,\n    acquired_date DATE,\n    CONSTRAINT pk_person_qualifications PRIMARY KEY (person_id, qualification_id),\n    CONSTRAINT fk_person_qualifications_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_qualifications_qualification_id FOREIGN KEY (qualification_id) REFERENCES qualifications (id)\n);\n\nCREATE TABLE status_messages (\n    id INTEGER NOT NULL,\n    incident_id INTEGER,\n    incident_unit_id INTEGER,\n    status VARCHAR(255) NOT NULL,\n    timestamp TIMESTAMP NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_status_messages PRIMARY KEY (id),\n    CONSTRAINT fk_status_messages_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_status_messages_incident_unit_id FOREIGN KEY (incident_unit_id) REFERENCES incident_units (id)\n);\n",
