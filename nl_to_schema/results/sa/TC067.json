    "final_ddl": "CREATE TABLE patients (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    gender VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address VARCHAR(255),\n    city VARCHAR(255),\n    postal_code VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_patients PRIMARY KEY (id)\n);\n\nCREATE TABLE admissions (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    admission_type VARCHAR(255) NOT NULL,\n    admission_date TIMESTAMP NOT NULL,\n    discharge_date TIMESTAMP,\n    reason TEXT,\n    CONSTRAINT pk_admissions PRIMARY KEY (id),\n    CONSTRAINT fk_admissions_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    employee_type VARCHAR(255) NOT NULL,\n    specialization VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    CONSTRAINT pk_employees PRIMARY KEY (id)\n);\n\nCREATE TABLE appointments (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    appointment_date TIMESTAMP NOT NULL,\n    appointment_type VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_appointments PRIMARY KEY (id),\n    CONSTRAINT fk_appointments_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_appointments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n\nCREATE TABLE contact_persons (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    relationship VARCHAR(255),\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_contact_persons PRIMARY KEY (id),\n    CONSTRAINT fk_contact_persons_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id)\n);\n\nCREATE TABLE departments (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_departments PRIMARY KEY (id)\n);\n\nCREATE TABLE diagnoses (\n    id INTEGER NOT NULL,\n    admission_id INTEGER NOT NULL,\n    icd_code VARCHAR(255),\n    description TEXT NOT NULL,\n    diagnosis_date DATE,\n    CONSTRAINT pk_diagnoses PRIMARY KEY (id),\n    CONSTRAINT fk_diagnoses_admission_id FOREIGN KEY (admission_id) REFERENCES admissions (id)\n);\n\nCREATE TABLE stations (\n    id INTEGER NOT NULL,\n    department_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    bed_capacity INTEGER NOT NULL,\n    CONSTRAINT pk_stations PRIMARY KEY (id),\n    CONSTRAINT fk_stations_department_id FOREIGN KEY (department_id) REFERENCES departments (id)\n);\n\nCREATE TABLE employee_station_assignments (\n    id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    station_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    is_primary BOOLEAN NOT NULL,\n    CONSTRAINT pk_employee_station_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_employee_station_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_employee_station_assignments_station_id FOREIGN KEY (station_id) REFERENCES stations (id)\n);\n\nCREATE TABLE insurance_companies (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    insurance_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_insurance_companies PRIMARY KEY (id)\n);\n\nCREATE TABLE medications (\n    id INTEGER NOT NULL,\n    admission_id INTEGER NOT NULL,\n    medication_name VARCHAR(255) NOT NULL,\n    dosage VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    prescribing_employee_id INTEGER NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_medications PRIMARY KEY (id),\n    CONSTRAINT fk_medications_admission_id FOREIGN KEY (admission_id) REFERENCES admissions (id),\n    CONSTRAINT fk_medications_prescribing_employee_id FOREIGN KEY (prescribing_employee_id) REFERENCES employees (id)\n);\n\nCREATE TABLE patient_insurance (\n    id INTEGER NOT NULL,\n    patient_id INTEGER NOT NULL,\n    insurance_company_id INTEGER,\n    insurance_type VARCHAR(255) NOT NULL,\n    policy_number VARCHAR(255),\n    start_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_patient_insurance PRIMARY KEY (id),\n    CONSTRAINT fk_patient_insurance_patient_id FOREIGN KEY (patient_id) REFERENCES patients (id),\n    CONSTRAINT fk_patient_insurance_insurance_company_id FOREIGN KEY (insurance_company_id) REFERENCES insurance_companies (id)\n);\n\nCREATE TABLE procedures (\n    id INTEGER NOT NULL,\n    admission_id INTEGER NOT NULL,\n    ops_code VARCHAR(255),\n    description TEXT NOT NULL,\n    responsible_employee_id INTEGER NOT NULL,\n    procedure_date TIMESTAMP NOT NULL,\n    CONSTRAINT pk_procedures PRIMARY KEY (id),\n    CONSTRAINT fk_procedures_admission_id FOREIGN KEY (admission_id) REFERENCES admissions (id),\n    CONSTRAINT fk_procedures_responsible_employee_id FOREIGN KEY (responsible_employee_id) REFERENCES employees (id)\n);\n\nCREATE TABLE stays (\n    id INTEGER NOT NULL,\n    admission_id INTEGER NOT NULL,\n    station_id INTEGER NOT NULL,\n    start_date TIMESTAMP NOT NULL,\n    end_date TIMESTAMP,\n    CONSTRAINT pk_stays PRIMARY KEY (id),\n    CONSTRAINT fk_stays_admission_id FOREIGN KEY (admission_id) REFERENCES admissions (id),\n    CONSTRAINT fk_stays_station_id FOREIGN KEY (station_id) REFERENCES stations (id)\n);\n",
