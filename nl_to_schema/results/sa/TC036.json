    "final_ddl": "CREATE TABLE teachers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    hire_date DATE NOT NULL,\n    CONSTRAINT pk_teachers PRIMARY KEY (id)\n);\n\nCREATE TABLE subjects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_subjects PRIMARY KEY (id)\n);\n\nCREATE TABLE learning_groups (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    school_year VARCHAR(255) NOT NULL,\n    class_teacher_id INTEGER NOT NULL,\n    CONSTRAINT pk_learning_groups PRIMARY KEY (id),\n    CONSTRAINT fk_learning_groups_class_teacher_id FOREIGN KEY (class_teacher_id) REFERENCES teachers (id)\n);\n\nCREATE TABLE class_teachings (\n    id INTEGER NOT NULL,\n    teacher_id INTEGER NOT NULL,\n    subject_id INTEGER NOT NULL,\n    learning_group_id INTEGER NOT NULL,\n    CONSTRAINT pk_class_teachings PRIMARY KEY (id),\n    CONSTRAINT fk_class_teachings_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id),\n    CONSTRAINT fk_class_teachings_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id),\n    CONSTRAINT fk_class_teachings_learning_group_id FOREIGN KEY (learning_group_id) REFERENCES learning_groups (id)\n);\n\nCREATE TABLE assessments (\n    id INTEGER NOT NULL,\n    assessment_date DATE NOT NULL,\n    subject VARCHAR(255) NOT NULL,\n    description TEXT,\n    class_teaching_id INTEGER NOT NULL,\n    CONSTRAINT pk_assessments PRIMARY KEY (id),\n    CONSTRAINT fk_assessments_class_teaching_id FOREIGN KEY (class_teaching_id) REFERENCES class_teachings (id)\n);\n\nCREATE TABLE students (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    birthdate DATE NOT NULL,\n    learning_group_id INTEGER NOT NULL,\n    CONSTRAINT pk_students PRIMARY KEY (id),\n    CONSTRAINT fk_students_learning_group_id FOREIGN KEY (learning_group_id) REFERENCES learning_groups (id)\n);\n\nCREATE TABLE grades (\n    id INTEGER NOT NULL,\n    student_id INTEGER NOT NULL,\n    assessment_id INTEGER NOT NULL,\n    grade DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_grades PRIMARY KEY (id),\n    CONSTRAINT fk_grades_student_id FOREIGN KEY (student_id) REFERENCES students (id),\n    CONSTRAINT fk_grades_assessment_id FOREIGN KEY (assessment_id) REFERENCES assessments (id)\n);\n\nCREATE TABLE learning_group_supervisors (\n    id INTEGER NOT NULL,\n    learning_group_id INTEGER NOT NULL,\n    teacher_id INTEGER NOT NULL,\n    CONSTRAINT pk_learning_group_supervisors PRIMARY KEY (id),\n    CONSTRAINT fk_learning_group_supervisors_learning_group_id FOREIGN KEY (learning_group_id) REFERENCES learning_groups (id),\n    CONSTRAINT fk_learning_group_supervisors_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id)\n);\n\nCREATE TABLE teacher_subjects (\n    id INTEGER NOT NULL,\n    teacher_id INTEGER NOT NULL,\n    subject_id INTEGER NOT NULL,\n    CONSTRAINT pk_teacher_subjects PRIMARY KEY (id),\n    CONSTRAINT fk_teacher_subjects_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id),\n    CONSTRAINT fk_teacher_subjects_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id)\n);\n",
