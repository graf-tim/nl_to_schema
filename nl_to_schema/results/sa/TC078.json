    "final_ddl": "CREATE TABLE projects (\n    id INTEGER NOT NULL,\n    project_number VARCHAR(255) NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    planned_start_date DATE,\n    planned_completion_date DATE,\n    current_status VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_projects PRIMARY KEY (id)\n);\n\nCREATE TABLE companies (\n    id INTEGER NOT NULL,\n    company_name VARCHAR(255) NOT NULL,\n    company_type VARCHAR(255),\n    CONSTRAINT pk_companies PRIMARY KEY (id)\n);\n\nCREATE TABLE contracts (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    contract_date DATE,\n    contract_amount DECIMAL(18,2),\n    status VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_contracts PRIMARY KEY (id),\n    CONSTRAINT fk_contracts_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_contracts_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE change_orders (\n    id INTEGER NOT NULL,\n    contract_id INTEGER,\n    project_id INTEGER NOT NULL,\n    change_order_date DATE,\n    amount DECIMAL(18,2),\n    reason TEXT,\n    status VARCHAR(255),\n    CONSTRAINT pk_change_orders PRIMARY KEY (id),\n    CONSTRAINT fk_change_orders_contract_id FOREIGN KEY (contract_id) REFERENCES contracts (id),\n    CONSTRAINT fk_change_orders_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE construction_sections (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    section_number VARCHAR(255) NOT NULL,\n    designation VARCHAR(255),\n    planned_start_date DATE,\n    planned_completion_date DATE,\n    current_status VARCHAR(255),\n    CONSTRAINT pk_construction_sections PRIMARY KEY (id),\n    CONSTRAINT fk_construction_sections_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE contacts (\n    id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    position VARCHAR(255),\n    CONSTRAINT pk_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_contacts_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE defects (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    construction_section_id INTEGER,\n    company_id INTEGER,\n    location_description VARCHAR(255),\n    description TEXT NOT NULL,\n    recorded_date DATE NOT NULL,\n    recorded_by_contact_id INTEGER,\n    responsible_contact_id INTEGER,\n    deadline DATE,\n    status VARCHAR(255),\n    CONSTRAINT pk_defects PRIMARY KEY (id),\n    CONSTRAINT fk_defects_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_defects_construction_section_id FOREIGN KEY (construction_section_id) REFERENCES construction_sections (id),\n    CONSTRAINT fk_defects_company_id FOREIGN KEY (company_id) REFERENCES companies (id),\n    CONSTRAINT fk_defects_recorded_by_contact_id FOREIGN KEY (recorded_by_contact_id) REFERENCES contacts (id),\n    CONSTRAINT fk_defects_responsible_contact_id FOREIGN KEY (responsible_contact_id) REFERENCES contacts (id)\n);\n\nCREATE TABLE documents (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    document_type VARCHAR(255),\n    document_title VARCHAR(255) NOT NULL,\n    planner_id INTEGER,\n    version_number INTEGER,\n    version_date DATE,\n    is_current BOOLEAN,\n    notes TEXT,\n    CONSTRAINT pk_documents PRIMARY KEY (id),\n    CONSTRAINT fk_documents_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_documents_planner_id FOREIGN KEY (planner_id) REFERENCES companies (id)\n);\n\nCREATE TABLE project_companies (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    trade VARCHAR(255),\n    role VARCHAR(255),\n    CONSTRAINT pk_project_companies PRIMARY KEY (id),\n    CONSTRAINT fk_project_companies_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_companies_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE project_events (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    event_type VARCHAR(255),\n    event_date DATE,\n    event_time VARCHAR(255),\n    description TEXT,\n    protocol_reference VARCHAR(255),\n    CONSTRAINT pk_project_events PRIMARY KEY (id),\n    CONSTRAINT fk_project_events_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n",
