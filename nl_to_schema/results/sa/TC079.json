    "final_ddl": "CREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    street VARCHAR(255),\n    city VARCHAR(255),\n    postalcode VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE insureds (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    insurance_number VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    enrollment_date DATE NOT NULL,\n    insurance_type VARCHAR(255),\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_insureds PRIMARY KEY (id),\n    CONSTRAINT fk_insureds_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE benefit_requests (\n    id INTEGER NOT NULL,\n    insured_id INTEGER NOT NULL,\n    request_type VARCHAR(255) NOT NULL,\n    request_date DATE NOT NULL,\n    description TEXT,\n    status VARCHAR(255) NOT NULL,\n    decision_date DATE,\n    decision_reason TEXT,\n    CONSTRAINT pk_benefit_requests PRIMARY KEY (id),\n    CONSTRAINT fk_benefit_requests_insured_id FOREIGN KEY (insured_id) REFERENCES insureds (id)\n);\n\nCREATE TABLE benefit_request_items (\n    id INTEGER NOT NULL,\n    benefit_request_id INTEGER NOT NULL,\n    item_description TEXT NOT NULL,\n    justification TEXT,\n    item_status VARCHAR(255),\n    CONSTRAINT pk_benefit_request_items PRIMARY KEY (id),\n    CONSTRAINT fk_benefit_request_items_benefit_request_id FOREIGN KEY (benefit_request_id) REFERENCES benefit_requests (id)\n);\n\nCREATE TABLE employers (\n    id INTEGER NOT NULL,\n    company_name VARCHAR(255) NOT NULL,\n    employer_id_number VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    street VARCHAR(255),\n    city VARCHAR(255),\n    postalcode VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_employers PRIMARY KEY (id)\n);\n\nCREATE TABLE employments (\n    id INTEGER NOT NULL,\n    insured_id INTEGER NOT NULL,\n    employer_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_employments PRIMARY KEY (id),\n    CONSTRAINT fk_employments_insured_id FOREIGN KEY (insured_id) REFERENCES insureds (id),\n    CONSTRAINT fk_employments_employer_id FOREIGN KEY (employer_id) REFERENCES employers (id)\n);\n\nCREATE TABLE contribution_reports (\n    id INTEGER NOT NULL,\n    employment_id INTEGER NOT NULL,\n    report_date DATE NOT NULL,\n    period_start DATE NOT NULL,\n    period_end DATE NOT NULL,\n    taxable_income DECIMAL(18,2) NOT NULL,\n    is_correction BOOLEAN NOT NULL,\n    correction_of_report_id INTEGER,\n    CONSTRAINT pk_contribution_reports PRIMARY KEY (id),\n    CONSTRAINT fk_contribution_reports_employment_id FOREIGN KEY (employment_id) REFERENCES employments (id),\n    CONSTRAINT fk_contribution_reports_correction_of_report_id FOREIGN KEY (correction_of_report_id) REFERENCES contribution_reports (id)\n);\n\nCREATE TABLE service_providers (\n    id INTEGER NOT NULL,\n    institution_name VARCHAR(255) NOT NULL,\n    institution_id VARCHAR(255) NOT NULL,\n    specialty VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    street VARCHAR(255),\n    city VARCHAR(255),\n    postalcode VARCHAR(255),\n    country VARCHAR(255),\n    CONSTRAINT pk_service_providers PRIMARY KEY (id)\n);\n\nCREATE TABLE treatment_cases (\n    id INTEGER NOT NULL,\n    insured_id INTEGER NOT NULL,\n    service_provider_id INTEGER NOT NULL,\n    case_start_date DATE NOT NULL,\n    case_end_date DATE,\n    description TEXT,\n    CONSTRAINT pk_treatment_cases PRIMARY KEY (id),\n    CONSTRAINT fk_treatment_cases_insured_id FOREIGN KEY (insured_id) REFERENCES insureds (id),\n    CONSTRAINT fk_treatment_cases_service_provider_id FOREIGN KEY (service_provider_id) REFERENCES service_providers (id)\n);\n\nCREATE TABLE diagnoses (\n    id INTEGER NOT NULL,\n    treatment_case_id INTEGER NOT NULL,\n    diagnosis_code VARCHAR(255) NOT NULL,\n    diagnosis_text TEXT,\n    diagnosis_status VARCHAR(255) NOT NULL,\n    diagnosis_date DATE,\n    CONSTRAINT pk_diagnoses PRIMARY KEY (id),\n    CONSTRAINT fk_diagnoses_treatment_case_id FOREIGN KEY (treatment_case_id) REFERENCES treatment_cases (id)\n);\n\nCREATE TABLE provider_accreditations (\n    id INTEGER NOT NULL,\n    service_provider_id INTEGER NOT NULL,\n    accreditation_number VARCHAR(255) NOT NULL,\n    accreditation_type VARCHAR(255),\n    valid_from DATE NOT NULL,\n    valid_until DATE,\n    regional_scope VARCHAR(255),\n    CONSTRAINT pk_provider_accreditations PRIMARY KEY (id),\n    CONSTRAINT fk_provider_accreditations_service_provider_id FOREIGN KEY (service_provider_id) REFERENCES service_providers (id)\n);\n\nCREATE TABLE request_inquiries (\n    id INTEGER NOT NULL,\n    benefit_request_id INTEGER NOT NULL,\n    inquiry_date DATE NOT NULL,\n    inquiry_text TEXT NOT NULL,\n    response_date DATE,\n    response_text TEXT,\n    CONSTRAINT pk_request_inquiries PRIMARY KEY (id),\n    CONSTRAINT fk_request_inquiries_benefit_request_id FOREIGN KEY (benefit_request_id) REFERENCES benefit_requests (id)\n);\n",
