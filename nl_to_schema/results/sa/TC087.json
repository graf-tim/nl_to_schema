    "final_ddl": "CREATE TABLE device_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_device_types PRIMARY KEY (id)\n);\n\nCREATE TABLE manufacturers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    country VARCHAR(255),\n    contact_email VARCHAR(255),\n    contact_phone VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_manufacturers PRIMARY KEY (id)\n);\n\nCREATE TABLE products (\n    id INTEGER NOT NULL,\n    device_type_id INTEGER NOT NULL,\n    manufacturer_id INTEGER NOT NULL,\n    model_designation VARCHAR(255) NOT NULL,\n    risk_class VARCHAR(255),\n    udi_di VARCHAR(255),\n    ce_marking BOOLEAN,\n    notes TEXT,\n    CONSTRAINT pk_products PRIMARY KEY (id),\n    CONSTRAINT fk_products_device_type_id FOREIGN KEY (device_type_id) REFERENCES device_types (id),\n    CONSTRAINT fk_products_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    building_name VARCHAR(255) NOT NULL,\n    station_name VARCHAR(255),\n    functional_area VARCHAR(255),\n    room_number VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE devices (\n    id INTEGER NOT NULL,\n    product_id INTEGER NOT NULL,\n    inventory_number VARCHAR(255),\n    serial_number VARCHAR(255),\n    commissioning_date DATE,\n    status VARCHAR(255),\n    current_location_id INTEGER,\n    notes TEXT,\n    CONSTRAINT pk_devices PRIMARY KEY (id),\n    CONSTRAINT fk_devices_product_id FOREIGN KEY (product_id) REFERENCES products (id),\n    CONSTRAINT fk_devices_current_location_id FOREIGN KEY (current_location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE device_location_history (\n    id INTEGER NOT NULL,\n    device_id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    notes TEXT,\n    CONSTRAINT pk_device_location_history PRIMARY KEY (id),\n    CONSTRAINT fk_device_location_history_device_id FOREIGN KEY (device_id) REFERENCES devices (id),\n    CONSTRAINT fk_device_location_history_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    department VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE device_responsibilities (\n    id INTEGER NOT NULL,\n    device_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    responsibility_type VARCHAR(255) NOT NULL,\n    start_date DATE,\n    end_date DATE,\n    notes TEXT,\n    CONSTRAINT pk_device_responsibilities PRIMARY KEY (id),\n    CONSTRAINT fk_device_responsibilities_device_id FOREIGN KEY (device_id) REFERENCES devices (id),\n    CONSTRAINT fk_device_responsibilities_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE inspection_types (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    code VARCHAR(255),\n    description TEXT,\n    default_interval_days INTEGER,\n    CONSTRAINT pk_inspection_types PRIMARY KEY (id)\n);\n\nCREATE TABLE device_type_inspections (\n    id INTEGER NOT NULL,\n    device_type_id INTEGER NOT NULL,\n    inspection_type_id INTEGER NOT NULL,\n    is_mandatory BOOLEAN,\n    interval_days INTEGER,\n    CONSTRAINT pk_device_type_inspections PRIMARY KEY (id),\n    CONSTRAINT fk_device_type_inspections_device_type_id FOREIGN KEY (device_type_id) REFERENCES device_types (id),\n    CONSTRAINT fk_device_type_inspections_inspection_type_id FOREIGN KEY (inspection_type_id) REFERENCES inspection_types (id)\n);\n\nCREATE TABLE incidents (\n    id INTEGER NOT NULL,\n    device_id INTEGER NOT NULL,\n    incident_type VARCHAR(255) NOT NULL,\n    report_date DATE NOT NULL,\n    severity VARCHAR(255),\n    description TEXT,\n    status VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_incidents PRIMARY KEY (id),\n    CONSTRAINT fk_incidents_device_id FOREIGN KEY (device_id) REFERENCES devices (id)\n);\n\nCREATE TABLE inspections (\n    id INTEGER NOT NULL,\n    device_id INTEGER NOT NULL,\n    inspection_type_id INTEGER NOT NULL,\n    inspection_date DATE NOT NULL,\n    next_due_date DATE,\n    result VARCHAR(255),\n    remarks TEXT,\n    defects_found BOOLEAN,\n    CONSTRAINT pk_inspections PRIMARY KEY (id),\n    CONSTRAINT fk_inspections_device_id FOREIGN KEY (device_id) REFERENCES devices (id),\n    CONSTRAINT fk_inspections_inspection_type_id FOREIGN KEY (inspection_type_id) REFERENCES inspection_types (id)\n);\n\nCREATE TABLE manufacturer_contacts (\n    id INTEGER NOT NULL,\n    manufacturer_id INTEGER NOT NULL,\n    contact_name VARCHAR(255) NOT NULL,\n    contact_role VARCHAR(255),\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    is_primary BOOLEAN,\n    CONSTRAINT pk_manufacturer_contacts PRIMARY KEY (id),\n    CONSTRAINT fk_manufacturer_contacts_manufacturer_id FOREIGN KEY (manufacturer_id) REFERENCES manufacturers (id)\n);\n\nCREATE TABLE service_providers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    service_type VARCHAR(255),\n    contact_email VARCHAR(255),\n    contact_phone VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_service_providers PRIMARY KEY (id)\n);\n\nCREATE TABLE product_service_providers (\n    id INTEGER NOT NULL,\n    product_id INTEGER NOT NULL,\n    service_provider_id INTEGER NOT NULL,\n    service_type VARCHAR(255),\n    is_primary BOOLEAN,\n    notes TEXT,\n    CONSTRAINT pk_product_service_providers PRIMARY KEY (id),\n    CONSTRAINT fk_product_service_providers_product_id FOREIGN KEY (product_id) REFERENCES products (id),\n    CONSTRAINT fk_product_service_providers_service_provider_id FOREIGN KEY (service_provider_id) REFERENCES service_providers (id)\n);\n\nCREATE TABLE standards (\n    id INTEGER NOT NULL,\n    standard_code VARCHAR(255) NOT NULL,\n    standard_name VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_standards PRIMARY KEY (id)\n);\n\nCREATE TABLE product_standards (\n    product_id INTEGER NOT NULL,\n    standard_id INTEGER NOT NULL,\n    CONSTRAINT pk_product_standards PRIMARY KEY (product_id, standard_id),\n    CONSTRAINT fk_product_standards_product_id FOREIGN KEY (product_id) REFERENCES products (id),\n    CONSTRAINT fk_product_standards_standard_id FOREIGN KEY (standard_id) REFERENCES standards (id)\n);\n",
