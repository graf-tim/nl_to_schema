    "final_ddl": "CREATE TABLE companies (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    industry VARCHAR(255) NOT NULL,\n    contact_address TEXT NOT NULL,\n    CONSTRAINT pk_companies PRIMARY KEY (id)\n);\n\nCREATE TABLE job_postings (\n    id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    start_date DATE,\n    end_date DATE,\n    budget DECIMAL(18,2),\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_job_postings PRIMARY KEY (id),\n    CONSTRAINT fk_job_postings_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE professionals (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    introduction TEXT,\n    hourly_rate DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_professionals PRIMARY KEY (id)\n);\n\nCREATE TABLE applications (\n    id INTEGER NOT NULL,\n    job_posting_id INTEGER NOT NULL,\n    professional_id INTEGER NOT NULL,\n    applied_at TIMESTAMP NOT NULL,\n    offered_price DECIMAL(18,2) NOT NULL,\n    is_accepted BOOLEAN,\n    CONSTRAINT pk_applications PRIMARY KEY (id),\n    CONSTRAINT fk_applications_job_posting_id FOREIGN KEY (job_posting_id) REFERENCES job_postings (id),\n    CONSTRAINT fk_applications_professional_id FOREIGN KEY (professional_id) REFERENCES professionals (id)\n);\n\nCREATE TABLE collaborations (\n    id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    professional_id INTEGER NOT NULL,\n    application_id INTEGER,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    is_ongoing BOOLEAN NOT NULL,\n    CONSTRAINT pk_collaborations PRIMARY KEY (id),\n    CONSTRAINT fk_collaborations_company_id FOREIGN KEY (company_id) REFERENCES companies (id),\n    CONSTRAINT fk_collaborations_professional_id FOREIGN KEY (professional_id) REFERENCES professionals (id),\n    CONSTRAINT fk_collaborations_application_id FOREIGN KEY (application_id) REFERENCES applications (id)\n);\n\nCREATE TABLE skills (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_skills PRIMARY KEY (id)\n);\n\nCREATE TABLE professional_skills (\n    professional_id INTEGER NOT NULL,\n    skill_id INTEGER NOT NULL,\n    CONSTRAINT pk_professional_skills PRIMARY KEY (professional_id, skill_id),\n    CONSTRAINT fk_professional_skills_professional_id FOREIGN KEY (professional_id) REFERENCES professionals (id),\n    CONSTRAINT fk_professional_skills_skill_id FOREIGN KEY (skill_id) REFERENCES skills (id)\n);\n",
