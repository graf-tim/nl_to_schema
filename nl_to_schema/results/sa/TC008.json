    "final_ddl": "CREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE dogs (\n    id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    breed VARCHAR(255),\n    care_notes TEXT,\n    CONSTRAINT pk_dogs PRIMARY KEY (id),\n    CONSTRAINT fk_dogs_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE treatments (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    price DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_treatments PRIMARY KEY (id)\n);\n\nCREATE TABLE appointments (\n    id INTEGER NOT NULL,\n    dog_id INTEGER NOT NULL,\n    treatment_id INTEGER NOT NULL,\n    appointment_date DATE NOT NULL,\n    is_completed BOOLEAN NOT NULL,\n    CONSTRAINT pk_appointments PRIMARY KEY (id),\n    CONSTRAINT fk_appointments_dog_id FOREIGN KEY (dog_id) REFERENCES dogs (id),\n    CONSTRAINT fk_appointments_treatment_id FOREIGN KEY (treatment_id) REFERENCES treatments (id)\n);\n",
