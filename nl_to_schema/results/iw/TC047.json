    "final_ddl": "CREATE TABLE departments (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_departments PRIMARY KEY (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    CONSTRAINT pk_employees PRIMARY KEY (id)\n);\n\nCREATE TABLE priorities (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    level INTEGER NOT NULL,\n    CONSTRAINT pk_priorities PRIMARY KEY (id)\n);\n\nCREATE TABLE statuses (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_statuses PRIMARY KEY (id)\n);\n\nCREATE TABLE tickets (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    department_id INTEGER NOT NULL,\n    priority_id INTEGER NOT NULL,\n    status_id INTEGER NOT NULL,\n    reporter_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    completed_at TIMESTAMP,\n    CONSTRAINT pk_tickets PRIMARY KEY (id),\n    CONSTRAINT fk_tickets_department_id FOREIGN KEY (department_id) REFERENCES departments (id),\n    CONSTRAINT fk_tickets_priority_id FOREIGN KEY (priority_id) REFERENCES priorities (id),\n    CONSTRAINT fk_tickets_status_id FOREIGN KEY (status_id) REFERENCES statuses (id),\n    CONSTRAINT fk_tickets_reporter_id FOREIGN KEY (reporter_id) REFERENCES employees (id)\n);\n\nCREATE TABLE notes (\n    id INTEGER NOT NULL,\n    ticket_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    content TEXT NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_notes PRIMARY KEY (id),\n    CONSTRAINT fk_notes_ticket_id FOREIGN KEY (ticket_id) REFERENCES tickets (id),\n    CONSTRAINT fk_notes_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n\nCREATE TABLE ticket_assignments (\n    ticket_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    assigned_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_ticket_assignments PRIMARY KEY (ticket_id, employee_id),\n    CONSTRAINT fk_ticket_assignments_ticket_id FOREIGN KEY (ticket_id) REFERENCES tickets (id),\n    CONSTRAINT fk_ticket_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n",
