    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    address TEXT,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE locations (\n    id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    address TEXT NOT NULL,\n    accessibility_note TEXT,\n    CONSTRAINT pk_locations PRIMARY KEY (id),\n    CONSTRAINT fk_locations_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE cleaning_services (\n    id INTEGER NOT NULL,\n    location_id INTEGER NOT NULL,\n    service_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    notes TEXT,\n    CONSTRAINT pk_cleaning_services PRIMARY KEY (id),\n    CONSTRAINT fk_cleaning_services_location_id FOREIGN KEY (location_id) REFERENCES locations (id)\n);\n",
