    "final_ddl": "CREATE TABLE product_categories (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_product_categories PRIMARY KEY (id)\n);\n\nCREATE TABLE suppliers (\n    id INTEGER NOT NULL,\n    company_name VARCHAR(255) NOT NULL,\n    contact_person VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_suppliers PRIMARY KEY (id)\n);\n\nCREATE TABLE articles (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    selling_price DECIMAL(18,2) NOT NULL,\n    stock_quantity INTEGER NOT NULL,\n    product_category_id INTEGER NOT NULL,\n    supplier_id INTEGER NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_articles PRIMARY KEY (id),\n    CONSTRAINT fk_articles_product_category_id FOREIGN KEY (product_category_id) REFERENCES product_categories (id),\n    CONSTRAINT fk_articles_supplier_id FOREIGN KEY (supplier_id) REFERENCES suppliers (id)\n);\n",
