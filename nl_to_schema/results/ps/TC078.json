    "final_ddl": "CREATE TABLE projects (\n    id INTEGER NOT NULL,\n    project_number VARCHAR(255) NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    planned_start_date DATE NOT NULL,\n    planned_completion_date DATE NOT NULL,\n    current_status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_projects PRIMARY KEY (id)\n);\n\nCREATE TABLE companies (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    company_type VARCHAR(255),\n    contact_person VARCHAR(255),\n    communication_data VARCHAR(255),\n    CONSTRAINT pk_companies PRIMARY KEY (id)\n);\n\nCREATE TABLE contracts (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    award_sum DECIMAL(18,2) NOT NULL,\n    contract_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_contracts PRIMARY KEY (id),\n    CONSTRAINT fk_contracts_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_contracts_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE change_orders (\n    id INTEGER NOT NULL,\n    contract_id INTEGER,\n    project_id INTEGER,\n    amount DECIMAL(18,2) NOT NULL,\n    date DATE NOT NULL,\n    justification TEXT NOT NULL,\n    CONSTRAINT pk_change_orders PRIMARY KEY (id),\n    CONSTRAINT fk_change_orders_contract_id FOREIGN KEY (contract_id) REFERENCES contracts (id),\n    CONSTRAINT fk_change_orders_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE construction_sections (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_construction_sections PRIMARY KEY (id),\n    CONSTRAINT fk_construction_sections_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE defects (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    company_id INTEGER,\n    construction_section_id INTEGER,\n    site_location VARCHAR(255),\n    description TEXT NOT NULL,\n    recorded_date DATE NOT NULL,\n    deadline DATE,\n    processing_status VARCHAR(255) NOT NULL,\n    recorded_by VARCHAR(255),\n    responsible_party VARCHAR(255),\n    CONSTRAINT pk_defects PRIMARY KEY (id),\n    CONSTRAINT fk_defects_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_defects_company_id FOREIGN KEY (company_id) REFERENCES companies (id),\n    CONSTRAINT fk_defects_construction_section_id FOREIGN KEY (construction_section_id) REFERENCES construction_sections (id)\n);\n\nCREATE TABLE milestones (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    date DATE NOT NULL,\n    milestone_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    protocol_reference VARCHAR(255),\n    CONSTRAINT pk_milestones PRIMARY KEY (id),\n    CONSTRAINT fk_milestones_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE plan_documents (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    company_id INTEGER,\n    document_type VARCHAR(255) NOT NULL,\n    version_number VARCHAR(255) NOT NULL,\n    date DATE NOT NULL,\n    version_status VARCHAR(255),\n    CONSTRAINT pk_plan_documents PRIMARY KEY (id),\n    CONSTRAINT fk_plan_documents_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_plan_documents_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n\nCREATE TABLE project_companies (\n    id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    company_id INTEGER NOT NULL,\n    trade VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_project_companies PRIMARY KEY (id),\n    CONSTRAINT fk_project_companies_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_companies_company_id FOREIGN KEY (company_id) REFERENCES companies (id)\n);\n",
