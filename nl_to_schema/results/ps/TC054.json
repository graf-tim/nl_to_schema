    "final_ddl": "CREATE TABLE acts (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    country_of_origin VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_acts PRIMARY KEY (id)\n);\n\nCREATE TABLE genres (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_genres PRIMARY KEY (id)\n);\n\nCREATE TABLE act_genres (\n    act_id INTEGER NOT NULL,\n    genre_id INTEGER NOT NULL,\n    CONSTRAINT pk_act_genres PRIMARY KEY (act_id, genre_id),\n    CONSTRAINT fk_act_genres_act_id FOREIGN KEY (act_id) REFERENCES acts (id),\n    CONSTRAINT fk_act_genres_genre_id FOREIGN KEY (genre_id) REFERENCES genres (id)\n);\n\nCREATE TABLE stages (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    max_capacity INTEGER NOT NULL,\n    CONSTRAINT pk_stages PRIMARY KEY (id)\n);\n\nCREATE TABLE festival_days (\n    id INTEGER NOT NULL,\n    date DATE NOT NULL,\n    CONSTRAINT pk_festival_days PRIMARY KEY (id)\n);\n\nCREATE TABLE program_slots (\n    id INTEGER NOT NULL,\n    start_time TIMESTAMP NOT NULL,\n    end_time TIMESTAMP NOT NULL,\n    slot_type VARCHAR(255) NOT NULL,\n    stage_id INTEGER NOT NULL,\n    festival_day_id INTEGER NOT NULL,\n    CONSTRAINT pk_program_slots PRIMARY KEY (id),\n    CONSTRAINT fk_program_slots_stage_id FOREIGN KEY (stage_id) REFERENCES stages (id),\n    CONSTRAINT fk_program_slots_festival_day_id FOREIGN KEY (festival_day_id) REFERENCES festival_days (id)\n);\n\nCREATE TABLE act_program_slots (\n    act_id INTEGER NOT NULL,\n    program_slot_id INTEGER NOT NULL,\n    CONSTRAINT pk_act_program_slots PRIMARY KEY (act_id, program_slot_id),\n    CONSTRAINT fk_act_program_slots_act_id FOREIGN KEY (act_id) REFERENCES acts (id),\n    CONSTRAINT fk_act_program_slots_program_slot_id FOREIGN KEY (program_slot_id) REFERENCES program_slots (id)\n);\n\nCREATE TABLE tickets (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    time_period VARCHAR(255) NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_tickets PRIMARY KEY (id)\n);\n",
