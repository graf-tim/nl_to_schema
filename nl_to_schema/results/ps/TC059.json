    "final_ddl": "CREATE TABLE owners (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    contact_data VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_owners PRIMARY KEY (id)\n);\n\nCREATE TABLE apartments (\n    id INTEGER NOT NULL,\n    owner_id INTEGER NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    size DECIMAL(18,2) NOT NULL,\n    rent DECIMAL(18,2) NOT NULL,\n    room_count INTEGER NOT NULL,\n    description TEXT,\n    availability_date DATE NOT NULL,\n    CONSTRAINT pk_apartments PRIMARY KEY (id),\n    CONSTRAINT fk_apartments_owner_id FOREIGN KEY (owner_id) REFERENCES owners (id)\n);\n\nCREATE TABLE viewing_appointments (\n    id INTEGER NOT NULL,\n    apartment_id INTEGER NOT NULL,\n    date DATE NOT NULL,\n    time VARCHAR(255) NOT NULL,\n    note TEXT,\n    viewing_type VARCHAR(255),\n    CONSTRAINT pk_viewing_appointments PRIMARY KEY (id),\n    CONSTRAINT fk_viewing_appointments_apartment_id FOREIGN KEY (apartment_id) REFERENCES apartments (id)\n);\n\nCREATE TABLE interested_parties (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    contact_options VARCHAR(255) NOT NULL,\n    inquiry_timestamp TIMESTAMP NOT NULL,\n    CONSTRAINT pk_interested_parties PRIMARY KEY (id)\n);\n\nCREATE TABLE appointment_participants (\n    viewing_appointment_id INTEGER NOT NULL,\n    interested_party_id INTEGER NOT NULL,\n    participation_status VARCHAR(255),\n    CONSTRAINT pk_appointment_participants PRIMARY KEY (viewing_appointment_id, interested_party_id),\n    CONSTRAINT fk_appointment_participants_viewing_appointment_id FOREIGN KEY (viewing_appointment_id) REFERENCES viewing_appointments (id),\n    CONSTRAINT fk_appointment_participants_interested_party_id FOREIGN KEY (interested_party_id) REFERENCES interested_parties (id)\n);\n\nCREATE TABLE feedbacks (\n    id INTEGER NOT NULL,\n    interested_party_id INTEGER NOT NULL,\n    apartment_id INTEGER NOT NULL,\n    rating INTEGER NOT NULL,\n    comment TEXT,\n    CONSTRAINT pk_feedbacks PRIMARY KEY (id),\n    CONSTRAINT fk_feedbacks_interested_party_id FOREIGN KEY (interested_party_id) REFERENCES interested_parties (id),\n    CONSTRAINT fk_feedbacks_apartment_id FOREIGN KEY (apartment_id) REFERENCES apartments (id)\n);\n\nCREATE TABLE reservations (\n    id INTEGER NOT NULL,\n    interested_party_id INTEGER NOT NULL,\n    apartment_id INTEGER NOT NULL,\n    creation_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_reservations PRIMARY KEY (id),\n    CONSTRAINT fk_reservations_interested_party_id FOREIGN KEY (interested_party_id) REFERENCES interested_parties (id),\n    CONSTRAINT fk_reservations_apartment_id FOREIGN KEY (apartment_id) REFERENCES apartments (id)\n);\n",
