    "final_ddl": "CREATE TABLE datasets (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    creationdate DATE NOT NULL,\n    access_conditions VARCHAR(255),\n    usage_conditions VARCHAR(255),\n    CONSTRAINT pk_datasets PRIMARY KEY (id)\n);\n\nCREATE TABLE methods (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_methods PRIMARY KEY (id)\n);\n\nCREATE TABLE dataset_methods (\n    dataset_id INTEGER NOT NULL,\n    method_id INTEGER NOT NULL,\n    CONSTRAINT pk_dataset_methods PRIMARY KEY (dataset_id, method_id),\n    CONSTRAINT fk_dataset_methods_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id),\n    CONSTRAINT fk_dataset_methods_method_id FOREIGN KEY (method_id) REFERENCES methods (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE roles (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    context VARCHAR(255),\n    CONSTRAINT pk_roles PRIMARY KEY (id)\n);\n\nCREATE TABLE dataset_persons (\n    dataset_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role_id INTEGER,\n    CONSTRAINT pk_dataset_persons PRIMARY KEY (dataset_id, person_id),\n    CONSTRAINT fk_dataset_persons_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id),\n    CONSTRAINT fk_dataset_persons_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_dataset_persons_role_id FOREIGN KEY (role_id) REFERENCES roles (id)\n);\n\nCREATE TABLE projects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    startdate DATE NOT NULL,\n    enddate DATE,\n    status VARCHAR(255) NOT NULL,\n    responsible_person_id INTEGER NOT NULL,\n    CONSTRAINT pk_projects PRIMARY KEY (id),\n    CONSTRAINT fk_projects_responsible_person_id FOREIGN KEY (responsible_person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE dataset_projects (\n    dataset_id INTEGER NOT NULL,\n    project_id INTEGER NOT NULL,\n    CONSTRAINT pk_dataset_projects PRIMARY KEY (dataset_id, project_id),\n    CONSTRAINT fk_dataset_projects_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id),\n    CONSTRAINT fk_dataset_projects_project_id FOREIGN KEY (project_id) REFERENCES projects (id)\n);\n\nCREATE TABLE dataset_versions (\n    id INTEGER NOT NULL,\n    dataset_id INTEGER NOT NULL,\n    version_number VARCHAR(255) NOT NULL,\n    processing_status VARCHAR(255),\n    filepath VARCHAR(255),\n    doi VARCHAR(255),\n    format VARCHAR(255),\n    size DECIMAL(18,2),\n    publication_status VARCHAR(255),\n    creationdate DATE NOT NULL,\n    access_conditions VARCHAR(255),\n    usage_conditions VARCHAR(255),\n    CONSTRAINT pk_dataset_versions PRIMARY KEY (id),\n    CONSTRAINT fk_dataset_versions_dataset_id FOREIGN KEY (dataset_id) REFERENCES datasets (id)\n);\n\nCREATE TABLE funders (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    funding_code VARCHAR(255),\n    approval_period_from DATE,\n    approval_period_to DATE,\n    CONSTRAINT pk_funders PRIMARY KEY (id)\n);\n\nCREATE TABLE project_funders (\n    project_id INTEGER NOT NULL,\n    funder_id INTEGER NOT NULL,\n    CONSTRAINT pk_project_funders PRIMARY KEY (project_id, funder_id),\n    CONSTRAINT fk_project_funders_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_funders_funder_id FOREIGN KEY (funder_id) REFERENCES funders (id)\n);\n\nCREATE TABLE project_persons (\n    project_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    role_id INTEGER,\n    CONSTRAINT pk_project_persons PRIMARY KEY (project_id, person_id),\n    CONSTRAINT fk_project_persons_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_persons_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_project_persons_role_id FOREIGN KEY (role_id) REFERENCES roles (id)\n);\n\nCREATE TABLE workgroups (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_workgroups PRIMARY KEY (id)\n);\n\nCREATE TABLE project_workgroups (\n    project_id INTEGER NOT NULL,\n    workgroup_id INTEGER NOT NULL,\n    CONSTRAINT pk_project_workgroups PRIMARY KEY (project_id, workgroup_id),\n    CONSTRAINT fk_project_workgroups_project_id FOREIGN KEY (project_id) REFERENCES projects (id),\n    CONSTRAINT fk_project_workgroups_workgroup_id FOREIGN KEY (workgroup_id) REFERENCES workgroups (id)\n);\n",
