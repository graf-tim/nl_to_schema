    "final_ddl": "CREATE TABLE journals (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    issn VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_journals PRIMARY KEY (id)\n);\n\nCREATE TABLE issues (\n    id INTEGER NOT NULL,\n    journal_id INTEGER NOT NULL,\n    volume INTEGER NOT NULL,\n    issue_number INTEGER NOT NULL,\n    CONSTRAINT pk_issues PRIMARY KEY (id),\n    CONSTRAINT fk_issues_journal_id FOREIGN KEY (journal_id) REFERENCES journals (id)\n);\n\nCREATE TABLE contributions (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    abstract TEXT,\n    submission_date DATE NOT NULL,\n    review_status VARCHAR(255) NOT NULL,\n    contribution_type VARCHAR(255) NOT NULL,\n    issue_id INTEGER,\n    CONSTRAINT pk_contributions PRIMARY KEY (id),\n    CONSTRAINT fk_contributions_issue_id FOREIGN KEY (issue_id) REFERENCES issues (id)\n);\n\nCREATE TABLE researchers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    orcid VARCHAR(255),\n    CONSTRAINT pk_researchers PRIMARY KEY (id)\n);\n\nCREATE TABLE contribution_researchers (\n    contribution_id INTEGER NOT NULL,\n    researcher_id INTEGER NOT NULL,\n    author_order INTEGER NOT NULL,\n    role VARCHAR(255),\n    CONSTRAINT pk_contribution_researchers PRIMARY KEY (contribution_id, researcher_id),\n    CONSTRAINT fk_contribution_researchers_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id),\n    CONSTRAINT fk_contribution_researchers_researcher_id FOREIGN KEY (researcher_id) REFERENCES researchers (id)\n);\n\nCREATE TABLE topics (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_topics PRIMARY KEY (id)\n);\n\nCREATE TABLE contribution_topics (\n    contribution_id INTEGER NOT NULL,\n    topic_id INTEGER NOT NULL,\n    CONSTRAINT pk_contribution_topics PRIMARY KEY (contribution_id, topic_id),\n    CONSTRAINT fk_contribution_topics_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id),\n    CONSTRAINT fk_contribution_topics_topic_id FOREIGN KEY (topic_id) REFERENCES topics (id)\n);\n\nCREATE TABLE decisions (\n    id INTEGER NOT NULL,\n    contribution_id INTEGER NOT NULL,\n    decision_type VARCHAR(255) NOT NULL,\n    decision_date DATE NOT NULL,\n    CONSTRAINT pk_decisions PRIMARY KEY (id),\n    CONSTRAINT fk_decisions_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id)\n);\n\nCREATE TABLE editors (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    orcid VARCHAR(255),\n    CONSTRAINT pk_editors PRIMARY KEY (id)\n);\n\nCREATE TABLE institutions (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    city VARCHAR(255) NOT NULL,\n    country VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_institutions PRIMARY KEY (id)\n);\n\nCREATE TABLE journal_editors (\n    journal_id INTEGER NOT NULL,\n    editor_id INTEGER NOT NULL,\n    CONSTRAINT pk_journal_editors PRIMARY KEY (journal_id, editor_id),\n    CONSTRAINT fk_journal_editors_journal_id FOREIGN KEY (journal_id) REFERENCES journals (id),\n    CONSTRAINT fk_journal_editors_editor_id FOREIGN KEY (editor_id) REFERENCES editors (id)\n);\n\nCREATE TABLE researcher_institutions (\n    researcher_id INTEGER NOT NULL,\n    institution_id INTEGER NOT NULL,\n    is_primary_affiliation BOOLEAN,\n    CONSTRAINT pk_researcher_institutions PRIMARY KEY (researcher_id, institution_id),\n    CONSTRAINT fk_researcher_institutions_researcher_id FOREIGN KEY (researcher_id) REFERENCES researchers (id),\n    CONSTRAINT fk_researcher_institutions_institution_id FOREIGN KEY (institution_id) REFERENCES institutions (id)\n);\n\nCREATE TABLE reviews (\n    id INTEGER NOT NULL,\n    contribution_id INTEGER NOT NULL,\n    editor_id INTEGER NOT NULL,\n    request_timestamp TIMESTAMP NOT NULL,\n    submission_date DATE,\n    recommendation VARCHAR(255),\n    comment TEXT,\n    is_anonymous BOOLEAN,\n    CONSTRAINT pk_reviews PRIMARY KEY (id),\n    CONSTRAINT fk_reviews_contribution_id FOREIGN KEY (contribution_id) REFERENCES contributions (id),\n    CONSTRAINT fk_reviews_editor_id FOREIGN KEY (editor_id) REFERENCES editors (id)\n);\n",
