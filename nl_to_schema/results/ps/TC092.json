    "final_ddl": "CREATE TABLE persons (\n    id VARCHAR(255) NOT NULL,\n    birthdate DATE,\n    biological_sex VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE studies (\n    id VARCHAR(255) NOT NULL,\n    study_code VARCHAR(255) NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    CONSTRAINT pk_studies PRIMARY KEY (id)\n);\n\nCREATE TABLE institutions (\n    id VARCHAR(255) NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255),\n    category VARCHAR(255),\n    CONSTRAINT pk_institutions PRIMARY KEY (id)\n);\n\nCREATE TABLE samples (\n    id VARCHAR(255) NOT NULL,\n    person_id VARCHAR(255) NOT NULL,\n    study_id VARCHAR(255) NOT NULL,\n    sample_type VARCHAR(255) NOT NULL,\n    collection_date DATE NOT NULL,\n    processing_method VARCHAR(255),\n    quality_values TEXT,\n    source_institution_id VARCHAR(255),\n    CONSTRAINT pk_samples PRIMARY KEY (id),\n    CONSTRAINT fk_samples_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_samples_study_id FOREIGN KEY (study_id) REFERENCES studies (id),\n    CONSTRAINT fk_samples_source_institution_id FOREIGN KEY (source_institution_id) REFERENCES institutions (id)\n);\n\nCREATE TABLE aliquots (\n    id VARCHAR(255) NOT NULL,\n    parent_sample_id VARCHAR(255) NOT NULL,\n    division_date DATE NOT NULL,\n    CONSTRAINT pk_aliquots PRIMARY KEY (id),\n    CONSTRAINT fk_aliquots_parent_sample_id FOREIGN KEY (parent_sample_id) REFERENCES samples (id)\n);\n\nCREATE TABLE consents (\n    id VARCHAR(255) NOT NULL,\n    person_id VARCHAR(255) NOT NULL,\n    study_id VARCHAR(255),\n    consent_date DATE NOT NULL,\n    withdrawal_date DATE,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_consents PRIMARY KEY (id),\n    CONSTRAINT fk_consents_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_consents_study_id FOREIGN KEY (study_id) REFERENCES studies (id)\n);\n\nCREATE TABLE containers (\n    id VARCHAR(255) NOT NULL,\n    type VARCHAR(255),\n    sample_id VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_containers PRIMARY KEY (id),\n    CONSTRAINT fk_containers_sample_id FOREIGN KEY (sample_id) REFERENCES samples (id)\n);\n\nCREATE TABLE storage_locations (\n    id VARCHAR(255) NOT NULL,\n    type VARCHAR(255),\n    description TEXT,\n    CONSTRAINT pk_storage_locations PRIMARY KEY (id)\n);\n\nCREATE TABLE container_locations (\n    id VARCHAR(255) NOT NULL,\n    container_id VARCHAR(255) NOT NULL,\n    storage_location_id VARCHAR(255) NOT NULL,\n    placement_date TIMESTAMP NOT NULL,\n    CONSTRAINT pk_container_locations PRIMARY KEY (id),\n    CONSTRAINT fk_container_locations_container_id FOREIGN KEY (container_id) REFERENCES containers (id),\n    CONSTRAINT fk_container_locations_storage_location_id FOREIGN KEY (storage_location_id) REFERENCES storage_locations (id)\n);\n\nCREATE TABLE diagnoses (\n    id VARCHAR(255) NOT NULL,\n    icd_code VARCHAR(255),\n    freetext_description TEXT,\n    CONSTRAINT pk_diagnoses PRIMARY KEY (id)\n);\n\nCREATE TABLE person_diagnoses (\n    person_id VARCHAR(255) NOT NULL,\n    diagnosis_id VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_person_diagnoses PRIMARY KEY (person_id, diagnosis_id),\n    CONSTRAINT fk_person_diagnoses_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_diagnoses_diagnosis_id FOREIGN KEY (diagnosis_id) REFERENCES diagnoses (id)\n);\n\nCREATE TABLE person_studies (\n    person_id VARCHAR(255) NOT NULL,\n    study_id VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_person_studies PRIMARY KEY (person_id, study_id),\n    CONSTRAINT fk_person_studies_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_studies_study_id FOREIGN KEY (study_id) REFERENCES studies (id)\n);\n\nCREATE TABLE sample_diagnoses (\n    sample_id VARCHAR(255) NOT NULL,\n    diagnosis_id VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_sample_diagnoses PRIMARY KEY (sample_id, diagnosis_id),\n    CONSTRAINT fk_sample_diagnoses_sample_id FOREIGN KEY (sample_id) REFERENCES samples (id),\n    CONSTRAINT fk_sample_diagnoses_diagnosis_id FOREIGN KEY (diagnosis_id) REFERENCES diagnoses (id)\n);\n\nCREATE TABLE study_institutions (\n    study_id VARCHAR(255) NOT NULL,\n    institution_id VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_study_institutions PRIMARY KEY (study_id, institution_id),\n    CONSTRAINT fk_study_institutions_study_id FOREIGN KEY (study_id) REFERENCES studies (id),\n    CONSTRAINT fk_study_institutions_institution_id FOREIGN KEY (institution_id) REFERENCES institutions (id)\n);\n",
