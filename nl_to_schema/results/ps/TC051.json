 skills (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_skills PRIMARY KEY (id)\n);\n\nCREATE TABLE professional_skills (\n    professional_id INTEGER NOT NULL,\n    skill_id INTEGER NOT NULL,\n    CONSTRAINT pk_professional_skills PRIMARY KEY (professional_id, skill_id),\n    CONSTRAINT fk_professional_skills_professional_id FOREIGN KEY (professional_id) REFERENCES professionals (id),\n    CONSTRAINT fk_professional_skills_skill_id FOREIGN KEY (skill_id) REFERENCES skills (id)\n);\n",
