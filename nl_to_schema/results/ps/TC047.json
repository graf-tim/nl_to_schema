    "final_ddl": "CREATE TABLE areas (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_areas PRIMARY KEY (id)\n);\n\nCREATE TABLE priorities (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    level INTEGER NOT NULL,\n    CONSTRAINT pk_priorities PRIMARY KEY (id)\n);\n\nCREATE TABLE processing_statuses (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_processing_statuses PRIMARY KEY (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    area_id INTEGER NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id),\n    CONSTRAINT fk_employees_area_id FOREIGN KEY (area_id) REFERENCES areas (id)\n);\n\nCREATE TABLE tickets (\n    id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    priority_id INTEGER NOT NULL,\n    area_id INTEGER NOT NULL,\n    processing_status_id INTEGER NOT NULL,\n    reporter_id INTEGER NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    completed_at TIMESTAMP,\n    CONSTRAINT pk_tickets PRIMARY KEY (id),\n    CONSTRAINT fk_tickets_priority_id FOREIGN KEY (priority_id) REFERENCES priorities (id),\n    CONSTRAINT fk_tickets_area_id FOREIGN KEY (area_id) REFERENCES areas (id),\n    CONSTRAINT fk_tickets_processing_status_id FOREIGN KEY (processing_status_id) REFERENCES processing_statuses (id),\n    CONSTRAINT fk_tickets_reporter_id FOREIGN KEY (reporter_id) REFERENCES employees (id)\n);\n\nCREATE TABLE assignments (\n    id INTEGER NOT NULL,\n    ticket_id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    assigned_at TIMESTAMP NOT NULL,\n    CONSTRAINT pk_assignments PRIMARY KEY (id),\n    CONSTRAINT fk_assignments_ticket_id FOREIGN KEY (ticket_id) REFERENCES tickets (id),\n    CONSTRAINT fk_assignments_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id)\n);\n\nCREATE TABLE notes (\n    id INTEGER NOT NULL,\n    ticket_id INTEGER NOT NULL,\n    content TEXT NOT NULL,\n    created_at TIMESTAMP NOT NULL,\n    author_id INTEGER NOT NULL,\n    CONSTRAINT pk_notes PRIMARY KEY (id),\n    CONSTRAINT fk_notes_ticket_id FOREIGN KEY (ticket_id) REFERENCES tickets (id),\n    CONSTRAINT fk_notes_author_id FOREIGN KEY (author_id) REFERENCES employees (id)\n);\n",
