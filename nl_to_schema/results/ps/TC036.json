    "final_ddl": "CREATE TABLE subjects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_subjects PRIMARY KEY (id)\n);\n\nCREATE TABLE assessments (\n    id INTEGER NOT NULL,\n    date DATE NOT NULL,\n    topic VARCHAR(255) NOT NULL,\n    subject_id INTEGER NOT NULL,\n    CONSTRAINT pk_assessments PRIMARY KEY (id),\n    CONSTRAINT fk_assessments_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id)\n);\n\nCREATE TABLE teachers (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    hiredate DATE NOT NULL,\n    CONSTRAINT pk_teachers PRIMARY KEY (id)\n);\n\nCREATE TABLE learninggroups (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    schoolyear VARCHAR(255) NOT NULL,\n    classleader_id INTEGER NOT NULL,\n    CONSTRAINT pk_learninggroups PRIMARY KEY (id),\n    CONSTRAINT fk_learninggroups_classleader_id FOREIGN KEY (classleader_id) REFERENCES teachers (id)\n);\n\nCREATE TABLE students (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    birthdate DATE NOT NULL,\n    learninggroup_id INTEGER NOT NULL,\n    CONSTRAINT pk_students PRIMARY KEY (id),\n    CONSTRAINT fk_students_learninggroup_id FOREIGN KEY (learninggroup_id) REFERENCES learninggroups (id)\n);\n\nCREATE TABLE grades (\n    id INTEGER NOT NULL,\n    value DECIMAL(18,2) NOT NULL,\n    student_id INTEGER NOT NULL,\n    assessment_id INTEGER NOT NULL,\n    CONSTRAINT pk_grades PRIMARY KEY (id),\n    CONSTRAINT fk_grades_student_id FOREIGN KEY (student_id) REFERENCES students (id),\n    CONSTRAINT fk_grades_assessment_id FOREIGN KEY (assessment_id) REFERENCES assessments (id)\n);\n\nCREATE TABLE supervisions (\n    id INTEGER NOT NULL,\n    teacher_id INTEGER NOT NULL,\n    learninggroup_id INTEGER NOT NULL,\n    supervision_type VARCHAR(255),\n    CONSTRAINT pk_supervisions PRIMARY KEY (id),\n    CONSTRAINT fk_supervisions_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id),\n    CONSTRAINT fk_supervisions_learninggroup_id FOREIGN KEY (learninggroup_id) REFERENCES learninggroups (id)\n);\n\nCREATE TABLE teacher_subjects (\n    id INTEGER NOT NULL,\n    teacher_id INTEGER NOT NULL,\n    subject_id INTEGER NOT NULL,\n    learninggroup_id INTEGER NOT NULL,\n    CONSTRAINT pk_teacher_subjects PRIMARY KEY (id),\n    CONSTRAINT fk_teacher_subjects_teacher_id FOREIGN KEY (teacher_id) REFERENCES teachers (id),\n    CONSTRAINT fk_teacher_subjects_subject_id FOREIGN KEY (subject_id) REFERENCES subjects (id),\n    CONSTRAINT fk_teacher_subjects_learninggroup_id FOREIGN KEY (learninggroup_id) REFERENCES learninggroups (id)\n);\n",
