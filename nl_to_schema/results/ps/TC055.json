    "final_ddl": "CREATE TABLE fairs (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    venue VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_fairs PRIMARY KEY (id)\n);\n\nCREATE TABLE booths (\n    id INTEGER NOT NULL,\n    fair_id INTEGER NOT NULL,\n    hall VARCHAR(255) NOT NULL,\n    area VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_booths PRIMARY KEY (id),\n    CONSTRAINT fk_booths_fair_id FOREIGN KEY (fair_id) REFERENCES fairs (id)\n);\n\nCREATE TABLE exhibitors (\n    id INTEGER NOT NULL,\n    company_name VARCHAR(255) NOT NULL,\n    contact_person VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    address VARCHAR(255),\n    CONSTRAINT pk_exhibitors PRIMARY KEY (id)\n);\n\nCREATE TABLE exhibitor_booths (\n    exhibitor_id INTEGER NOT NULL,\n    booth_id INTEGER NOT NULL,\n    booth_number VARCHAR(255),\n    size VARCHAR(255),\n    CONSTRAINT pk_exhibitor_booths PRIMARY KEY (exhibitor_id, booth_id),\n    CONSTRAINT fk_exhibitor_booths_exhibitor_id FOREIGN KEY (exhibitor_id) REFERENCES exhibitors (id),\n    CONSTRAINT fk_exhibitor_booths_booth_id FOREIGN KEY (booth_id) REFERENCES booths (id)\n);\n\nCREATE TABLE exhibitor_fairs (\n    exhibitor_id INTEGER NOT NULL,\n    fair_id INTEGER NOT NULL,\n    registration_date DATE,\n    registration_status VARCHAR(255),\n    CONSTRAINT pk_exhibitor_fairs PRIMARY KEY (exhibitor_id, fair_id),\n    CONSTRAINT fk_exhibitor_fairs_exhibitor_id FOREIGN KEY (exhibitor_id) REFERENCES exhibitors (id),\n    CONSTRAINT fk_exhibitor_fairs_fair_id FOREIGN KEY (fair_id) REFERENCES fairs (id)\n);\n\nCREATE TABLE program_items (\n    id INTEGER NOT NULL,\n    fair_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    description TEXT,\n    start_time TIMESTAMP NOT NULL,\n    end_time TIMESTAMP NOT NULL,\n    event_date DATE NOT NULL,\n    CONSTRAINT pk_program_items PRIMARY KEY (id),\n    CONSTRAINT fk_program_items_fair_id FOREIGN KEY (fair_id) REFERENCES fairs (id)\n);\n\nCREATE TABLE exhibitor_program_items (\n    exhibitor_id INTEGER NOT NULL,\n    program_item_id INTEGER NOT NULL,\n    role VARCHAR(255),\n    CONSTRAINT pk_exhibitor_program_items PRIMARY KEY (exhibitor_id, program_item_id),\n    CONSTRAINT fk_exhibitor_program_items_exhibitor_id FOREIGN KEY (exhibitor_id) REFERENCES exhibitors (id),\n    CONSTRAINT fk_exhibitor_program_items_program_item_id FOREIGN KEY (program_item_id) REFERENCES program_items (id)\n);\n",
