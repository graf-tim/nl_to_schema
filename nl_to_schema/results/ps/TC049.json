    "final_ddl": "CREATE TABLE branches (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    location VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_branches PRIMARY KEY (id)\n);\n\nCREATE TABLE accounts (\n    id INTEGER NOT NULL,\n    account_type VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    creation_date DATE NOT NULL,\n    closure_date DATE,\n    branch_id INTEGER NOT NULL,\n    CONSTRAINT pk_accounts PRIMARY KEY (id),\n    CONSTRAINT fk_accounts_branch_id FOREIGN KEY (branch_id) REFERENCES branches (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    firstname VARCHAR(255) NOT NULL,\n    lastname VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE account_holders (\n    id INTEGER NOT NULL,\n    account_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    access_right VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_account_holders PRIMARY KEY (id),\n    CONSTRAINT fk_account_holders_account_id FOREIGN KEY (account_id) REFERENCES accounts (id),\n    CONSTRAINT fk_account_holders_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE employees (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    branch_id INTEGER NOT NULL,\n    CONSTRAINT pk_employees PRIMARY KEY (id),\n    CONSTRAINT fk_employees_branch_id FOREIGN KEY (branch_id) REFERENCES branches (id)\n);\n\nCREATE TABLE customer_care (\n    id INTEGER NOT NULL,\n    employee_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    care_since DATE NOT NULL,\n    CONSTRAINT pk_customer_care PRIMARY KEY (id),\n    CONSTRAINT fk_customer_care_employee_id FOREIGN KEY (employee_id) REFERENCES employees (id),\n    CONSTRAINT fk_customer_care_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE transactions (\n    id INTEGER NOT NULL,\n    transaction_date DATE NOT NULL,\n    amount DECIMAL(18,2) NOT NULL,\n    transaction_type VARCHAR(255) NOT NULL,\n    purpose TEXT,\n    account_id INTEGER NOT NULL,\n    CONSTRAINT pk_transactions PRIMARY KEY (id),\n    CONSTRAINT fk_transactions_account_id FOREIGN KEY (account_id) REFERENCES accounts (id)\n);\n",
