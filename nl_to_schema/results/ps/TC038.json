    "final_ddl": "CREATE TABLE brokers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    entry_date DATE NOT NULL,\n    CONSTRAINT pk_brokers PRIMARY KEY (id)\n);\n\nCREATE TABLE prospects (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    search_criteria TEXT,\n    last_contact TIMESTAMP,\n    CONSTRAINT pk_prospects PRIMARY KEY (id)\n);\n\nCREATE TABLE owners (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    phone VARCHAR(255),\n    email VARCHAR(255),\n    contact_preference VARCHAR(255),\n    CONSTRAINT pk_owners PRIMARY KEY (id)\n);\n\nCREATE TABLE properties (\n    id INTEGER NOT NULL,\n    owner_id INTEGER NOT NULL,\n    title VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    property_type VARCHAR(255) NOT NULL,\n    living_area DECIMAL(18,2) NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    price_type VARCHAR(255) NOT NULL,\n    is_available BOOLEAN NOT NULL,\n    offer_start_date DATE NOT NULL,\n    CONSTRAINT pk_properties PRIMARY KEY (id),\n    CONSTRAINT fk_properties_owner_id FOREIGN KEY (owner_id) REFERENCES owners (id)\n);\n\nCREATE TABLE interests (\n    id INTEGER NOT NULL,\n    prospect_id INTEGER NOT NULL,\n    property_id INTEGER NOT NULL,\n    interest_date DATE NOT NULL,\n    CONSTRAINT pk_interests PRIMARY KEY (id),\n    CONSTRAINT fk_interests_prospect_id FOREIGN KEY (prospect_id) REFERENCES prospects (id),\n    CONSTRAINT fk_interests_property_id FOREIGN KEY (property_id) REFERENCES properties (id)\n);\n\nCREATE TABLE property_managements (\n    id INTEGER NOT NULL,\n    broker_id INTEGER NOT NULL,\n    property_id INTEGER NOT NULL,\n    management_start_date DATE NOT NULL,\n    management_end_date DATE,\n    CONSTRAINT pk_property_managements PRIMARY KEY (id),\n    CONSTRAINT fk_property_managements_broker_id FOREIGN KEY (broker_id) REFERENCES brokers (id),\n    CONSTRAINT fk_property_managements_property_id FOREIGN KEY (property_id) REFERENCES properties (id)\n);\n\nCREATE TABLE viewings (\n    id INTEGER NOT NULL,\n    prospect_id INTEGER NOT NULL,\n    property_id INTEGER NOT NULL,\n    appointment_time TIMESTAMP NOT NULL,\n    result VARCHAR(255),\n    notes TEXT,\n    CONSTRAINT pk_viewings PRIMARY KEY (id),\n    CONSTRAINT fk_viewings_prospect_id FOREIGN KEY (prospect_id) REFERENCES prospects (id),\n    CONSTRAINT fk_viewings_property_id FOREIGN KEY (property_id) REFERENCES properties (id)\n);\n\nCREATE TABLE viewing_brokers (\n    viewing_id INTEGER NOT NULL,\n    broker_id INTEGER NOT NULL,\n    CONSTRAINT pk_viewing_brokers PRIMARY KEY (viewing_id, broker_id),\n    CONSTRAINT fk_viewing_brokers_viewing_id FOREIGN KEY (viewing_id) REFERENCES viewings (id),\n    CONSTRAINT fk_viewing_brokers_broker_id FOREIGN KEY (broker_id) REFERENCES brokers (id)\n);\n",
