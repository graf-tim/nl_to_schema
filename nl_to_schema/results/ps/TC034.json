    "final_ddl": "CREATE TABLE guests (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    email VARCHAR(255) NOT NULL,\n    phone VARCHAR(255) NOT NULL,\n    address TEXT,\n    CONSTRAINT pk_guests PRIMARY KEY (id)\n);\n\nCREATE TABLE categories (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    price_per_night DECIMAL(18,2) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_categories PRIMARY KEY (id)\n);\n\nCREATE TABLE rooms (\n    id INTEGER NOT NULL,\n    room_number VARCHAR(255) NOT NULL,\n    floor INTEGER NOT NULL,\n    max_persons INTEGER NOT NULL,\n    category_id INTEGER NOT NULL,\n    CONSTRAINT pk_rooms PRIMARY KEY (id),\n    CONSTRAINT fk_rooms_category_id FOREIGN KEY (category_id) REFERENCES categories (id)\n);\n\nCREATE TABLE bookings (\n    id INTEGER NOT NULL,\n    guest_id INTEGER NOT NULL,\n    room_id INTEGER NOT NULL,\n    checkin_date DATE NOT NULL,\n    checkout_date DATE NOT NULL,\n    booking_timestamp TIMESTAMP NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_bookings PRIMARY KEY (id),\n    CONSTRAINT fk_bookings_guest_id FOREIGN KEY (guest_id) REFERENCES guests (id),\n    CONSTRAINT fk_bookings_room_id FOREIGN KEY (room_id) REFERENCES rooms (id)\n);\n\nCREATE TABLE services (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    price DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_services PRIMARY KEY (id)\n);\n\nCREATE TABLE booking_services (\n    id INTEGER NOT NULL,\n    booking_id INTEGER NOT NULL,\n    service_id INTEGER NOT NULL,\n    quantity INTEGER,\n    num_days INTEGER,\n    CONSTRAINT pk_booking_services PRIMARY KEY (id),\n    CONSTRAINT fk_booking_services_booking_id FOREIGN KEY (booking_id) REFERENCES bookings (id),\n    CONSTRAINT fk_booking_services_service_id FOREIGN KEY (service_id) REFERENCES services (id)\n);\n\nCREATE TABLE room_unavailability (\n    id INTEGER NOT NULL,\n    room_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    reason VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_room_unavailability PRIMARY KEY (id),\n    CONSTRAINT fk_room_unavailability_room_id FOREIGN KEY (room_id) REFERENCES rooms (id)\n);\n",
