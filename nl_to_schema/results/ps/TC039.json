    "final_ddl": "CREATE TABLE destinations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    country VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_destinations PRIMARY KEY (id)\n);\n\nCREATE TABLE travels (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    startdate DATE NOT NULL,\n    enddate DATE NOT NULL,\n    baseprice DECIMAL(18,2) NOT NULL,\n    destination_id INTEGER NOT NULL,\n    CONSTRAINT pk_travels PRIMARY KEY (id),\n    CONSTRAINT fk_travels_destination_id FOREIGN KEY (destination_id) REFERENCES destinations (id)\n);\n\nCREATE TABLE customers (\n    id INTEGER NOT NULL,\n    email VARCHAR(255),\n    phone VARCHAR(255),\n    address VARCHAR(255),\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE bookings (\n    id INTEGER NOT NULL,\n    travel_id INTEGER NOT NULL,\n    customer_id INTEGER NOT NULL,\n    bookingdate TIMESTAMP NOT NULL,\n    paid BOOLEAN NOT NULL,\n    CONSTRAINT pk_bookings PRIMARY KEY (id),\n    CONSTRAINT fk_bookings_travel_id FOREIGN KEY (travel_id) REFERENCES travels (id),\n    CONSTRAINT fk_bookings_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE travelers (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    birthdate DATE NOT NULL,\n    CONSTRAINT pk_travelers PRIMARY KEY (id)\n);\n\nCREATE TABLE booking_travelers (\n    booking_id INTEGER NOT NULL,\n    traveler_id INTEGER NOT NULL,\n    CONSTRAINT pk_booking_travelers PRIMARY KEY (booking_id, traveler_id),\n    CONSTRAINT fk_booking_travelers_booking_id FOREIGN KEY (booking_id) REFERENCES bookings (id),\n    CONSTRAINT fk_booking_travelers_traveler_id FOREIGN KEY (traveler_id) REFERENCES travelers (id)\n);\n\nCREATE TABLE service_partners (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    partnertype VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_service_partners PRIMARY KEY (id)\n);\n\nCREATE TABLE travel_service_partners (\n    travel_id INTEGER NOT NULL,\n    service_partner_id INTEGER NOT NULL,\n    servicetype VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_travel_service_partners PRIMARY KEY (travel_id, service_partner_id),\n    CONSTRAINT fk_travel_service_partners_travel_id FOREIGN KEY (travel_id) REFERENCES travels (id),\n    CONSTRAINT fk_travel_service_partners_service_partner_id FOREIGN KEY (service_partner_id) REFERENCES service_partners (id)\n);\n",
