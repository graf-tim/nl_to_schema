    "final_ddl": "CREATE TABLE product_families (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_product_families PRIMARY KEY (id)\n);\n\nCREATE TABLE articles (\n    id VARCHAR(255) NOT NULL,\n    product_family_id INTEGER NOT NULL,\n    planning_status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_articles PRIMARY KEY (id),\n    CONSTRAINT fk_articles_product_family_id FOREIGN KEY (product_family_id) REFERENCES product_families (id)\n);\n\nCREATE TABLE components (\n    id VARCHAR(255) NOT NULL,\n    unit VARCHAR(255),\n    CONSTRAINT pk_components PRIMARY KEY (id)\n);\n\nCREATE TABLE bill_of_materials (\n    id INTEGER NOT NULL,\n    article_id VARCHAR(255) NOT NULL,\n    component_id VARCHAR(255) NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    unit VARCHAR(255),\n    CONSTRAINT pk_bill_of_materials PRIMARY KEY (id),\n    CONSTRAINT fk_bill_of_materials_article_id FOREIGN KEY (article_id) REFERENCES articles (id),\n    CONSTRAINT fk_bill_of_materials_component_id FOREIGN KEY (component_id) REFERENCES components (id)\n);\n\nCREATE TABLE machines (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_machines PRIMARY KEY (id)\n);\n\nCREATE TABLE machine_availabilities (\n    id INTEGER NOT NULL,\n    machine_id INTEGER NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    available_hours DECIMAL(18,2) NOT NULL,\n    CONSTRAINT pk_machine_availabilities PRIMARY KEY (id),\n    CONSTRAINT fk_machine_availabilities_machine_id FOREIGN KEY (machine_id) REFERENCES machines (id)\n);\n\nCREATE TABLE production_orders (\n    id VARCHAR(255) NOT NULL,\n    article_id VARCHAR(255) NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_production_orders PRIMARY KEY (id),\n    CONSTRAINT fk_production_orders_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE material_reservations (\n    id INTEGER NOT NULL,\n    production_order_id VARCHAR(255) NOT NULL,\n    component_id VARCHAR(255) NOT NULL,\n    quantity DECIMAL(18,2) NOT NULL,\n    storage_location VARCHAR(255),\n    CONSTRAINT pk_material_reservations PRIMARY KEY (id),\n    CONSTRAINT fk_material_reservations_production_order_id FOREIGN KEY (production_order_id) REFERENCES production_orders (id),\n    CONSTRAINT fk_material_reservations_component_id FOREIGN KEY (component_id) REFERENCES components (id)\n);\n\nCREATE TABLE work_plans (\n    id INTEGER NOT NULL,\n    article_id VARCHAR(255) NOT NULL,\n    version VARCHAR(255) NOT NULL,\n    release_status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_work_plans PRIMARY KEY (id),\n    CONSTRAINT fk_work_plans_article_id FOREIGN KEY (article_id) REFERENCES articles (id)\n);\n\nCREATE TABLE operations (\n    id INTEGER NOT NULL,\n    work_plan_id INTEGER NOT NULL,\n    operation_type VARCHAR(255) NOT NULL,\n    sequence INTEGER NOT NULL,\n    CONSTRAINT pk_operations PRIMARY KEY (id),\n    CONSTRAINT fk_operations_work_plan_id FOREIGN KEY (work_plan_id) REFERENCES work_plans (id)\n);\n\nCREATE TABLE operation_machines (\n    id INTEGER NOT NULL,\n    operation_id INTEGER NOT NULL,\n    machine_id INTEGER NOT NULL,\n    CONSTRAINT pk_operation_machines PRIMARY KEY (id),\n    CONSTRAINT fk_operation_machines_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_operation_machines_machine_id FOREIGN KEY (machine_id) REFERENCES machines (id)\n);\n\nCREATE TABLE order_operations (\n    id INTEGER NOT NULL,\n    production_order_id VARCHAR(255) NOT NULL,\n    operation_id INTEGER,\n    machine_id INTEGER NOT NULL,\n    sequence INTEGER NOT NULL,\n    CONSTRAINT pk_order_operations PRIMARY KEY (id),\n    CONSTRAINT fk_order_operations_production_order_id FOREIGN KEY (production_order_id) REFERENCES production_orders (id),\n    CONSTRAINT fk_order_operations_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_order_operations_machine_id FOREIGN KEY (machine_id) REFERENCES machines (id)\n);\n",
