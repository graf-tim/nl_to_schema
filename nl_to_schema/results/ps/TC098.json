    "final_ddl": "CREATE TABLE events (\n    id INTEGER NOT NULL,\n    event_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_events PRIMARY KEY (id)\n);\n\nCREATE TABLE operations (\n    id INTEGER NOT NULL,\n    timestamp TIMESTAMP NOT NULL,\n    keyword VARCHAR(255) NOT NULL,\n    priority VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    location VARCHAR(255),\n    event_id INTEGER,\n    CONSTRAINT pk_operations PRIMARY KEY (id),\n    CONSTRAINT fk_operations_event_id FOREIGN KEY (event_id) REFERENCES events (id)\n);\n\nCREATE TABLE calls (\n    id INTEGER NOT NULL,\n    timestamp TIMESTAMP NOT NULL,\n    caller VARCHAR(255),\n    location VARCHAR(255),\n    operation_id INTEGER,\n    CONSTRAINT pk_calls PRIMARY KEY (id),\n    CONSTRAINT fk_calls_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id)\n);\n\nCREATE TABLE measures (\n    id INTEGER NOT NULL,\n    measure_type VARCHAR(255) NOT NULL,\n    description TEXT,\n    timestamp TIMESTAMP NOT NULL,\n    operation_id INTEGER NOT NULL,\n    CONSTRAINT pk_measures PRIMARY KEY (id),\n    CONSTRAINT fk_measures_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id)\n);\n\nCREATE TABLE organisations (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    organisation_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_organisations PRIMARY KEY (id)\n);\n\nCREATE TABLE operation_organisations (\n    operation_id INTEGER NOT NULL,\n    organisation_id INTEGER NOT NULL,\n    CONSTRAINT pk_operation_organisations PRIMARY KEY (operation_id, organisation_id),\n    CONSTRAINT fk_operation_organisations_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_operation_organisations_organisation_id FOREIGN KEY (organisation_id) REFERENCES organisations (id)\n);\n\nCREATE TABLE persons (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_persons PRIMARY KEY (id)\n);\n\nCREATE TABLE operation_persons (\n    operation_id INTEGER NOT NULL,\n    person_id INTEGER NOT NULL,\n    function VARCHAR(255),\n    CONSTRAINT pk_operation_persons PRIMARY KEY (operation_id, person_id),\n    CONSTRAINT fk_operation_persons_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_operation_persons_person_id FOREIGN KEY (person_id) REFERENCES persons (id)\n);\n\nCREATE TABLE vehicles (\n    id INTEGER NOT NULL,\n    vehicle_type VARCHAR(255) NOT NULL,\n    license_plate VARCHAR(255) NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    organisation_id INTEGER NOT NULL,\n    CONSTRAINT pk_vehicles PRIMARY KEY (id),\n    CONSTRAINT fk_vehicles_organisation_id FOREIGN KEY (organisation_id) REFERENCES organisations (id)\n);\n\nCREATE TABLE units (\n    id INTEGER NOT NULL,\n    unit_type VARCHAR(255) NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    vehicle_id INTEGER,\n    CONSTRAINT pk_units PRIMARY KEY (id),\n    CONSTRAINT fk_units_vehicle_id FOREIGN KEY (vehicle_id) REFERENCES vehicles (id)\n);\n\nCREATE TABLE operation_units (\n    operation_id INTEGER NOT NULL,\n    unit_id INTEGER NOT NULL,\n    CONSTRAINT pk_operation_units PRIMARY KEY (operation_id, unit_id),\n    CONSTRAINT fk_operation_units_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_operation_units_unit_id FOREIGN KEY (unit_id) REFERENCES units (id)\n);\n\nCREATE TABLE qualifications (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    description TEXT,\n    CONSTRAINT pk_qualifications PRIMARY KEY (id)\n);\n\nCREATE TABLE person_qualifications (\n    person_id INTEGER NOT NULL,\n    qualification_id INTEGER NOT NULL,\n    CONSTRAINT pk_person_qualifications PRIMARY KEY (person_id, qualification_id),\n    CONSTRAINT fk_person_qualifications_person_id FOREIGN KEY (person_id) REFERENCES persons (id),\n    CONSTRAINT fk_person_qualifications_qualification_id FOREIGN KEY (qualification_id) REFERENCES qualifications (id)\n);\n\nCREATE TABLE status_messages (\n    id INTEGER NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    timestamp TIMESTAMP NOT NULL,\n    source VARCHAR(255),\n    operation_id INTEGER NOT NULL,\n    unit_id INTEGER,\n    CONSTRAINT pk_status_messages PRIMARY KEY (id),\n    CONSTRAINT fk_status_messages_operation_id FOREIGN KEY (operation_id) REFERENCES operations (id),\n    CONSTRAINT fk_status_messages_unit_id FOREIGN KEY (unit_id) REFERENCES units (id)\n);\n",
