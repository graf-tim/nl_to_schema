    "final_ddl": "CREATE TABLE customers (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    customer_type VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_customers PRIMARY KEY (id)\n);\n\nCREATE TABLE connections (\n    id INTEGER NOT NULL,\n    tariff VARCHAR(255) NOT NULL,\n    activation_date DATE NOT NULL,\n    technical_status VARCHAR(255) NOT NULL,\n    customer_id INTEGER NOT NULL,\n    CONSTRAINT pk_connections PRIMARY KEY (id),\n    CONSTRAINT fk_connections_customer_id FOREIGN KEY (customer_id) REFERENCES customers (id)\n);\n\nCREATE TABLE sites (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    address VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    commissioning_date DATE NOT NULL,\n    is_active BOOLEAN NOT NULL,\n    CONSTRAINT pk_sites PRIMARY KEY (id)\n);\n\nCREATE TABLE connection_sites (\n    connection_id INTEGER NOT NULL,\n    site_id INTEGER NOT NULL,\n    CONSTRAINT pk_connection_sites PRIMARY KEY (connection_id, site_id),\n    CONSTRAINT fk_connection_sites_connection_id FOREIGN KEY (connection_id) REFERENCES connections (id),\n    CONSTRAINT fk_connection_sites_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE devices (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    type VARCHAR(255) NOT NULL,\n    commissioning_date DATE NOT NULL,\n    decommissioning_date DATE,\n    site_id INTEGER NOT NULL,\n    CONSTRAINT pk_devices PRIMARY KEY (id),\n    CONSTRAINT fk_devices_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE radio_cells (\n    id INTEGER NOT NULL,\n    identifier VARCHAR(255) NOT NULL,\n    technology VARCHAR(255) NOT NULL,\n    sector_designation VARCHAR(255) NOT NULL,\n    status VARCHAR(255) NOT NULL,\n    site_id INTEGER NOT NULL,\n    CONSTRAINT pk_radio_cells PRIMARY KEY (id),\n    CONSTRAINT fk_radio_cells_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE device_radio_cells (\n    device_id INTEGER NOT NULL,\n    radio_cell_id INTEGER NOT NULL,\n    CONSTRAINT pk_device_radio_cells PRIMARY KEY (device_id, radio_cell_id),\n    CONSTRAINT fk_device_radio_cells_device_id FOREIGN KEY (device_id) REFERENCES devices (id),\n    CONSTRAINT fk_device_radio_cells_radio_cell_id FOREIGN KEY (radio_cell_id) REFERENCES radio_cells (id)\n);\n\nCREATE TABLE frequency_bands (\n    id INTEGER NOT NULL,\n    designation VARCHAR(255) NOT NULL,\n    frequency_range VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_frequency_bands PRIMARY KEY (id)\n);\n\nCREATE TABLE incidents (\n    id INTEGER NOT NULL,\n    report_date TIMESTAMP NOT NULL,\n    priority VARCHAR(255) NOT NULL,\n    description TEXT NOT NULL,\n    processing_status VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_incidents PRIMARY KEY (id)\n);\n\nCREATE TABLE incident_connections (\n    incident_id INTEGER NOT NULL,\n    connection_id INTEGER NOT NULL,\n    CONSTRAINT pk_incident_connections PRIMARY KEY (incident_id, connection_id),\n    CONSTRAINT fk_incident_connections_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_connections_connection_id FOREIGN KEY (connection_id) REFERENCES connections (id)\n);\n\nCREATE TABLE incident_radio_cells (\n    incident_id INTEGER NOT NULL,\n    radio_cell_id INTEGER NOT NULL,\n    CONSTRAINT pk_incident_radio_cells PRIMARY KEY (incident_id, radio_cell_id),\n    CONSTRAINT fk_incident_radio_cells_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_radio_cells_radio_cell_id FOREIGN KEY (radio_cell_id) REFERENCES radio_cells (id)\n);\n\nCREATE TABLE incident_sites (\n    incident_id INTEGER NOT NULL,\n    site_id INTEGER NOT NULL,\n    CONSTRAINT pk_incident_sites PRIMARY KEY (incident_id, site_id),\n    CONSTRAINT fk_incident_sites_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_sites_site_id FOREIGN KEY (site_id) REFERENCES sites (id)\n);\n\nCREATE TABLE technicians (\n    id INTEGER NOT NULL,\n    name VARCHAR(255) NOT NULL,\n    personnel_number VARCHAR(255) NOT NULL,\n    CONSTRAINT pk_technicians PRIMARY KEY (id)\n);\n\nCREATE TABLE incident_technicians (\n    incident_id INTEGER NOT NULL,\n    technician_id INTEGER NOT NULL,\n    CONSTRAINT pk_incident_technicians PRIMARY KEY (incident_id, technician_id),\n    CONSTRAINT fk_incident_technicians_incident_id FOREIGN KEY (incident_id) REFERENCES incidents (id),\n    CONSTRAINT fk_incident_technicians_technician_id FOREIGN KEY (technician_id) REFERENCES technicians (id)\n);\n\nCREATE TABLE radio_cell_frequency_bands (\n    radio_cell_id INTEGER NOT NULL,\n    frequency_band_id INTEGER NOT NULL,\n    CONSTRAINT pk_radio_cell_frequency_bands PRIMARY KEY (radio_cell_id, frequency_band_id),\n    CONSTRAINT fk_radio_cell_frequency_bands_radio_cell_id FOREIGN KEY (radio_cell_id) REFERENCES radio_cells (id),\n    CONSTRAINT fk_radio_cell_frequency_bands_frequency_band_id FOREIGN KEY (frequency_band_id) REFERENCES frequency_bands (id)\n);\n",
